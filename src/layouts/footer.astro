---
import logoSvg from '@/assets/icons/logo.svg'
import MyImage from '@/components/my-image.astro'
import { NewsletterForm } from '@/components/newsletter-form'
import { createTranslator, type I18n } from '@/i18n/translations'
import { getHoursForToday, getHoursSchedule, type HoursDay, type HoursRange } from '@/lib/hours'
import { getMenuNavs } from '@/lib/menu-navs'
import type { Hour } from '@/types/hours'
import { getRelativeLocaleUrl } from 'astro:i18n'
import BeHappyImg from '@/assets/imgs/sponsos/be-happy.webp'
import EuropeImg from '@/assets/imgs/sponsos/europe.webp'
import HautesPyreneesImg from '@/assets/imgs/sponsos/hautes-pyrenees.webp'
import ParcNationalImg from '@/assets/imgs/sponsos/parc-national.webp'
import OccitanieImg from '@/assets/imgs/sponsos/occitanie.webp'
import PrefetImg from '@/assets/imgs/sponsos/prefet.webp'

interface Props {
	locale: I18n
	hoursData: Hour
}

const { locale, hoursData } = Astro.props
const t = createTranslator(locale)
const menuNavs = getMenuNavs(t)
const { period } = getHoursForToday(hoursData)
const schedule = getHoursSchedule(hoursData, period)

const espacesArtistiques = menuNavs[0]?.subMenus || []
const maisonDuParc = [
	menuNavs[3],
	menuNavs[1],
	menuNavs[2],
	menuNavs[4],
	{ label: t('MENTIONS_LEGALES'), link: '/mentions-legales' }
].filter(Boolean)

const formatHourFr = (iso: string) => {
	const d = new Date(iso)
	const parts = d
		.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit', hour12: false, timeZone: 'Europe/Paris' })
		.split(':')
	const h = parseInt(parts[0], 10)
	const m = parts[1]
	return m === '00' ? `${h}h` : `${h}h${m}`
}

const formatRanges = (ranges: HoursRange[]) =>
	ranges.map((range) => `${formatHourFr(range.start)} - ${formatHourFr(range.end)}`).join(' / ')

const getHoursDayLabel = (day: HoursDay) => {
	if (day === 'wednesday') return t('MERCREDI')
	if (day === 'sunday') return t('DIMANCHE')
	return t('LUNDI_SAMEDI')
}
---

<footer class="bg-foreground text-white space-y-8 lg:space-y-14 px-5 lg:px-10 py-10 lg:py-20 mt-8 lg:mt-16 rounded-t-3xl">
	<!-- Top section: Logo, Info, Site Map, Newsletter -->
	<div class="flex flex-col lg:flex-row items-start gap-6">
		<!-- Logo -->

		<img src={logoSvg.src} width={180} alt={t('LOGO_ALT')} class="hidden lg:block" />

		<!-- Informations pratiques -->
		<div class="w-full">
			<h3 class="text-white pb-4 lg:pb-8 font-normal!">{t('INFORMATIONS_PRATIQUES')}</h3>

			<div class="grid grid-cols-1 lg:grid-cols-2 space-y-4 gap-x-20 gap-y-3">
				<div>
					<h4 class="text-white font-normal font-serif">{t('ADRESSE_DU_LIEU')}</h4>
					<hr class="mb-4 border-white/40" />
					<p class="pl-4 text-sm text-white">24, Place Saint Clément <br />65120, Luz-Saint-Sauveur</p>
				</div>

				<div>
					<h4 class="text-white font-normal font-serif">{t('ACCES')}</h4>
					<hr class="mb-4 border-white/40 text-white" />
					<p class="pl-4 text-sm text-white">{t('PARKING_OUI')}</p>
					<p class="pl-4 text-sm text-white">{t('TRANSPORT_PUBLIC')}</p>
				</div>

				<div>
					<h4 class="text-white font-normal font-serif">{t('HORAIRES')}</h4>
					<hr class="mb-4 border-white/40" />
					<div class="space-y-1 pl-4 text-sm text-white">
						{
							schedule.map((line) => (
								<p class="text-white">
									{getHoursDayLabel(line.day)} : {line.isClosed ? t('FERME') : formatRanges(line.ranges)}
								</p>
							))
						}
					</div>
				</div>
			</div>
		</div>
	</div>

	<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-20">
		<div>
			<h3 class="text-white pb-4 lg:pb-8 font-normal!">{t('PLAN_DU_SITE')}</h3>

			<div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-20">
				<div>
					<h4 class="text-white tracking-wider">{t('ESPACES_ARTISTIQUES')}</h4>
					<hr class="mb-4 border-white/40" />
					<ul class="space-y-2 pl-4">
						{
							espacesArtistiques.map((item) => (
								<li>
									<a href={getRelativeLocaleUrl(locale, item.link.replace(/^\//, ''))} class="text-sm hover:underline">
										{item.label}
									</a>
								</li>
							))
						}
					</ul>
				</div>
				<div>
					<h4 class="text-white tracking-wider">Maison du Parc</h4>
					<hr class="mb-4 border-white/40" />
					<ul class="space-y-2 pl-4">
						{
							maisonDuParc.map((item) => (
								<li>
									<a href={getRelativeLocaleUrl(locale, (item.link ?? '').replace(/^\//, ''))} class="text-sm hover:underline">
										{item.label}
									</a>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</div>
		<div>
			<h3 class="text-white pb-4 lg:pb-8 font-normal!">{t('NEWSLETTER_TITRE')}</h3>
			<p class="pb-8 text-sm text-white">{t('NEWSLETTER_INTRO')}</p>
			<NewsletterForm client:load locale={locale} variant="footer" apiBaseUrl={import.meta.env.PUBLIC_PAYLOAD_URL} />
		</div>
	</div>

	<!-- Partners section -->
	<div>
		<h3 class="text-white! pb-4 lg:pb-8 font-normal!">{t('NOS_PARTENAIRES')}</h3>

		<div class="flex flex-wrap items-center justify-center gap-4 lg:gap-5">
			<MyImage src={BeHappyImg} alt="Be Happy partenaire" width={80} height={80} class="w-12 lg:w-20 rounded-none" />
			<MyImage src={HautesPyreneesImg} alt="Hautes-Pyrénées partenaire" width={80} height={80} class="w-12 lg:w-20 rounded-none" />
			<MyImage src={OccitanieImg} alt="Parc National partenaire" width={80} height={80} class="w-12 lg:w-20 rounded-none" />
			<MyImage src={PrefetImg} alt="Préfet partenaire" width={80} height={80} class="w-12 lg:w-20 rounded-none" />
			<MyImage src={ParcNationalImg} alt="Parc National partenaire" width={160} height={80} class="w-24 lg:w-40 rounded-none" />
			<MyImage src={EuropeImg} alt="Europe partenaire" width={454} height={80} class="w-40 lg:w-auto rounded-none" />
		</div>
	</div>
</footer>
