---
import { NavigationMenuDemo } from '@/components/header-menu'
import { LanguageSelect } from '@/components/language-select'
import { MobileMenu } from '@/components/mobile-menu'
import { Button } from '@/components/ui/button'
import { createTranslator, I18n } from '@/i18n/translations'
import { getMenuNavs } from '@/lib/menu-navs'
import { getRelativeLocaleUrl } from 'astro:i18n'

import BurgerIcon from '@/assets/icons/burger.svg'
import LogoImg from '@/assets/icons/logo-icon-only.svg'
import type { Hour } from '@/types/hours'
import { ArrowRightIcon } from 'lucide-react'

interface HoursForToday {
	isClosed: boolean
	today: Date
	openStart: string | null
	openEnd: string | null
}

interface Props {
	hoursForToday: HoursForToday
	hoursData: Hour
}

const { hoursForToday, hoursData } = Astro.props
const locale = (Astro.currentLocale || 'fr') as I18n
const t = createTranslator(locale)
const menuNavs = getMenuNavs(t)
const currentPath = Astro.url.pathname
const localePrefix = getRelativeLocaleUrl(locale, '').replace(/\/$/, '')

const mobileLinks = [
	{ label: t('ART_VIVANT'), href: getRelativeLocaleUrl(locale, 'art-vivant') },
	{ label: t('CINEMA'), href: getRelativeLocaleUrl(locale, 'cinema') },
	{ label: t('MEDIATHEQUE'), href: getRelativeLocaleUrl(locale, 'mediatheque') },
	{ label: t('EXPOSITION'), href: getRelativeLocaleUrl(locale, 'exposition') },
	{ label: t('JEUNESSE'), href: getRelativeLocaleUrl(locale, 'jeune-public') },
	{ label: t('PARC_NATIONAL'), href: getRelativeLocaleUrl(locale, 'parc-national') },
	{ label: t('AUTRES_INFORMATIONS'), href: getRelativeLocaleUrl(locale, 'informations') },
	{ label: t('AUTRES_ACTUALITES'), href: getRelativeLocaleUrl(locale, 'autres-actualites') },
	{ label: t('ARCHIVES'), href: getRelativeLocaleUrl(locale, 'archives') },
	{ label: t('MENTIONS_LEGALES'), href: getRelativeLocaleUrl(locale, 'mentions-legales') }
]

const formatTime = (iso: string) =>
	new Date(iso).toLocaleTimeString(locale, { hour: '2-digit', minute: '2-digit', timeZone: 'Europe/Paris' })

const hoursInfo = {
	isClosed: hoursForToday.isClosed,
	todayLabel: hoursForToday.today.toLocaleDateString(locale, { dateStyle: 'full', timeZone: 'Europe/Paris' }),
	todayShortLabel: hoursForToday.today.toLocaleDateString(locale, { weekday: 'long', day: 'numeric', month: 'long', timeZone: 'Europe/Paris' }),
	todayIso: hoursForToday.today.toISOString().split('T')[0],
	openLabel:
		hoursForToday.openStart && hoursForToday.openEnd
			? `${formatTime(hoursForToday.openStart)} - ${formatTime(hoursForToday.openEnd)}`
			: undefined,
	openStart: hoursForToday.openStart,
	openEnd: hoursForToday.openEnd,
	baseStart: hoursData.horaires_base.base_start,
	baseEnd: hoursData.horaires_base.base_end,
	dimancheStart: hoursData.horaires_base.dimanche_start,
	dimancheEnd: hoursData.horaires_base.dimanche_end
}

---

<a
	href="#main-content"
	class="sr-only focus:not-sr-only focus:absolute focus:z-50 focus:bg-white focus:px-4 focus:py-2 focus:text-black"
	>{t('SKIP_TO_CONTENT')}</a
>
<header class="bg-primary-foreground sticky top-0 z-50 flex h-(--header-height) gap-4 rounded-b-3xl -mb-8">
	<div class="flex h-full flex-1 justify-between px-5 py-2">
		<a class="flex items-center justify-center" href={getRelativeLocaleUrl(locale, '')}
			><img src={LogoImg.src} alt={t('LOGO_ALT')} loading="eager" class="w-15" /></a
		>
		<NavigationMenuDemo
			menuNavs={menuNavs}
			localePrefix={localePrefix}
			client:media="(min-width: 1280px)"
			className="hidden lg:flex"
		/>
		<MobileMenu
			client:load
			logoSrc={LogoImg.src}
			logoAlt={t('LOGO_ALT')}
			burgerSrc={BurgerIcon.src}
			locale={locale}
			currentPath={currentPath}
			links={mobileLinks}
			homeHref={getRelativeLocaleUrl(locale, '')}
			contactHref={getRelativeLocaleUrl(locale, 'contact')}
			artisteHref={getRelativeLocaleUrl(locale, 'artiste')}
			contactLabel={t('NOUS_CONTACTER')}
			artisteLabel={t('ARTISTE')}
			hoursLabel={t('HORAIRES_OUVERTURE')}
			closedLabel={t('FERME')}
			learnMoreLabel={t('EN_SAVOIR_PLUS')}
			hoursCardLabels={{
				tabLabel: t('HORAIRES_TAB'),
				dateFromLabel: t('DATE_FROM'),
				seasonLabel: t('DE_LA_SAISON'),
				mondaySaturdayLabel: t('LUNDI_SAMEDI'),
				sundayLabel: t('DIMANCHE')
			}}
			hoursLearnMoreHref={`${getRelativeLocaleUrl(locale, 'informations')}#horaires`}
			hours={hoursInfo}
			payloadUrl={import.meta.env.PUBLIC_PAYLOAD_URL}
			className="lg:hidden"
		/>
	</div>
	<LanguageSelect
		client:media="(min-width: 1280px)"
		currentLocale={locale}
		currentPath={currentPath}
		className="hidden lg:flex self-center"
	/>
	<Button
		link={getRelativeLocaleUrl(locale, 'contact')}
		variant={'default'}
		client:media="(min-width: 1280px)"
		className="group hidden w-40 lg:flex self-center mr-6"
		>{t('NOUS_CONTACTER')}</Button
	>
</header>
