---
export const prerender = true
import { find } from '@/api/payload'

import FirstImg from '@/assets/imgs/home/1.webp'
import TenthImg from '@/assets/imgs/home/10.webp'
import EleventhImg from '@/assets/imgs/home/11.webp'
import NewsletterImg from '@/assets/imgs/newsletter.png'
import SecondImg from '@/assets/imgs/home/2.webp'
import ThirdImg from '@/assets/imgs/home/3.webp'
import FourthImg from '@/assets/imgs/home/4.webp'
import FifthImg from '@/assets/imgs/home/5.webp'
import SixthImg from '@/assets/imgs/home/6.webp'
import SeventhImg from '@/assets/imgs/home/7.webp'
import EighthImg from '@/assets/imgs/home/8.webp'
import NinthImg from '@/assets/imgs/home/9.webp'
import LayoutHome1 from '@/assets/imgs/layout_home/1.png'
import LayoutHome2 from '@/assets/imgs/layout_home/2.png'
import LayoutHome3 from '@/assets/imgs/layout_home/3.png'
import LayoutHome4 from '@/assets/imgs/layout_home/4.png'
import LayoutHome5 from '@/assets/imgs/layout_home/5.png'
import LayoutHome6 from '@/assets/imgs/layout_home/6.png'
import { HoverImageSwap } from '@/components/hover-image-swap'
import MyImage from '@/components/my-image.astro'
import { NewsletterForm } from '@/components/newsletter-form'
import SpectacleCard from '@/components/spectacle-card.astro'
import { Button } from '@/components/ui/button'
import { createTranslator, I18n } from '@/i18n/translations'
import Layout from '@/layouts/layout.astro'
import { translatePublicField } from '@/lib/translate-fields'
import type { ArtVivant } from '@/types/art-vivant'
import type { Cinema } from '@/types/cinema'
import type { ExpositionType } from '@/types/exposition'
import { renderRichText } from '@/utils/helper'
import { getRelativeLocaleUrl } from 'astro:i18n'

const locale = (Astro.currentLocale || 'fr') as I18n
const t = createTranslator(locale)

const spectacles = await find<ArtVivant>('art_vivant', {
	limit: 4,
	locale,
	where: { type: { equals: 'evenement' } }
})

const seances = await find<Cinema>('cinema', {
	limit: 4,
	locale,
	where: {
		type: { equals: 'seance' }
	}
})

const exposition = (await find<ExpositionType>('exposition/current', {
	locale
})) as unknown as ExpositionType | null

const expoImages =
	exposition?.images
		?.slice(0, 4)
		.map((i) => i.image)
		.filter((img): img is NonNullable<typeof img> => Boolean(img?.url)) ?? []

const PAYLOAD_URL = import.meta.env.PUBLIC_PAYLOAD_URL

const buildExpoRows = () => {
	const toSlot = (img: (typeof expoImages)[number], asBar = false) => ({
		src: `${PAYLOAD_URL}${img.url}`,
		alt: img.alt ?? '',
		...(asBar && { barClassName: 'bg-primary' })
	})

	if (expoImages.length === 1) {
		return [{ slots: [toSlot(expoImages[0])], height: 'h-96' }]
	}
	if (expoImages.length === 2) {
		return [
			{ slots: [toSlot(expoImages[0])], height: 'h-48' },
			{ slots: [toSlot(expoImages[1])], height: 'h-72' }
		]
	}
	if (expoImages.length === 3) {
		return [
			{ slots: [toSlot(expoImages[0])], height: 'h-48' },
			{
				slots: [toSlot(expoImages[1]), toSlot(expoImages[2], true)],
				defaultIndex: 0,
				height: 'h-72'
			}
		]
	}
	return [
		{ slots: [toSlot(expoImages[0])], height: 'h-48' },
		{
			slots: [toSlot(expoImages[1]), toSlot(expoImages[2], true), toSlot(expoImages[3], true)],
			defaultIndex: 0,
			height: 'h-72'
		}
	]
}

const expoRows = buildExpoRows()
---

<Layout title={t('ACCUEIL_TITLE')}>
	<main id="main-content">
		<section
			class="relative grid h-[calc(100dvh-var(--header-height))] max-h-225 grid-cols-40 grid-rows-40 gap-3.5 bg-[#345f6e] p-3.5 pt-11.5 *:rounded-lg lg:rounded-b-3xl"
		>
			<div class="notch-br col-span-10 col-start-1 row-span-18 row-start-1 overflow-hidden bg-[#be7a5a]">
				<img src={LayoutHome1.src} alt="" class="h-full w-full rounded-lg object-cover" />
			</div>
			<div class="col-span-11 col-start-11 row-span-16 row-start-1 relative z-20 [clip-path:inset(0_0_-0.75rem_0_round_0.5rem)] lg:[clip-path:inset(0_0_-1.5rem_0_round_0.5rem)]">
				<div class="absolute inset-0 rounded-lg bg-[#e5aa7f]"></div>
				<div class="absolute inset-x-0 top-0 z-20 h-[calc(100%+0.75rem)] lg:h-[calc(100%+1.5rem)]">
					<img src={LayoutHome2.src} alt="" class="h-full w-full object-cover object-bottom" />
				</div>
			</div>
			<div class="notch-bl col-span-19 col-start-22 row-span-20 row-start-1 overflow-hidden bg-[#f4ede1]">
				<img src={LayoutHome3.src} alt="" class="h-full w-full rounded-lg object-cover" />
			</div>
			<div class="notch-tr col-span-13 col-start-1 row-span-22 row-start-19 overflow-hidden bg-[#f4ede1]">
				<img src={LayoutHome4.src} alt="" class="h-full w-full rounded-lg object-cover" />
			</div>
			<div class="col-span-14 col-start-14 row-span-16 row-start-25 relative z-20 [clip-path:inset(-0.75rem_0_0_0_round_0.5rem)] lg:[clip-path:inset(-1.5rem_0_0_0_round_0.5rem)]">
				<div class="absolute inset-0 rounded-lg bg-[#be7a5a]"></div>
				<div class="absolute inset-x-0 bottom-0 z-20 h-[calc(100%+0.75rem)] lg:h-[calc(100%+1.5rem)]">
					<img src={LayoutHome5.src} alt="" class="h-full w-full object-cover object-top" />
				</div>
			</div>
			<div class="notch-tl col-span-13 col-start-28 row-span-20 row-start-21 overflow-hidden bg-[#e5aa7f]">
				<img src={LayoutHome6.src} alt="" class="h-full w-full rounded-lg object-cover" />
			</div>
			<div
				class="z-10 col-span-25 col-start-8 row-span-8 row-start-17 flex translate-x-[0.2rem] items-center justify-center overflow-hidden bg-[#f4ede1] p-2"
			>
				<h1 class="text-primary text-center text-3xl! leading-8 font-medium! lg:text-[42px]! lg:leading-14">
					Maison du Parc national et<br />de la vallée Luz-Saint-Sauveur
				</h1>
			</div>
		</section>

		<section class="section-default">
			<article class="grid grid-cols-1 gap-4 lg:flex">
				<div class="lg:w-2/3">
					<h2 class="pb-2 lg:pb-3">{t('ESPACE_CULTURE_TITRE')}</h2>
					<p class="distinguished pb-3 lg:pb-12">{t('ESPACE_CULTURE_INTRO')}</p>
					<p>
						{t('ESPACE_CULTURE_DESC_PART1')}<br /><br />
						{t('ESPACE_CULTURE_DESC_PART2')}<br /><br />
						{t('ESPACE_CULTURE_DESC_PART3')}<br /><br />
						{t('ESPACE_CULTURE_DESC_PART4')}<br /><br />
						{t('ESPACE_CULTURE_DESC_PART5')}
					</p>

					<Button
						link={`${getRelativeLocaleUrl(locale, 'parc-national')}#evenements`}
						className="mt-10 h-10 px-6 mb-4 lg:mb-0 lg:h-12 lg:px-8">{t('DECOUVREZ_PROCHAINS_EVENEMENTS')}</Button
					>
				</div>
				<HoverImageSwap
					client:visible
					className="lg:w-1/3"
					rows={[
						{
							slots: [
								{ src: FirstImg.src, alt: '' },
								{ src: SecondImg.src, alt: '', barClassName: 'bg-secondary-muted' }
							],
							defaultIndex: 0,
							height: 'h-48'
						},
						{
							slots: [{ src: ThirdImg.src, alt: '' }],
							height: 'h-64'
						},
						{
							slots: [
								{ src: FourthImg.src, alt: '', barClassName: 'bg-secondary-muted' },
								{ src: FifthImg.src, alt: '', barClassName: 'bg-secondary' },
								{ src: FirstImg.src, alt: '' }
							],
							defaultIndex: 2,
							height: 'h-48'
						}
					]}
				/>
			</article>
		</section>

		<section class="section-default bg-primary">
			<article class="grid grid-cols-5 gap-5">
				<div class="lg:col-span-3 col-span-5 mb-5 lg:mb-0">
					<h2 class="pb-2 lg:pb-3">{t('SPECTACLES_A_VENIR')}</h2>
					<p class="distinguished pb-3 lg:pb-12">{t('SPECTACLES_INTRO')}</p>
					<p>
						{t('SPECTACLES_DESC_PART1')}<br />
						{t('SPECTACLES_DESC_PART2')}
					</p>
				</div>
				<div class="col-span-5 grid-cols-2 lg:col-span-2 grid lg:grid-cols-5 grid-rows-3 gap-4">
					<MyImage
						alt=""
						src={EighthImg}
						width={550}
						height={400}
						layout="fullWidth"
						class="col-span-1  lg:col-span-3 row-span-3"
					/>
					<MyImage
						alt=""
						src={SeventhImg}
						width={300}
						height={270}
						layout="fullWidth"
						class="col-span-1  lg:col-span-2 row-span-2"
					/>
					<MyImage
						alt=""
						src={SixthImg}
						width={300}
						height={115}
						layout="fullWidth"
						class="col-span-1  lg:col-span-2 row-span-1"
					/>
				</div>
			</article>
			<div class="my-16 grid grid-cols-1 place-items-center gap-x-4 gap-y-8 *:max-w-80 *:min-w-[300px] md:grid-cols-2 lg:grid-cols-4">
				{
					spectacles.docs.map((item, index) => {
						const descText = item.description.root.children
							.flatMap((para) => para.children)
							.filter((child) => child.type === 'text')
							.map((child) => child.text)
							.join(' ')

						return (
							<SpectacleCard
								title={item.title}
								href={getRelativeLocaleUrl(locale, `art-vivant/spectacle/${item.id}`)}
								locale={locale}
								description={descText}
								dateStart={item.date_start}
								genre={item.genre}
								ctaLabel={t('VOIR_LA_REPRESENTATION')}
								imageSrc={item.thumbnail?.url}
								imageAlt={item.thumbnail?.alt}
								imageBlurhash={item.thumbnail?.blurhash}
								class={index >= 2 ? 'max-md:hidden' : undefined}
							/>
						)
					})
				}
			</div>

			<Button link={`${getRelativeLocaleUrl(locale, 'art-vivant')}#spectacles`} size={'xl'}
				>{t('VOIR_TOUS_SPECTACLES')}</Button
			>
		</section>

		<section>
			<div class="section-default">
				<div class="flex flex-col gap-5 lg:flex-row lg:gap-5">
					<div class="flex flex-col gap-8 lg:w-2/3">
						<div class="mb-6 pr-4">
							<h2 class="pb-2 lg:pb-3">{t('SEANCES_A_VENIR')}</h2>
							<p class="distinguished pb-3 lg:pb-12">{t('CINEMA_INTRO')}</p>
							<p>{t('CINEMA_DESC_PART1')}</p>
						</div>
						<MyImage src={TenthImg} alt="" width={1200} height={205} layout="fullWidth" />
					</div>
					<HoverImageSwap
						client:visible
						direction="vertical"
						className="lg:w-1/3"
						rows={[
							{
								slots: [
									{ src: FifthImg.src, alt: '', barClassName: 'bg-primary' },
									{ src: NinthImg.src, alt: '' },
									{ src: EleventhImg.src, alt: '', barClassName: 'bg-secondary-muted' },
									{ src: SixthImg.src, alt: '', barClassName: 'bg-secondary' }
								],
								defaultIndex: 1,
								height: 'h-[455px]'
							}
						]}
					/>
				</div>

				<div class="my-8 grid grid-cols-1 gap-3 lg:my-16 lg:grid-cols-2 lg:gap-5">
					{
						seances.docs.map((item, index, arr) => {
							const synopsisText = item.synopsis.root.children
								.flatMap((para) => para.children)
								.filter((child) => child.type === 'text')
								.map((child) => child.text)
								.join(' ')

							const isLoneOnRow = index === arr.length - 1 && arr.length % 2 === 1
							const cardClass = [isLoneOnRow && 'lg:col-span-2', index >= 2 && 'max-md:hidden']
								.filter(Boolean)
								.join(' ')

							return (
								<SpectacleCard
									title={item.title}
									href={getRelativeLocaleUrl(locale, `cinema/seance/${item.id}`)}
									locale={locale}
									description={synopsisText}
									dateStart={item.date_start}
									genre={`${translatePublicField(item.public, t)} - ${item.genre} - ${item.languages}`}
									ctaLabel={t('EN_SAVOIR_PLUS')}
									imageSrc={item.thumbnail?.url}
									imageAlt={item.thumbnail?.alt}
									imageBlurhash={item.thumbnail?.blurhash}
									height="h-[300px]"
									class={cardClass || undefined}
								/>
							)
						})
					}
				</div>
				<Button link={`${getRelativeLocaleUrl(locale, 'cinema')}#cinema`} size={'xl'} className="mt-6 lg:mt-12"
					>{t('VOIR_TOUTES_SEANCES')}</Button
				>
			</div>
		</section>

		{exposition && (
			<section class="section-default">
				<article class="grid grid-cols-1 gap-5 lg:grid-cols-2">
					<div class="flex flex-col">
						<h2 class="pb-2 lg:pb-3">{t('EXPO_MOMENT_TITRE')}</h2>
						<p class="distinguished pb-3 lg:pb-12">{exposition.title}</p>
						<p set:html={renderRichText(exposition.description)} />

						<div class="lg:mt-auto pt-12 mb-5">
							<Button link={getRelativeLocaleUrl(locale, 'exposition')} size={'xl'} className="w-fit"
								>{t('EN_SAVOIR_PLUS')}</Button
							>
						</div>
					</div>
					{expoRows.length > 0 && <HoverImageSwap client:visible rows={expoRows} />}
				</article>
			</section>
		)}

		<section class="section-default w-[358px] px-0 lg:w-auto mx-auto">
			<article class="flex bg-foreground rounded-4xl flex-col-reverse lg:flex-row w-full" >
				<div class="relative w-[358px] h-[301px] lg:h-[349.5px] lg:w-[378px] shrink-0 overflow-hidden rounded-b-4xl lg:rounded-none lg:overflow-visible">
					<div class="absolute -inset-[29px] z-1 lg:inset-auto lg:right-0 lg:bottom-0 lg:h-[calc(100%+28px)] lg:w-[calc(100%+28px)]">
						<MyImage alt="" src={NewsletterImg} width={420} height={400} layout="constrained" class='rounded-none h-full! w-full! object-cover object-left-top lg:object-center' />
					</div>
				</div>
				<div class="flex flex-col justify-center p-4 lg:p-8 mb-8 lg:mb-0">
					<h2 class="pb-3 text-white!">{t('NEWSLETTER_TITRE')}</h2>
					<p class="pb-8 text-base font-medium text-white">{t('NEWSLETTER_INTRO')}</p>
					<p class="pb-8 text-sm text-white">{t('NEWSLETTER_DESC')}</p>

					<NewsletterForm
						client:load
						locale={locale}
						variant="default"
						apiBaseUrl={import.meta.env.PUBLIC_PAYLOAD_URL}
					/>
				</div>
			</article>
		</section>
	</main>
</Layout>
