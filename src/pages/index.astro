---
export const prerender = true
import { find } from '@/api/payload'

import FirstImg from '@/assets/imgs/home/1.webp'
import TenthImg from '@/assets/imgs/home/10.webp'
import EleventhImg from '@/assets/imgs/home/11.webp'
import ThirteenthImg from '@/assets/imgs/home/13.webp'
import FourteenthImg from '@/assets/imgs/home/14.webp'
import NewsletterImg from '@/assets/imgs/newsletter.png'
import FifteenthImg from '@/assets/imgs/home/15.webp'
import SixteenthImg from '@/assets/imgs/home/16.webp'
import SecondImg from '@/assets/imgs/home/2.webp'
import ThirdImg from '@/assets/imgs/home/3.webp'
import FourthImg from '@/assets/imgs/home/4.webp'
import FifthImg from '@/assets/imgs/home/5.webp'
import SixthImg from '@/assets/imgs/home/6.webp'
import SeventhImg from '@/assets/imgs/home/7.webp'
import EighthImg from '@/assets/imgs/home/8.webp'
import NinthImg from '@/assets/imgs/home/9.webp'
import LayoutHome1 from '@/assets/imgs/layout_home/1.png'
import LayoutHome2 from '@/assets/imgs/layout_home/2.png'
import LayoutHome3 from '@/assets/imgs/layout_home/3.png'
import LayoutHome4 from '@/assets/imgs/layout_home/4.png'
import LayoutHome5 from '@/assets/imgs/layout_home/5.png'
import LayoutHome6 from '@/assets/imgs/layout_home/6.png'
import MyImage from '@/components/my-image.astro'
import { NewsletterForm } from '@/components/newsletter-form'
import { Button } from '@/components/ui/button'
import { createTranslator, I18n } from '@/i18n/translations'
import Layout from '@/layouts/layout.astro'
import { translatePublicField } from '@/lib/translate-fields'
import type { ArtVivant } from '@/types/art-vivant'
import type { Cinema } from '@/types/cinema'
import { getRelativeLocaleUrl } from 'astro:i18n'

const locale = (Astro.currentLocale || 'fr') as I18n
const t = createTranslator(locale)

const spectacles = await find<ArtVivant>('art_vivant', {
	limit: 4,
	locale,
	where: { type: { equals: 'evenement' } }
})

const seances = await find<Cinema>('cinema', {
	limit: 4,
	locale,
	where: {
		type: { equals: 'seance' }
	}
})
---

<Layout title={t('ACCUEIL_TITLE')}>
	<main id="main-content">
		<section
			class="relative grid h-[calc(100dvh-var(--header-height))] max-h-225 grid-cols-40 grid-rows-40 gap-3.5 bg-[#345f6e] p-3.5 pt-11.5 *:rounded-lg"
		>
			<div class="notch-br col-span-10 col-start-1 row-span-18 row-start-1 overflow-hidden bg-[#be7a5a]">
				<img src={LayoutHome1.src} alt="" class="h-full w-full rounded-lg object-cover" />
			</div>
			<div class="col-span-11 col-start-11 row-span-16 row-start-1 relative z-20 [clip-path:inset(0_0_-0.75rem_0_round_0.5rem)] lg:[clip-path:inset(0_0_-1.5rem_0_round_0.5rem)]">
				<div class="absolute inset-0 rounded-lg bg-[#e5aa7f]"></div>
				<div class="absolute inset-x-0 top-0 z-20 h-[calc(100%+0.75rem)] lg:h-[calc(100%+1.5rem)]">
					<img src={LayoutHome2.src} alt="" class="h-full w-full object-cover object-bottom" />
				</div>
			</div>
			<div class="notch-bl col-span-19 col-start-22 row-span-20 row-start-1 overflow-hidden bg-[#f4ede1]">
				<img src={LayoutHome3.src} alt="" class="h-full w-full rounded-lg object-cover" />
			</div>
			<div class="notch-tr col-span-13 col-start-1 row-span-22 row-start-19 overflow-hidden bg-[#f4ede1]">
				<img src={LayoutHome4.src} alt="" class="h-full w-full rounded-lg object-cover" />
			</div>
			<div class="col-span-14 col-start-14 row-span-16 row-start-25 relative z-20 [clip-path:inset(-0.75rem_0_0_0_round_0.5rem)] lg:[clip-path:inset(-1.5rem_0_0_0_round_0.5rem)]">
				<div class="absolute inset-0 rounded-lg bg-[#be7a5a]"></div>
				<div class="absolute inset-x-0 bottom-0 z-20 h-[calc(100%+0.75rem)] lg:h-[calc(100%+1.5rem)]">
					<img src={LayoutHome5.src} alt="" class="h-full w-full object-cover object-top" />
				</div>
			</div>
			<div class="notch-tl col-span-13 col-start-28 row-span-20 row-start-21 overflow-hidden bg-[#e5aa7f]">
				<img src={LayoutHome6.src} alt="" class="h-full w-full rounded-lg object-cover" />
			</div>
			<div
				class="z-10 col-span-25 col-start-8 row-span-8 row-start-17 flex translate-x-[0.2rem] items-center justify-center overflow-hidden bg-[#f4ede1] p-2"
			>
				<h1 class="text-primary text-center text-3xl! leading-8 font-medium! lg:text-[42px]! lg:leading-14">
					Maison du Parc national et<br />de la vallée Luz-Saint-Sauveur
				</h1>
			</div>
		</section>

		<section class="section-default">
			<article class="grid grid-cols-1 gap-4 lg:flex">
				<div class="lg:w-2/3">
					<h2 class="pb-2 lg:pb-3">{t('ESPACE_CULTURE_TITRE')}</h2>
					<p class="distinguished pb-3 lg:pb-12">{t('ESPACE_CULTURE_INTRO')}</p>
					<p>
						{t('ESPACE_CULTURE_DESC_PART1')}<br /><br />
						{t('ESPACE_CULTURE_DESC_PART2')}<br /><br />
						{t('ESPACE_CULTURE_DESC_PART3')}<br /><br />
						{t('ESPACE_CULTURE_DESC_PART4')}<br /><br />
						{t('ESPACE_CULTURE_DESC_PART5')}
					</p>

					<Button
						link={`${getRelativeLocaleUrl(locale, 'parc-national')}#evenements`}
						className="mt-10 h-10 px-6 lg:h-12 lg:px-8">{t('DECOUVREZ_PROCHAINS_EVENEMENTS')}</Button
					>
				</div>
				<div class="grid grid-cols-3 gap-3 lg:w-1/3 lg:gap-4">
					<MyImage alt="" src={FirstImg} width={400} height={160} layout="fullWidth" class="col-span-2 h-full!" />
					<MyImage alt="" src={SecondImg} width={200} height={160} layout="fullWidth" class="col-span-1 h-full!" />
					<MyImage alt="" src={ThirdImg} width={600} height={250} layout="fullWidth" class="col-span-3 h-full!" />
					<MyImage alt="" src={FourthImg} width={200} height={160} layout="fullWidth" class="col-span-1 h-full!" />
					<MyImage alt="" src={FifthImg} width={400} height={160} layout="fullWidth" class="col-span-2 h-full!" />
				</div>
			</article>
		</section>

		<section class="section-default bg-primary">
			<article class="grid grid-cols-1 gap-5 lg:flex">
				<div class="lg:w-7/12">
					<h2 class="pb-2 lg:pb-3">{t('SPECTACLES_A_VENIR')}</h2>
					<p class="distinguished pb-3 lg:pb-12">{t('SPECTACLES_INTRO')}</p>
					<p>
						{t('SPECTACLES_DESC_PART1')}<br />
						{t('SPECTACLES_DESC_PART2')}
					</p>
				</div>
				<div class="grid grid-cols-2 gap-3 lg:w-5/12 lg:grid-cols-5 lg:grid-rows-3 lg:gap-4">
					<MyImage
						alt=""
						src={EighthImg}
						width={550}
						height={600}
						layout="fullWidth"
						class="col-span-2 h-full! lg:col-span-3 lg:row-span-3 lg:max-h-none"
					/>
					<MyImage
						alt=""
						src={SeventhImg}
						width={300}
						height={500}
						layout="fullWidth"
						class="col-span-1 h-full! lg:col-span-2 lg:row-span-2 lg:max-h-none"
					/>
					<MyImage
						alt=""
						src={SixthImg}
						width={300}
						height={250}
						layout="fullWidth"
						class="col-span-1 h-full! lg:col-span-2 lg:row-span-1 lg:max-h-none"
					/>
				</div>
			</article>
			<div class="my-16 grid grid-cols-1 place-items-center gap-x-4 gap-y-8 *:max-w-80 md:grid-cols-2 lg:grid-cols-4">
				{
					spectacles.docs.map((item) => {
						const descText = item.description.root.children
							.flatMap((para) => para.children)
							.filter((child) => child.type === 'text')
							.map((child) => child.text)
							.join(' ')

						return (
							<article class="group shadow-card relative col-span-1 w-full overflow-hidden rounded-2xl border border-black bg-white">
								<MyImage
									src={item.thumbnail?.url}
									alt={item.thumbnail?.alt ?? t('IMAGE_PLACEHOLDER')}
									background={item.thumbnail?.blurhash}
									width={275}
									height={400}
									layout="fullWidth"
									class="rounded-2xl"
								/>
								<figure class="bg-background/90 absolute inset-x-0 bottom-0 h-auto max-h-full overflow-hidden rounded-t-2xl p-4 transition-[height] duration-300 ease-[cubic-bezier(0.2,0,0,1)] group-hover:h-full">
									<figcaption>
										<h3 class="truncate pb-3 group-hover:line-clamp-2 group-hover:whitespace-normal">
											<a
												href={getRelativeLocaleUrl(locale, `art-vivant/spectacle/${item.id}`)}
												class="after:absolute after:inset-0 after:z-10"
											>
												{item.title} fzefefe
											</a>
										</h3>
										<p class="distinguished text-secondary-muted! truncate text-xs uppercase group-hover:line-clamp-2 group-hover:whitespace-normal">{item.genre}</p>
										<time class="distinguished text-primary text-sm capitalize tabular-nums" datetime={item.date_start}>
											{new Date(item.date_start).toLocaleDateString(locale, {
												dateStyle: 'full',
												timeZone: 'Europe/Paris'
											})}{' '}
											-{' '}
											{new Date(item.date_start).toLocaleTimeString(locale, {
												hour: '2-digit',
												minute: '2-digit',
												hour12: false,
												timeZone: 'Europe/Paris'
											})}
										</time>
										<div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-[cubic-bezier(0.2,0,0,1)] group-hover:grid-rows-[1fr]">
											<div class="overflow-hidden">
												<p class="text-foreground! line-clamp-8 pt-4 text-sm">{descText}</p>
												<p class="text-secondary-muted! inline-flex items-center gap-2 pt-4 text-medium font-semibold opacity-0 transition-opacity duration-200 ease-[cubic-bezier(0.2,0,0,1)] group-hover:opacity-100 group-hover:delay-300">
													{t('VOIR_LA_REPRESENTATION')}
													<svg
														xmlns="http://www.w3.org/2000/svg"
														width="16"
														height="16"
														viewBox="0 0 24 24"
														fill="none"
														stroke="currentColor"
														stroke-width="2"
														stroke-linecap="round"
														stroke-linejoin="round"
													>
														<path d="M5 12h14" />
														<path d="m12 5 7 7-7 7" />
													</svg>
												</p>
											</div>
										</div>
									</figcaption>
								</figure>
							</article>
						)
					})
				}
			</div>

			<Button link={`${getRelativeLocaleUrl(locale, 'art-vivant')}#spectacles`} size={'xl'}
				>{t('VOIR_TOUS_SPECTACLES')}</Button
			>
		</section>

		<section>
			<div class="section-default pt-6 lg:pt-12">
				<div class="flex flex-col gap-5 lg:flex-row lg:gap-10">
					<div class="flex flex-col gap-8 lg:w-2/3">
						<div class="mb-10">
							<h2 class="pb-2 lg:pb-3">{t('SEANCES_A_VENIR')}</h2>
							<p class="distinguished pb-3 lg:pb-12">{t('CINEMA_INTRO')}</p>
							<p>{t('CINEMA_DESC_PART1')}</p>
						</div>
						<MyImage src={TenthImg} alt="" width={1200} height={200} layout="fullWidth" />
					</div>
					<div class="flex flex-col gap-5 lg:w-1/3">
						<MyImage src={NinthImg} alt="" width={600} height={150} layout="fullWidth" class="rounded-2xl" />
						<MyImage src={EleventhImg} alt="" width={600} height={150} layout="fullWidth" class="rounded-2xl" />
						<MyImage src={ThirteenthImg} alt="" width={600} height={150} layout="fullWidth" class="rounded-2xl" />
					</div>
				</div>

				<div class="my-8 grid grid-cols-1 gap-3 lg:my-16 lg:grid-cols-2 lg:gap-5">
					{
						seances.docs.map((item) => {
							const synopsisText = item.synopsis.root.children
								.flatMap((para) => para.children)
								.filter((child) => child.type === 'text')
								.map((child) => child.text)
								.join(' ')

							return (
								<article class="group relative col-span-1 w-full overflow-hidden bg-white shadow-sm">
									<div class="overflow-hidden">
										<MyImage
											src={item.thumbnail?.url}
											alt={item.thumbnail?.alt ?? t('IMAGE_PLACEHOLDER')}
											background={item.thumbnail?.blurhash}
											width={900}
											height={220}
											layout="fullWidth"
										/>
									</div>
									<figure class="p-4 transition-opacity duration-250 group-hover:opacity-0">
										<figcaption>
											<h3 class="pb-3 text-black">
												<a
													href={getRelativeLocaleUrl(locale, `cinema/seance/${item.id}`)}
													class="after:absolute after:inset-0 after:z-10"
												>
													{item.title}
												</a>
											</h3>
											<p class="distinguished text-primary pb-1 text-xs">
												{translatePublicField(item.public, t)} - {item.genre} - {item.languages}
											</p>
											<p class="font-serif text-sm capitalize">
												{new Date(item.date_start).toLocaleDateString(locale, {
													dateStyle: 'full',
													timeZone: 'Europe/Paris'
												})}{' '}
												-{' '}
												{new Date(item.date_start).toLocaleTimeString(locale, {
													hour: '2-digit',
													minute: '2-digit',
													hour12: false,
													timeZone: 'Europe/Paris'
												})}
											</p>
										</figcaption>
									</figure>
									<div class="bg-primary/80 pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-250 group-hover:opacity-100" />
									<figure class="pointer-events-none absolute inset-0 p-5 opacity-0 transition-opacity duration-250 group-hover:opacity-100">
										<figcaption class="text-white">
											<p class="line-clamp-6 text-sm">{synopsisText}</p>
											<p class="inline-flex items-center gap-2 pt-10 text-sm font-semibold underline underline-offset-2">
												{t('EN_SAVOIR_PLUS')}
												<svg
													xmlns="http://www.w3.org/2000/svg"
													width="16"
													height="16"
													viewBox="0 0 24 24"
													fill="none"
													stroke="currentColor"
													stroke-width="2"
													stroke-linecap="round"
													stroke-linejoin="round"
												>
													<path d="M5 12h14" />
													<path d="m12 5 7 7-7 7" />
												</svg>
											</p>
										</figcaption>
									</figure>
								</article>
							)
						})
					}
				</div>
				<Button link={`${getRelativeLocaleUrl(locale, 'cinema')}#cinema`} size={'xl'} className="mt-6 lg:mt-12"
					>{t('VOIR_TOUTES_SEANCES')}</Button
				>
			</div>
		</section>

		<section class="section-default">
			<article class="grid grid-cols-1 gap-5 lg:grid-cols-2">
				<div class="flex flex-col">
					<h2 class="text-secondary pb-2 lg:pb-3">{t('EXPOSITIONS_TITRE')}</h2>
					<p class="distinguished pb-3 lg:pb-12">
						{t('EXPOSITIONS_INTRO')}
					</p>
					<p>
						{t('EXPOSITIONS_DESC')}
					</p>

					<Button link={`${getRelativeLocaleUrl(locale, 'cinema')}#cinema`} size={'xl'} className="mt-auto w-fit"
						>{t('VOIR_EXPOSITION_MOMENT')}</Button
					>
				</div>
				<div class="space-y-3 lg:space-y-5">
					<div class="grid grid-cols-2 gap-3 lg:gap-5">
						<div class="space-y-3 lg:space-y-5">
							<MyImage alt="" src={ThirteenthImg} width={400} height={160} layout="fullWidth" />
							<MyImage alt="" src={FifteenthImg} width={400} height={320} layout="fullWidth" />
						</div>

						<div class="space-y-3 lg:space-y-5">
							<MyImage alt="" src={FourteenthImg} width={400} height={360} layout="fullWidth" />
							<MyImage alt="" src={SixteenthImg} width={400} height={120} layout="fullWidth" />
						</div>
					</div>
				</div>
			</article>
		</section>

		<section class="section-default">
			<article class="flex bg-foreground rounded-4xl" >
				<div class="relative h-[349.5px] w-[378px] shrink-0 ">
					<div class="absolute right-0 bottom-0 z-1 h-[calc(100%+28px)] w-[calc(100%+28px)]">
						<MyImage alt="" src={NewsletterImg} width={420} height={400} layout="fullWidth" class='rounded-none h-full!' />
					</div>
				</div>
				<div class="flex flex-col justify-center p-4 lg:p-8">
					<h2 class="pb-3 text-white!">{t('NEWSLETTER_TITRE')}</h2>
					<p class="pb-8 text-sm font-medium text-white">{t('NEWSLETTER_INTRO')}</p>
					<p class="pb-8 text-sm text-white">{t('NEWSLETTER_DESC')}</p>

					<NewsletterForm
						client:load
						locale={locale}
						variant="default"
						apiBaseUrl={import.meta.env.PUBLIC_PAYLOAD_URL}
					/>
				</div>,
			</article>
		</section>
	</main>
</Layout>
