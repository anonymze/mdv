---
export const prerender = true
import { find } from '@/api/payload'
import FirstMediaImg from '@/assets/imgs/cinema/1.webp'
import SecondMediaImg from '@/assets/imgs/cinema/2.webp'
import ThirdMediaImg from '@/assets/imgs/cinema/3.webp'
import { CinemaGrid } from '@/components/cinema-grid'
import MyImage from '@/components/my-image.astro'
import { createTranslator, I18n } from '@/i18n/translations'
import Layout from '@/layouts/layout.astro'
import type { Cinema } from '@/types/cinema'
import { getRelativeLocaleUrl } from 'astro:i18n'
const locale = (Astro.currentLocale || 'fr') as I18n
const t = createTranslator(locale)
const localePrefix = getRelativeLocaleUrl(locale, '').replace(/\/$/, '')

const SEANCES_LIMIT = 6

const seances = await find<Cinema>('cinema', {
	limit: SEANCES_LIMIT,
	page: 1,
	locale,
	where: {
		type: { equals: 'seance' }
	}
})

const rdv = await find<Cinema>('cinema', {
	limit: 4,
	locale,
	where: {
		type: { equals: 'rdv_cinema' }
	}
})
const scolaire = await find<Cinema>('cinema', {
	limit: 4,
	locale,
	where: {
		type: { equals: 'scolaire' }
	}
})

const cinemaTranslations = {
	PRECEDENT: t('PRECEDENT'),
	SUIVANT: t('SUIVANT'),
	IMAGE_PLACEHOLDER: t('IMAGE_PLACEHOLDER'),
	EN_SAVOIR_PLUS: t('EN_SAVOIR_PLUS'),
	MOTS_CLES: t('MOTS_CLES'),
	GENRE: t('GENRE'),
	TAGS_FILTER: t('TYPE_PUBLIC'),
	DATE: t('DATE'),
	AUCUN_CONTENU: t('AUCUN_CONTENU'),
	TOUS: t('TOUS'),
	publicLabels: {
		children: t('PUBLIC_ENFANTS'),
		all_public: t('PUBLIC_TOUT_PUBLIC'),
		all_public_avertissment: t('PUBLIC_TOUT_PUBLIC_AVERTISSEMENT'),
		forbidden_12: t('PUBLIC_INTERDIT_12'),
		forbidden_16: t('PUBLIC_INTERDIT_16'),
		forbidden_18: t('PUBLIC_INTERDIT_18')
	},
	genreOptions: [
		{ key: t('GENRE_COMEDIE'), value: 'Comédie' },
		{ key: t('GENRE_DRAME'), value: 'Drame' },
		{ key: t('GENRE_ACTION'), value: 'Action' },
		{ key: t('GENRE_ANIMATION'), value: 'Animation' },
		{ key: t('GENRE_DOCUMENTAIRE'), value: 'Documentaire' }
	],
	dateOptions: [
		{ key: t('DATE_SEMAINE_PROCHAINE'), value: 'semaine_prochaine' },
		{ key: t('DATE_MOIS_PROCHAIN'), value: 'mois_prochain' },
		{ key: t('DATE_6_MOIS'), value: '6_mois' },
		{ key: t('DATE_1_AN'), value: '1_an' }
	],
	LANGUE: t('LANGUE'),
	langueOptions: [
		{ key: t('LANGUE_VF'), value: 'VF' },
		{ key: t('LANGUE_VOSTFR'), value: 'VOSTFR' }
	]
}

const PAYLOAD_URL = import.meta.env.PUBLIC_PAYLOAD_URL
---

<Layout title={t('CINEMA')}>
	<main id="main-content">
		<section class="section-default" id="description">
			<h1 class="text-primary pb-8 lg:pb-20">{t('CINEMA')}</h1>
			<article class="grid grid-cols-1 gap-3 lg:grid-cols-2 lg:gap-5">
				<div class="order-1 flex flex-col">
					<p class="distinguished pb-8 lg:pb-16">{t('CINEMA_DECOUVREZ_PROGRAMME')}</p>
					<p>
						{t('CINEMA_DESC_PART1')}
						<br />
						<br />
						{t('CINEMA_DESC_PART2')}
						<br />
						<br />
						{t('CINEMA_DESC_PART3')}
					</p>
				</div>
				<div class="order-2 grid grid-cols-2 gap-2 lg:grid-cols-4 lg:grid-rows-2 lg:gap-5">
					<MyImage
						alt=""
						src={FirstMediaImg}
						width={420}
						height={670}
						layout="fullWidth"
						class="col-span-2 max-h-48 object-cover lg:row-span-2 lg:max-h-none"
					/>
					<MyImage
						alt=""
						src={SecondMediaImg}
						width={420}
						height={330}
						layout="fullWidth"
						class="col-span-2 max-h-24 object-cover lg:col-span-2 lg:row-span-1 lg:max-h-none"
					/>
					<MyImage
						alt=""
						src={ThirdMediaImg}
						width={420}
						height={320}
						layout="fullWidth"
						class="col-span-2 max-h-24 object-cover lg:row-span-1 lg:max-h-none"
					/>
				</div>
			</article>
		</section>
		<section class="section-default bg-primary/20" id="cinema">
			<article>
				<h2 class="pb-2 lg:pb-3">{t('CINEMA')}</h2>
				<p class="distinguished pb-3 lg:pb-6">{t('CINEMA_INTRO')}</p>
				<p class="lg:w-2/3">
					{t('CINEMA_DESC_PART1')}<br /><br />
					{t('CINEMA_DESC_PART2')}<br /><br />
					{t('CINEMA_DESC_PART3')}
				</p>
			</article>

			<CinemaGrid
				client:load
				initialData={seances}
				locale={locale}
				localePrefix={localePrefix}
				limit={SEANCES_LIMIT}
				payloadUrl={PAYLOAD_URL}
				showFilters={true}
				translations={cinemaTranslations}
			/>
		</section>

		<section class="section-default" id="rdv-cinema">
			<h2 class="text-secondary pb-2 lg:pb-3">{t('RDV_CINEMA')}</h2>
			<p class="distinguished pb-3 lg:pb-6">{t('RDV_CINEMA_INTRO')}</p>
			<p class="lg:w-2/3">{t('RDV_CINEMA_DESC')}</p>

			<div
				class="my-8 grid grid-cols-1 place-items-start gap-x-4 gap-y-8 *:max-w-80 md:grid-cols-2 lg:my-16 lg:grid-cols-4"
			>
				{
					rdv.docs.map((item) => {
						const descText = item.synopsis.root.children
							.flatMap((para) => para.children)
							.filter((child) => child.type === 'text')
							.map((child) => child.text)
							.join(' ')

						return (
							<article class="group relative col-span-1 w-full overflow-hidden bg-white shadow-sm">
								<div class="overflow-hidden">
									<MyImage
										src={item.thumbnail?.url}
										alt={item.thumbnail?.alt ?? t('IMAGE_PLACEHOLDER')}
										background={item.thumbnail?.blurhash}
										width={275}
										height={305}
										layout="fullWidth"
									/>
								</div>
								<figure class="p-4 transition-opacity duration-250 group-hover:opacity-0">
									<figcaption>
										<h3 class="pb-3 text-black">
											<a
												href={`${localePrefix}/cinema/rdv-cinema/${item.id}`}
												class="after:absolute after:inset-0 after:z-10"
											>
												{item.title}
											</a>
										</h3>
										<p class="distinguished text-primary pb-1 text-xs">{item.genre}</p>
										<time class="distinguished text-sm capitalize" datetime={item.date_start}>
											{new Date(item.date_start).toLocaleDateString(locale, { dateStyle: 'full', timeZone: 'Europe/Paris' })} -{' '}
											{new Date(item.date_start).toLocaleTimeString(locale, {
												hour: '2-digit',
												minute: '2-digit',
												hour12: false,
												timeZone: 'Europe/Paris'
											})}
										</time>
									</figcaption>
								</figure>
								<div class="bg-secondary/80 pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-250 group-hover:opacity-100" />
								<figure class="pointer-events-none absolute inset-0 p-5 opacity-0 transition-opacity duration-250 group-hover:opacity-100">
									<figcaption class="text-white">
										<p class="line-clamp-8 text-sm">{descText}</p>
										<p class="inline-flex items-center gap-2 pt-10 text-sm font-semibold underline underline-offset-2">
											{t('EN_SAVOIR_PLUS')}
											<svg
												xmlns="http://www.w3.org/2000/svg"
												width="16"
												height="16"
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											>
												<path d="M5 12h14" />
												<path d="m12 5 7 7-7 7" />
											</svg>
										</p>
									</figcaption>
								</figure>
							</article>
						)
					})
				}
			</div>
		</section>

		<section class="section-default bg-secondary/20" id="cinema-scolaire">
			<h2 class="text-secondary pb-2 lg:pb-3">{t('CINEMA_SCOLAIRE_TITRE')}</h2>
			<p class="distinguished pb-3 lg:pb-6">{t('CINEMA_SCOLAIRE_INTRO')}</p>
			<p class="lg:w-2/3">{t('CINEMA_SCOLAIRE_DESC')}</p>

			<div
				class="my-8 grid grid-cols-1 place-items-start gap-x-4 gap-y-8 *:max-w-80 md:grid-cols-2 lg:my-16 lg:grid-cols-4"
			>
				{
					scolaire.docs.map((item) => {
						const descText = item.synopsis.root.children
							.flatMap((para) => para.children)
							.filter((child) => child.type === 'text')
							.map((child) => child.text)
							.join(' ')

						return (
							<article class="group relative col-span-1 w-full overflow-hidden bg-white shadow-sm">
								<div class="overflow-hidden">
									<MyImage
										src={item.thumbnail?.url}
										alt={item.thumbnail?.alt ?? t('IMAGE_PLACEHOLDER')}
										background={item.thumbnail?.blurhash}
										width={275}
										height={305}
										layout="fullWidth"
									/>
								</div>
								<figure class="p-4 transition-opacity duration-250 group-hover:opacity-0">
									<figcaption>
										<h3 class="pb-3 text-black">
											<a
												href={`${localePrefix}/cinema/scolaire/${item.id}`}
												class="after:absolute after:inset-0 after:z-10"
											>
												{item.title}
											</a>
										</h3>
										<p class="distinguished text-primary pb-1 text-xs">{item.genre}</p>
										<time class="distinguished text-sm capitalize" datetime={item.date_start}>
											{new Date(item.date_start).toLocaleDateString(locale, { dateStyle: 'full', timeZone: 'Europe/Paris' })} -{' '}
											{new Date(item.date_start).toLocaleTimeString(locale, {
												hour: '2-digit',
												minute: '2-digit',
												hour12: false,
												timeZone: 'Europe/Paris'
											})}
										</time>
									</figcaption>
								</figure>
								<div class="bg-secondary/80 pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-250 group-hover:opacity-100" />
								<figure class="pointer-events-none absolute inset-0 p-5 opacity-0 transition-opacity duration-250 group-hover:opacity-100">
									<figcaption class="text-white">
										<p class="line-clamp-8 text-sm">{descText}</p>
										<p class="inline-flex items-center gap-2 pt-10 text-sm font-semibold underline underline-offset-2">
											{t('EN_SAVOIR_PLUS')}
											<svg
												xmlns="http://www.w3.org/2000/svg"
												width="16"
												height="16"
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											>
												<path d="M5 12h14" />
												<path d="m12 5 7 7-7 7" />
											</svg>
										</p>
									</figcaption>
								</figure>
							</article>
						)
					})
				}
			</div>
		</section>
	</main>
</Layout>
