---
export const prerender = true
import { find } from '@/api/payload'
import FirstMediaImg from '@/assets/imgs/art_vivant/1.webp'
import SecondMediaImg from '@/assets/imgs/art_vivant/2.webp'
import ThirdMediaImg from '@/assets/imgs/art_vivant/3.webp'
import MyImage from '@/components/my-image.astro'
import { SpectaclesGrid } from '@/components/spectacles-grid'
import { createTranslator, I18n } from '@/i18n/translations'
import Layout from '@/layouts/layout.astro'
import type { ArtVivant } from '@/types/art-vivant'
import { getRelativeLocaleUrl } from 'astro:i18n'

const locale = (Astro.currentLocale || 'fr') as I18n
const t = createTranslator(locale)
const localePrefix = getRelativeLocaleUrl(locale, '').replace(/\/$/, '')

const SPECTACLES_LIMIT = 8
const RESIDENCE_LIMIT = 4

// Build time: fetch only first page
const spectacles = await find<ArtVivant>('art_vivant', {
	limit: SPECTACLES_LIMIT,
	page: 1,
	locale,
	where: {
		type: { equals: 'evenement' }
	}
})
const residences = await find<ArtVivant>('art_vivant', {
	limit: RESIDENCE_LIMIT,
	locale,
	where: {
		type: { equals: 'residence' }
	}
})

const spectacleTranslations = {
	PRECEDENT: t('PRECEDENT'),
	SUIVANT: t('SUIVANT'),
	IMAGE_PLACEHOLDER: t('IMAGE_PLACEHOLDER'),
	EN_SAVOIR_PLUS: t('EN_SAVOIR_PLUS'),
	MOTS_CLES: t('MOTS_CLES'),
	GENRE: t('GENRE'),
	DATE: t('DATE'),
	AUCUN_CONTENU: t('AUCUN_CONTENU'),
	TOUS: t('TOUS'),
	genreOptions: [
		{ key: t('SPECTACLE_GENRE_HUMOUR'), value: 'Humour' },
		{ key: t('SPECTACLE_GENRE_THEATRE'), value: 'Théâtre' },
		{ key: t('SPECTACLE_GENRE_DANSE'), value: 'Danse' },
		{ key: t('SPECTACLE_GENRE_MUSIQUE'), value: 'Musique' },
		{ key: t('SPECTACLE_GENRE_CIRQUE'), value: 'Cirque' },
		{ key: t('SPECTACLE_GENRE_CONCERT'), value: 'Concert' }
	],
	dateOptions: [
		{ key: t('DATE_SEMAINE_PROCHAINE'), value: 'semaine_prochaine' },
		{ key: t('DATE_MOIS_PROCHAIN'), value: 'mois_prochain' },
		{ key: t('DATE_6_MOIS'), value: '6_mois' },
		{ key: t('DATE_1_AN'), value: '1_an' }
	]
}

const PAYLOAD_URL = import.meta.env.PUBLIC_PAYLOAD_URL
---

<Layout title={t('ART_VIVANT')}>
	<main id="main-content">
		<section class="section-default" id="description">
			<h1 class="text-primary pb-8 lg:pb-20">{t('ART_VIVANT')}</h1>
			<article class="grid grid-cols-1 gap-3 lg:grid-cols-2 lg:gap-5">
				<div class="order-1 flex flex-col">
					<p class="distinguished pb-8 lg:pb-16">{t('SPECTACLES_INTRO')}</p>
					<p>
						{t('ART_VIVANT_DESC_PART1')}<br /><br />
						{t('ART_VIVANT_DESC_PART2')}<br /><br />
						{t('ART_VIVANT_DESC_PART3')}
					</p>
				</div>
				<div class="order-2 grid grid-cols-2 grid-rows-2 gap-2 lg:gap-5">
					<MyImage
						alt=""
						src={ThirdMediaImg}
						width={420}
						height={310}
						layout="fullWidth"
						class="col-start-1 row-start-1 h-40 w-full object-cover lg:h-full"
					/>
					<MyImage
						alt=""
						src={SecondMediaImg}
						width={420}
						height={310}
						layout="fullWidth"
						class="col-start-1 row-start-2 h-40 w-full object-cover lg:h-full"
					/>
					<MyImage
						alt=""
						src={FirstMediaImg}
						width={420}
						height={640}
						layout="fullWidth"
						class="col-start-2 row-span-2 h-80 w-full object-cover lg:h-full"
					/>
				</div>
			</article>
		</section>

		<section class="section-default bg-primary/20" id="spectacles">
			<article>
				<h2 class="pb-2 lg:pb-3">{t('SPECTACLES_A_VENIR')}</h2>
				<p class="distinguished pb-3 lg:pb-6">{t('SPECTACLES_INTRO')}</p>
				<p class="lg:w-2/3">
					{t('SPECTACLES_DESC_PART1')}<br />
					{t('SPECTACLES_DESC_PART2')}
				</p>
			</article>

			<SpectaclesGrid
				client:load
				initialData={spectacles}
				locale={locale}
				localePrefix={localePrefix}
				limit={SPECTACLES_LIMIT}
				payloadUrl={PAYLOAD_URL}
				collection="art_vivant"
				showFilters={true}
				translations={spectacleTranslations}
			/>
		</section>

		<section class="section-default" id="residence">
			<article>
				<h2 class="text-secondary pb-2 lg:pb-3">{t('RESIDENCE_ARTISTIQUE')}</h2>
				<p class="distinguished pb-3 lg:pb-6">{t('RESIDENCE_INTRO')}</p>
				<p class="lg:w-2/3">
					{t('RESIDENCE_DESC_PART1')}<br /><br />
					{t('RESIDENCE_DESC_PART2')}
				</p>
			</article>

			<div
				class="my-8 grid grid-cols-1 place-items-start gap-x-4 gap-y-8 *:max-w-80 md:grid-cols-2 lg:my-16 lg:grid-cols-4"
			>
				{
					residences.docs.map((item) => {
						const descText = item.description.root.children
							.flatMap((para) => para.children)
							.filter((child) => child.type === 'text')
							.map((child) => child.text)
							.join(' ')

						return (
							<article class="group relative col-span-1 w-full overflow-hidden bg-white shadow-sm">
								<div class="overflow-hidden">
									<MyImage
										src={item.thumbnail?.url}
										alt={item.thumbnail?.alt ?? t('IMAGE_PLACEHOLDER')}
										background={item.thumbnail?.blurhash}
										width={275}
										height={305}
										layout="fullWidth"
									/>
								</div>
								<figure class="p-4 transition-opacity duration-250 group-hover:opacity-0">
									<figcaption>
										<h3 class="pb-3 text-black">
											<a
												href={`${localePrefix}/art-vivant/residence/${item.id}`}
												class="after:absolute after:inset-0 after:z-10"
											>
												{item.title}
											</a>
										</h3>
										<p class="distinguished text-primary pb-1 text-xs">{item.genre}</p>
										<time class="distinguished text-sm capitalize" datetime={item.date_start}>
											{new Date(item.date_start).toLocaleDateString(locale, { dateStyle: 'full' })} -{' '}
											{new Date(item.date_start).toLocaleTimeString(locale, {
												hour: '2-digit',
												minute: '2-digit',
												hour12: false
											})}
										</time>
									</figcaption>
								</figure>
								<div class="bg-secondary/80 pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-250 group-hover:opacity-100" />
								<figure class="pointer-events-none absolute inset-0 p-5 opacity-0 transition-opacity duration-250 group-hover:opacity-100">
									<figcaption class="text-white">
										<p class="line-clamp-8 text-sm">{descText}</p>
										<p class="inline-flex items-center gap-2 pt-10 text-sm font-semibold underline underline-offset-2">
											{t('EN_SAVOIR_PLUS')}
											<svg
												xmlns="http://www.w3.org/2000/svg"
												width="16"
												height="16"
												viewBox="0 0 24 24"
												fill="none"
												stroke="currentColor"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											>
												<path d="M5 12h14" />
												<path d="m12 5 7 7-7 7" />
											</svg>
										</p>
									</figcaption>
								</figure>
							</article>
						)
					})
				}
			</div>
		</section>
	</main>
</Layout>
