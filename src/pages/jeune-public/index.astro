---
export const prerender = true
import { find } from '@/api/payload'
import MyImage from '@/components/my-image.astro'
import SpectacleCard from '@/components/spectacle-card.astro'
import { createTranslator, I18n } from '@/i18n/translations'
import { getRelativeLocaleUrl } from 'astro:i18n'
import Layout from '@/layouts/layout.astro'
import {
	translateLudoDuration,
	translatePublicField
} from '@/lib/translate-fields'
import type { ArtVivant } from '@/types/art-vivant'
import type { Cinema } from '@/types/cinema'
import type { Ludotheque, Mediatheque } from '@/types/mediatheque'
import LayoutHome1 from '@/assets/imgs/layout_home/1.png'
import LayoutHome2 from '@/assets/imgs/layout_home/2.png'
import LayoutHome3 from '@/assets/imgs/layout_home/3.png'
import LayoutHome4 from '@/assets/imgs/layout_home/4.png'
import LayoutHome5 from '@/assets/imgs/layout_home/5.png'
import LayoutHome6 from '@/assets/imgs/layout_home/6.png'

const locale = (Astro.currentLocale || 'fr') as I18n
const t = createTranslator(locale)

const evenements = await find<ArtVivant>('art_vivant', {
	limit: 4,
	locale,
	where: {
		type: { equals: 'evenement' },
		jeunePublic: { equals: true }
	}
})

const ludotheque = await find<Ludotheque>('mediatheque', {
	limit: 3,
	locale,
	upcomingOnly: false,
	where: {
		type: { equals: 'ludotheque' },
		jeunePublic: { equals: true }
	}
})

const cinema = await find<Cinema>('cinema', {
	limit: 4,
	locale,
	where: {
		jeunePublic: { equals: true }
	}
})
---

<Layout title={t('JEUNESSE')}>
	<main id="main-content">
	<section
		class="relative grid h-[calc(100dvh-var(--header-height))] max-h-225 grid-cols-40 grid-rows-40 gap-3.5 bg-[#345f6e] p-3.5 pt-11.5 *:rounded-lg lg:rounded-b-3xl"
	>
		<a
			href={getRelativeLocaleUrl(locale, 'art-vivant')}
			aria-label={t('ART_VIVANT')}
			class="notch-br group relative col-span-10 col-start-1 row-span-18 row-start-1 block overflow-hidden bg-[#be7a5a]"
		>
			<img src={LayoutHome1.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
			<div
				class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#be7a5a]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
			>
				<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('ART_VIVANT')}</h2>
				<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
					>{t('HERO_TILE_ART_VIVANT_SUB')}</span
				>
			</div>
		</a>
		<a
			href={getRelativeLocaleUrl(locale, 'cinema')}
			aria-label={t('CINEMA')}
			class="group relative z-20 col-span-11 col-start-11 row-span-16 row-start-1 block [clip-path:inset(0_0_-0.75rem_0_round_0.5rem)] lg:[clip-path:inset(0_0_-1.5rem_0_round_0.5rem)]"
		>
			<div class="absolute inset-0 rounded-lg bg-[#e5aa7f]"></div>
			<div class="absolute inset-x-0 top-0 z-20 h-[calc(100%+0.75rem)] lg:h-[calc(100%+1.5rem)]">
				<img src={LayoutHome2.src} alt="" loading="eager" class="h-full w-full object-cover object-bottom" />
			</div>
			<div
				class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#e5aa7f]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
			>
				<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('CINEMA')}</h2>
				<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
					>{t('HERO_TILE_CINEMA_SUB')}</span
				>
			</div>
		</a>
		<a
			href={getRelativeLocaleUrl(locale, 'exposition')}
			aria-label={t('EXPOSITION')}
			class="notch-bl group relative col-span-19 col-start-22 row-span-20 row-start-1 block overflow-hidden bg-[#f4ede1]"
		>
			<img
				src={LayoutHome3.src}
				alt=""
				loading="eager"
				fetchpriority="high"
				class="h-full w-full rounded-lg object-cover"
			/>
			<div
				class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#f4ede1]/90 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
			>
				<h2 class="text-foreground font-serif text-3xl lg:text-5xl">{t('EXPOSITION')}</h2>
				<span class="text-foreground max-w-40 pt-1 font-sans text-sm font-medium lg:pt-2 lg:text-lg"
					>{t('HERO_TILE_EXPOSITION_SUB')}</span
				>
			</div>
		</a>
		<a
			href={getRelativeLocaleUrl(locale, 'artiste')}
			aria-label={t('ARTISTE')}
			class="notch-tr group relative col-span-13 col-start-1 row-span-22 row-start-19 block overflow-hidden bg-[#f4ede1]"
		>
			<img src={LayoutHome4.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
			<div
				class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#f4ede1]/90 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
			>
				<h2 class="text-foreground font-serif text-3xl lg:text-5xl">{t('ARTISTE')}</h2>
				<span class="text-foreground max-w-40 pt-1 font-sans text-sm font-medium lg:pt-2 lg:text-lg"
					>{t('HERO_TILE_ARTISTE_SUB')}</span
				>
			</div>
		</a>
		<a
			href={getRelativeLocaleUrl(locale, 'jeune-public')}
			aria-label={t('JEUNESSE')}
			class="group relative z-20 col-span-14 col-start-14 row-span-16 row-start-25 block [clip-path:inset(-0.75rem_0_0_0_round_0.5rem)] lg:[clip-path:inset(-1.5rem_0_0_0_round_0.5rem)]"
		>
			<div class="absolute inset-0 rounded-lg bg-[#be7a5a]"></div>
			<div class="absolute inset-x-0 bottom-0 z-20 h-[calc(100%+0.75rem)] lg:h-[calc(100%+1.5rem)]">
				<img src={LayoutHome5.src} alt="" loading="eager" class="h-full w-full object-cover object-top" />
			</div>
			<div
				class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#be7a5a]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
			>
				<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('JEUNESSE')}</h2>
				<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
					>{t('HERO_TILE_JEUNESSE_SUB')}</span
				>
			</div>
		</a>
		<a
			href={getRelativeLocaleUrl(locale, 'mediatheque')}
			aria-label={t('MEDIATHEQUE')}
			class="notch-tl group relative col-span-13 col-start-28 row-span-20 row-start-21 block overflow-hidden bg-[#e5aa7f]"
		>
			<img src={LayoutHome6.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
			<div
				class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#e5aa7f]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
			>
				<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('MEDIATHEQUE')}</h2>
				<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
					>{t('HERO_TILE_MEDIATHEQUE_SUB')}</span
				>
			</div>
		</a>
		<div
			class="z-10 col-span-25 col-start-8 row-span-8 row-start-17 flex translate-x-[0.2rem] items-center justify-center overflow-hidden bg-[#f4ede1] p-2"
		>
			<h1 class="text-primary text-center text-3xl! leading-8 font-medium! lg:text-[42px]! lg:leading-14">
				Maison du Parc national et<br />de la vallée &middot; Luz-Saint-Sauveur
			</h1>
		</div>
	</section>

		{evenements.docs.length > 0 && (
		<section class="section-default" id="spectacles">
			<h2 class="text-primary pb-2 lg:pb-3">{t('SPECTACLES_JEUNE_PUBLIC_TITRE')}</h2>
			<p class="distinguished pb-3 lg:pb-16">{t('SPECTACLES_JEUNE_PUBLIC_INTRO')}</p>
			<p class="lg:w-2/3">
				{t('SPECTACLES_JEUNE_PUBLIC_DESC')}
			</p>

			<div
				class="my-8 grid grid-cols-[repeat(auto-fit,320px)] justify-center lg:justify-between content-start gap-x-4 gap-y-8 *:only:col-span-full lg:my-16"
			>
				{
					evenements.docs.map((item) => {
						const descText = item.description.root.children
							.flatMap((para) => para.children)
							.filter((child) => child.type === 'text')
							.map((child) => child.text)
							.join(' ')

						return (
							<SpectacleCard
								title={item.title}
								href={getRelativeLocaleUrl(locale, `jeune-public/spectacles/${item.id}`)}
								locale={locale}
								description={descText}
								dateStart={item.date_start}
								genre={item.genre ?? ''}
								ctaLabel={t('EN_SAVOIR_PLUS')}
								imageSrc={item.thumbnail?.url}
								imageAlt={item.thumbnail?.alt}
								imageBlurhash={item.thumbnail?.blurhash}
								width="w-[320px]"
							/>
						)
					})
				}
			</div>
		</section>
		)}

		{cinema.docs.length > 0 && (
		<section class="section-default bg-primary pb-4" id="cinema">
			<article>
				<h2 class="pb-2 lg:pb-3">{t('CINEMA_JEUNE_PUBLIC_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-16">{t('CINEMA_JEUNE_PUBLIC_INTRO')}</p>
				<p class="lg:w-2/3">{t('CINEMA_JEUNE_PUBLIC_DESC')}</p>
			</article>

			<div class="my-8 grid grid-cols-1 gap-3 lg:my-16 lg:grid-cols-2 lg:gap-5">
				{
					cinema.docs.map((item) => {
						const synopsisText = item.synopsis.root.children
							.flatMap((para) => para.children)
							.filter((child) => child.type === 'text')
							.map((child) => child.text)
							.join(' ')

						return (
							<SpectacleCard
								title={item.title}
								href={getRelativeLocaleUrl(locale, `jeune-public/seance/${item.id}`)}
								locale={locale}
								description={synopsisText}
								dateStart={item.date_start}
								genre={`${translatePublicField(item.public, t)} - ${item.genre} - ${item.languages}`}
								ctaLabel={t('EN_SAVOIR_PLUS')}
								imageSrc={item.thumbnail?.url}
								imageAlt={item.thumbnail?.alt}
								imageBlurhash={item.thumbnail?.blurhash}
								height="h-[300px]"
							/>
						)
					})
				}
			</div>
		</section>
		)}

		{ludotheque.docs.length > 0 && (
		<section class="section-default" id="ludotheque">
			<article>
				<h2 class="pb-2 lg:pb-3">{t('LUDOTHEQUE_JEUNE_PUBLIC_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-16">{t('LUDOTHEQUE_JEUNE_PUBLIC_INTRO')}</p>
				<p class="lg:w-2/3">{t('LUDOTHEQUE_JEUNE_PUBLIC_DESC')}</p>
			</article>

			<div
				class="my-8 grid grid-cols-[repeat(auto-fit,360px)] justify-center lg:justify-between content-start gap-x-4 gap-y-8 *:only:col-span-full lg:my-16"
			>
				{
					ludotheque.docs.map((item) => {
						const descText = item.description.root.children
							.flatMap((para) => para.children)
							.filter((child) => child.type === 'text')
							.map((child) => child.text)
							.join(' ')

						return (
							<article
								class="group shadow-card relative col-span-1 overflow-hidden rounded-2xl border border-black bg-white w-[360px] h-[360px]"
							>
								<MyImage
									src={item.thumbnail?.url}
									alt={item.thumbnail?.alt ?? t('IMAGE_PLACEHOLDER')}
									background={item.thumbnail?.blurhash}
									width={275}
									height={400}
									class="h-full w-full rounded-2xl object-cover"
									loading="lazy"
									layout="fullWidth"
								/>
								<figure class="bg-background/90 absolute inset-x-0 bottom-0 h-[116px] overflow-hidden rounded-t-2xl p-4 transition-[height] duration-300 ease-[cubic-bezier(0.2,0,0,1)] group-hover:h-full">
									<figcaption>
										<h3 class="line-clamp-1 mb-0.5 group-hover:line-clamp-2">
											<a
												href={getRelativeLocaleUrl(locale, `jeune-public/ludotheque/${item.id}`)}
												class="after:absolute after:inset-0 after:z-10"
											>
												{item.title}
											</a>
										</h3>
										{item.genre && (
											<p class="distinguished text-primary! line-clamp-1 text-sm group-hover:line-clamp-2">{item.genre}</p>
										)}
										{(item.public || item.players || item.duration) && (
											<div class="bg-secondary text-secondary-foreground rounded-xl mt-1.5 flex items-center">
												<div class="flex-1 distinguished text-center text-xs py-2">{item.public}</div>
												<div class="bg-background distinguished flex-1 text-center text-xs py-1 mx-1 rounded-xl">{item.players}</div>
												<div class="flex-1 distinguished text-center text-xs py-2">{translateLudoDuration(item.duration, t)}</div>
											</div>
										)}
										<div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-[cubic-bezier(0.2,0,0,1)] group-hover:grid-rows-[1fr]">
											<div class="overflow-hidden">
												{descText && <p class="text-foreground! line-clamp-8 pt-4 text-sm">{descText}</p>}
												<p class="text-secondary-muted! inline-flex items-center gap-2 pt-4 text-medium font-semibold transition-opacity opacity-0 duration-200 group-hover:opacity-100 group-hover:delay-200 pl-0.5">
													{t('EN_SAVOIR_PLUS')}
													<svg
														xmlns="http://www.w3.org/2000/svg"
														width="16"
														height="16"
														viewBox="0 0 24 24"
														fill="none"
														stroke="currentColor"
														stroke-width="2"
														stroke-linecap="round"
														stroke-linejoin="round"
													>
														<path d="M5 12h14" />
														<path d="m12 5 7 7-7 7" />
													</svg>
												</p>
											</div>
										</div>
									</figcaption>
								</figure>
							</article>
						)
					})
				}
			</div>
		</section>
		)}
	</main>
</Layout>
