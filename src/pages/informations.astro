---
export const prerender = true
import { findGlobal } from '@/api/payload'
import FirstImg from '@/assets/imgs/info/1.webp'
import SecondImg from '@/assets/imgs/info/2.webp'
import ThirdImg from '@/assets/imgs/info/3.webp'
import EquipeImg from '@/assets/imgs/info/4.webp'
import FivethImg from '@/assets/imgs/info/5.webp'
import LayoutHome1 from '@/assets/imgs/layout_home/1.png'
import LayoutHome2 from '@/assets/imgs/layout_home/2.png'
import LayoutHome3 from '@/assets/imgs/layout_home/3.png'
import LayoutHome4 from '@/assets/imgs/layout_home/4.png'
import LayoutHome5 from '@/assets/imgs/layout_home/5.png'
import LayoutHome6 from '@/assets/imgs/layout_home/6.png'
import BeHappyImg from '@/assets/imgs/sponsos/be-happy.webp'
import EuropeImg from '@/assets/imgs/sponsos/europe.webp'
import HautesPyreneesImg from '@/assets/imgs/sponsos/hautes-pyrenees.webp'
import OccitanieImg from '@/assets/imgs/sponsos/occitanie.webp'
import ParcNationalImg from '@/assets/imgs/sponsos/parc-national.webp'
import PrefetImg from '@/assets/imgs/sponsos/prefet.webp'
import MyImage from '@/components/my-image.astro'
import { createTranslator, I18n } from '@/i18n/translations'
import Layout from '@/layouts/layout.astro'
import type { Hour } from '@/types/hours'
import { MDV_DEFAULT_ADDRESS, MDV_PARKING_DEFAULT_ADDRESS } from '@/utils/helper'
import { getRelativeLocaleUrl } from 'astro:i18n'

const locale = (Astro.currentLocale || 'fr') as I18n
const t = createTranslator(locale)
const hours = await findGlobal<Hour>('hours', { locale })
const formatTime = (dateStr: string) => {
	return new Date(dateStr).toLocaleTimeString(locale, {
		hour: '2-digit',
		minute: '2-digit',
		hour12: false,
		timeZone: 'Europe/Paris'
	})
}
---

<Layout title={t('INFORMATIONS')}>
	<main id="main-content">
		<section
			class="relative grid h-[calc(100dvh-var(--header-height))] max-h-225 grid-cols-40 grid-rows-40 gap-3.5 bg-[#345f6e] p-3.5 pt-11.5 *:rounded-lg lg:rounded-b-3xl"
		>
			<a
				href={getRelativeLocaleUrl(locale, 'art-vivant')}
				aria-label={t('ART_VIVANT')}
				class="notch-br group relative col-span-10 col-start-1 row-span-18 row-start-1 block overflow-hidden bg-[#be7a5a]"
			>
				<img src={LayoutHome1.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
				<div
					class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#be7a5a]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
				>
					<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('ART_VIVANT')}</h2>
					<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
						>{t('HERO_TILE_ART_VIVANT_SUB')}</span
					>
				</div>
			</a>
			<a
				href={getRelativeLocaleUrl(locale, 'cinema')}
				aria-label={t('CINEMA')}
				class="group relative col-span-11 col-start-11 row-span-16 row-start-1 block overflow-hidden bg-[#e5aa7f]"
			>
				<img src={LayoutHome2.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
				<div
					class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#e5aa7f]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
				>
					<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('CINEMA')}</h2>
					<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
						>{t('HERO_TILE_CINEMA_SUB')}</span
					>
				</div>
			</a>
			<a
				href={getRelativeLocaleUrl(locale, 'exposition')}
				aria-label={t('EXPOSITION')}
				class="notch-bl group relative col-span-19 col-start-22 row-span-20 row-start-1 block overflow-hidden bg-[#f4ede1]"
			>
				<img
					src={LayoutHome3.src}
					alt=""
					loading="eager"
					fetchpriority="high"
					class="h-full w-full rounded-lg object-cover"
				/>
				<div
					class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#f4ede1]/90 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
				>
					<h2 class="text-foreground font-serif text-3xl lg:text-5xl">{t('EXPOSITION')}</h2>
					<span class="text-foreground max-w-40 pt-1 font-sans text-sm font-medium lg:pt-2 lg:text-lg"
						>{t('HERO_TILE_EXPOSITION_SUB')}</span
					>
				</div>
			</a>
			<a
				href={getRelativeLocaleUrl(locale, 'artiste')}
				aria-label={t('ARTISTE')}
				class="notch-tr group relative col-span-13 col-start-1 row-span-22 row-start-19 block overflow-hidden bg-[#f4ede1]"
			>
				<img src={LayoutHome4.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
				<div
					class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#f4ede1]/90 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
				>
					<h2 class="text-foreground font-serif text-3xl lg:text-5xl">{t('ARTISTE')}</h2>
					<span class="text-foreground max-w-40 pt-1 font-sans text-sm font-medium lg:pt-2 lg:text-lg"
						>{t('HERO_TILE_ARTISTE_SUB')}</span
					>
				</div>
			</a>
			<a
				href={getRelativeLocaleUrl(locale, 'jeune-public')}
				aria-label={t('JEUNESSE')}
				class="group relative col-span-14 col-start-14 row-span-16 row-start-25 block overflow-hidden bg-[#be7a5a]"
			>
				<img src={LayoutHome5.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
				<div
					class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#be7a5a]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
				>
					<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('JEUNESSE')}</h2>
					<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
						>{t('HERO_TILE_JEUNESSE_SUB')}</span
					>
				</div>
			</a>
			<a
				href={getRelativeLocaleUrl(locale, 'mediatheque')}
				aria-label={t('MEDIATHEQUE')}
				class="notch-tl group relative col-span-13 col-start-28 row-span-20 row-start-21 block overflow-hidden bg-[#e5aa7f]"
			>
				<img src={LayoutHome6.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
				<div
					class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#e5aa7f]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
				>
					<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('MEDIATHEQUE')}</h2>
					<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
						>{t('HERO_TILE_MEDIATHEQUE_SUB')}</span
					>
				</div>
			</a>
			<div
				class="z-10 col-span-25 col-start-8 row-span-8 row-start-17 flex translate-x-[0.2rem] items-center justify-center overflow-hidden bg-[#f4ede1] p-2"
			>
				<h1 class="text-primary text-center text-3xl! leading-8 font-medium! lg:text-[42px]! lg:leading-14">
					Maison du Parc national et<br />de la vallée &middot; Luz-Saint-Sauveur
				</h1>
			</div>
		</section>
		<section class="section-default mt-4 lg:mt-0" id="horaires">
			<article class="grid grid-cols-1 gap-8 lg:grid-cols-[1.15fr_0.85fr]">
				<div class="flex flex-col">
					<div class="max-w-2xl">
						<h2 class="text-primary pb-2 lg:pb-3">{t('OU_NOUS_TROUVER_TITRE')}</h2>
						<p class="pb-8 lg:pb-16">{t('OU_NOUS_TROUVER_INTRO')}</p>
					</div>

					<div class="bg-secondary grid grid-cols-1 gap-3 rounded-4xl p-6 md:grid-cols-2 lg:gap-5">
						<div class="rounded-3xl bg-[#F5EDE2] p-4">
							<p class="font-title text-foreground border-foreground mb-4 border-b text-lg">{t('ADRESSE_DU_LIEU')}</p>
							<p class="pl-3">{MDV_DEFAULT_ADDRESS}</p>
						</div>

						<div class="rounded-3xl bg-[#F5EDE2] p-4">
							<p class="font-title text-foreground border-foreground mb-4 border-b text-lg">{t('ACCES')}</p>
							<p class="pl-3">{t('TRANSPORT_PUBLIC')}</p>
						</div>

						<div class="rounded-3xl bg-[#F5EDE2] p-4">
							<p class="font-title text-foreground border-foreground mb-4 border-b text-lg">{t('HORAIRES')}</p>
							<div class="space-y-2 pl-3">
								<div>
									<p class="font-medium">{t('LUNDI_SAMEDI')}</p>
									<p>{formatTime(hours.horaires_base.base_start)} - {formatTime(hours.horaires_base.base_end)}</p>
								</div>
								<div>
									<p class="font-medium">{t('DIMANCHE')}</p>
									<p>
										{formatTime(hours.horaires_base.dimanche_start)} - {formatTime(hours.horaires_base.dimanche_end)}
									</p>
								</div>
							</div>
						</div>

						<div class="rounded-3xl bg-[#F5EDE2] p-4">
							<p class="font-title text-foreground border-foreground mb-4 border-b text-lg">{t('PARKING')}</p>
							<p class="pl-3">{MDV_PARKING_DEFAULT_ADDRESS}</p>
						</div>
					</div>
				</div>

				<div
					class="bg-primary/5 overflow-hidden rounded-[2rem] border border-black/5 shadow-[0_22px_60px_rgba(27,66,79,0.12)]"
				>
					<iframe
						class="h-[22rem] min-h-[22rem] w-full lg:h-full"
						style="border:0"
						referrerpolicy="no-referrer-when-downgrade"
						src="https://www.google.com/maps?q=24+Place+Saint+Clément,+65120+Luz-Saint-Sauveur&output=embed"
						allowfullscreen
						title="Maison du Parc National et de la Vallée — Luz-Saint-Sauveur"
					>
					</iframe>
				</div>
			</article>
		</section>

		<section class="section-default bg-primary" id="tarifs">
			<article>
				<h2 class="text-primary pb-2 lg:pb-3">{t('NOS_TARIFS')}</h2>
				<p class="distinguished pb-8 lg:pb-12">{t('NOS_TARIFS_INTRO')}</p>
				<p class="pb-12">{t('NOS_TARIFS_DESC')}</p>

				<div class="grid grid-cols-1 gap-5 lg:grid-cols-3 lg:gap-6">
					<div
						class="border-primary grid grid-cols-[1fr_auto] gap-4 overflow-hidden rounded-[2rem] border-2 bg-[#F5EDE2] p-7"
					>
						<div class="flex flex-col">
							<h3 class="text-foreground pb-8">{t('TARIFS_MEDIATHEQUE')}</h3>
							<div class="mt-auto flex flex-col items-start gap-3">
								<div class="bg-secondary rounded-3xl px-4 py-2">
									<p class="text-foreground!"><span>{t('ADULTE')}</span> : 10 €</p>
									<p class="text-primary! font-sans text-[13px] font-medium tracking-wider uppercase">{t('ANNEE')}</p>
								</div>
								<div class="bg-secondary rounded-3xl px-4 py-2">
									<p class="text-foreground!"><span>{t('ENFANT')}</span> : 5 €</p>
									<p class="text-primary! font-sans text-[13px] font-medium tracking-wider uppercase">{t('ANNEE')}</p>
								</div>
								<div class="bg-secondary rounded-3xl px-4 py-2">
									<p class="text-foreground!"><span>{t('FAMILLE')}</span> : 5 €</p>
									<p class="text-primary! font-sans text-[13px] font-medium tracking-wider uppercase">
										3 {t('SEMAINES')}
									</p>
								</div>
							</div>
						</div>
						<div class="w-25 overflow-hidden rounded-3xl] lg:w-28.75">
							<MyImage
								src={FirstImg}
								alt=""
								width={130}
								height={500}
								layout="fullWidth"
								class="h-full w-full object-cover"
							/>
						</div>
					</div>

					<div
						class="border-primary grid grid-cols-[1fr_auto] gap-4 overflow-hidden rounded-[2rem] border-2 bg-[#F5EDE2] p-7"
					>
						<div class="flex flex-col">
							<h3 class="text-foreground pb-8">{t('TARIFS_SPECTACLE')}</h3>
							<div class="mt-auto flex flex-col items-start gap-3">
								<div class="bg-secondary rounded-3xl px-4 py-2">
									<p class="text-foreground!"><span>{t('NORMAL')}</span> : 10 €</p>
									<p class="text-primary! font-sans text-[13px] font-medium tracking-wider uppercase">
										{t('DES_14ANS')}
									</p>
								</div>
								<div class="bg-secondary rounded-3xl px-4 py-2">
									<p class="text-foreground!"><span>{t('REDUIT')}</span> : 7 €</p>
									<p class="text-primary! font-sans text-[13px] font-medium tracking-wider uppercase">
										{t('REDUIT_DESC')}
									</p>
								</div>
								<div class="bg-secondary rounded-3xl px-4 py-2">
									<p class="text-foreground!"><span>{t('ENFANT')}</span> : {t('OFFERT')}</p>
									<p class="text-primary! font-sans text-[13px] font-medium tracking-wider uppercase">
										{t('MOINS_3ANS')}
									</p>
								</div>
							</div>
						</div>
						<div class="w-25 overflow-hidden rounded-3xl] lg:w-28.75">
							<MyImage
								src={SecondImg}
								alt=""
								width={130}
								height={500}
								layout="fullWidth"
								class="h-full w-full object-cover"
							/>
						</div>
					</div>

					<div
						class="border-primary grid grid-cols-[1fr_auto] gap-4 overflow-hidden rounded-[2rem] border-2 bg-[#F5EDE2] p-7"
					>
						<div class="flex flex-col">
							<h3 class="text-foreground pb-8">{t('TARIFS_CINEMA')}</h3>
							<div class="mt-auto flex flex-col items-start gap-3">
								<div class="bg-secondary rounded-3xl px-4 py-2">
									<p class="text-foreground!"><span>{t('ADULTE')}</span> : 7 €</p>
								</div>
								<div class="bg-secondary rounded-3xl px-4 py-2">
									<p class="text-foreground!"><span>{t('ETUDIANT')}</span> : 6 €</p>
								</div>
								<div class="bg-secondary rounded-3xl px-4 py-2">
									<p class="text-foreground!"><span>{t('ENFANT_MOINS_13')}</span> : 5 €</p>
								</div>
								<div class="bg-secondary rounded-3xl px-4 py-2">
									<p class="text-foreground!"><span>{t('ABONNE')}</span> : 5,80 €</p>
								</div>
							</div>
						</div>
						<div class="w-25 overflow-hidden rounded-3xl] lg:w-28.75">
							<MyImage
								src={ThirdImg}
								alt=""
								width={130}
								height={500}
								layout="fullWidth"
								class="h-full w-full object-cover"
							/>
						</div>
					</div>
				</div>
			</article>
		</section>

		<section class="section-default" id="equipe">
			<article>
				<div class="grid grid-cols-1 gap-6 pb-8 lg:grid-cols-2 lg:gap-10 lg:pb-16">
					<div class="flex flex-col">
						<h2 class="text-primary pb-2 lg:pb-3">{t('L_EQUIPE')}</h2>
						<p class="distinguished pb-8 lg:pb-12">{t('EQUIPE_INTRO')}</p>
						<p>{t('EQUIPE_DESC')}</p>
					</div>

					<MyImage
						src={EquipeImg}
						alt=""
						width={700}
						height={400}
						layout="fullWidth"
						class="h-full w-full object-cover"
					/>
				</div>
			</article>
		</section>

		<section class="section-default mx-auto lg:w-auto">
			<article class="grid w-full grid-cols-1 rounded-4xl lg:grid-cols-[1fr_2fr]">
				<div
					class="bg-secondary-muted relative order-2 overflow-hidden rounded-b-4xl lg:order-1 lg:overflow-visible lg:rounded-l-4xl lg:rounded-br-none"
				>
					<div
						class="lg:absolute lg:inset-x-0 lg:bottom-0 lg:top-[-28px] lg:h-[calc(100%+28px)] lg:overflow-hidden lg:rounded-bl-4xl"
					>
						<MyImage
							alt=""
							src={FivethImg}
							width={500}
							height={400}
							layout="fullWidth"
							class="h-full! w-full! rounded-none object-cover"
						/>
					</div>
				</div>
				<div class="bg-secondary order-1 rounded-t-4xl p-6 lg:order-2 lg:rounded-tl-none lg:rounded-r-4xl">
					<h2 class="text-foreground pb-2 lg:pb-3">{t('ENGAGEMENTS_VALEURS_TITRE')}</h2>
					<p class="distinguished pb-8 lg:pb-12">{t('ENGAGEMENTS_VALEURS_INTRO')}</p>
					<p class="text-foreground whitespace-pre-line">{t('ENGAGEMENTS_VALEURS_DESC')}</p>
				</div>
			</article>
		</section>

		<section class="section-default" id="partenaires">
			<article class="grid grid-cols-1 gap-3 lg:grid-cols-3 lg:gap-16">
				<div class="mb-6 lg:col-span-2 lg:mb-0">
					<h2 class="text-primary pb-2 lg:pb-3">{t('PARTENAIRES_TITRE')}</h2>
					<p class="distinguished pb-8 lg:pb-16">{t('PARTENAIRES_INTRO')}</p>
					<p>{t('PARTENAIRES_DESC')}</p>
				</div>
				<div class="grid grid-cols-3 grid-rows-3 place-items-start gap-3 lg:order-1 lg:col-span-1 lg:pt-48">
					<MyImage src={BeHappyImg} alt="Be Happy" width={120} height={120} class="col-span-1 rounded-none" />
					<MyImage
						src={HautesPyreneesImg}
						alt="Département des Hautes-Pyrénées"
						width={120}
						height={120}
						class="col-span-1 rounded-none"
					/>
					<MyImage src={OccitanieImg} alt="Région Occitanie" width={120} height={120} class="col-span-1 rounded-none" />
					<MyImage
						src={PrefetImg}
						alt="Préfet des Hautes-Pyrénées"
						width={120}
						height={120}
						class="col-span-1 rounded-none"
					/>
					<MyImage
						src={ParcNationalImg}
						alt="Parc National des Pyrénées"
						width={240}
						height={120}
						class="col-span-2 rounded-none"
					/>
					<MyImage
						src={EuropeImg}
						alt="Union Européenne – Fonds Européen de Développement Régional"
						width={700}
						height={120}
						class="col-span-3 rounded-none"
					/>
				</div>
			</article>
		</section>
	</main>
</Layout>
