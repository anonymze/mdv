---
export const prerender = true
import { find } from '@/api/payload'
import FirstMediaImg from '@/assets/imgs/parc/1.webp'
import SecondMediaImg from '@/assets/imgs/parc/2.webp'
import ThirdMediaImg from '@/assets/imgs/parc/3.webp'
import FourthMediaImg from '@/assets/imgs/parc/4.webp'
import MyImage from '@/components/my-image.astro'
import { SpectaclesGrid } from '@/components/spectacles-grid'
import { ArticleGrid } from '@/components/article-grid'
import { Button } from '@/components/ui/button'
import { createTranslator, I18n } from '@/i18n/translations'
import Layout from '@/layouts/layout.astro'
import type { ParcNational } from '@/types/parc-national'
const locale = (Astro.currentLocale || 'fr') as I18n
const t = createTranslator(locale)

const EVENEMENTS_LIMIT = 4

const evenements = await find<ParcNational>('parc_national', {
	limit: EVENEMENTS_LIMIT,
	page: 1,
	locale,
	where: { type: { equals: 'evenement' } }
})

const ARTICLES_LIMIT = 6

const articles = await find<ParcNational>('parc_national', {
	limit: ARTICLES_LIMIT,
	page: 1,
	locale,
	upcomingOnly: false,
	where: {
		type: { equals: 'article' },
	}
})

const evenementsTranslations = {
	PRECEDENT: t('PRECEDENT'),
	SUIVANT: t('SUIVANT'),
	IMAGE_PLACEHOLDER: t('IMAGE_PLACEHOLDER'),
	EN_SAVOIR_PLUS: t('EN_SAVOIR_PLUS')
}

const articlesTranslations = {
	PRECEDENT: t('PRECEDENT'),
	SUIVANT: t('SUIVANT'),
	IMAGE_PLACEHOLDER: t('IMAGE_PLACEHOLDER'),
	AUCUN_CONTENU: t('AUCUN_CONTENU')
}

const PAYLOAD_URL = import.meta.env.PUBLIC_PAYLOAD_URL
---

<Layout title={t('ACCUEIL_TITLE')}>
	<main>
		<section class="section-default" id="description">
			<h1 class="text-primary pb-8 lg:pb-20">{t('PARC_NATIONAL_TITRE')}</h1>
			<article class="grid grid-cols-1 gap-3 lg:grid-cols-2 lg:gap-5">
				<div class="order-1 flex flex-col">
					<p class="distinguished pb-8 lg:pb-16">{t('PARC_NATIONAL_INTRO')}</p>
					<p>
						{t('PARC_NATIONAL_DESC')}
					</p>

					<Button link="https://www.pyrenees-parcnational.fr/fr" openInNewTab size={'xl'} className="mt-auto w-fit"
						>{t('PARC_NATIONAL_SITE_OFFICIEL')}</Button
					>
				</div>
				<div class="order-2 grid grid-cols-2 gap-2 lg:grid-cols-4 lg:grid-rows-3 lg:gap-5">
					<MyImage
						alt=""
						src={FirstMediaImg}
						width={420}
						height={670}
						layout="fullWidth"
						class="col-span-2 max-h-48 object-cover lg:row-span-3 lg:max-h-none"
					/>
					<MyImage
						alt=""
						src={SecondMediaImg}
						width={420}
						height={210}
						layout="fullWidth"
						class="col-span-1 max-h-24 object-cover lg:col-span-2 lg:row-span-1 lg:max-h-none"
					/>
					<MyImage
						alt=""
						src={ThirdMediaImg}
						width={420}
						height={210}
						layout="fullWidth"
						class="col-span-1 max-h-24 object-cover lg:col-span-2 lg:row-span-1 lg:max-h-none"
					/>
					<MyImage
						alt=""
						src={FourthMediaImg}
						width={420}
						height={210}
						layout="fullWidth"
						class="col-span-2 max-h-24 object-cover lg:row-span-1 lg:max-h-none"
					/>
				</div>
			</article>
		</section>
	</main>

	<section class="section-default bg-primary/20" id="evenements">
		<h2 class="text-primary pb-2 lg:pb-3">{t('PARC_EVENEMENTS_TITRE')}</h2>
		<p class="distinguished pb-3 lg:pb-6">{t('PARC_EVENEMENTS_INTRO')}</p>
		<p class="lg:w-2/3">
			{t('PARC_EVENEMENTS_DESC')}
		</p>

		<SpectaclesGrid
			client:load
			initialData={evenements}
			locale={locale}
			limit={EVENEMENTS_LIMIT}
			payloadUrl={PAYLOAD_URL}
			collection="parc_national"
			showFilters={false}
			mobileScrollOnly={true}
			translations={evenementsTranslations}
		/>
	</section>

	<section class="section-default" id="articles">
		<h2 class="text-secondary pb-2 lg:pb-3">{t('PARC_ARTICLES_TITRE')}</h2>
		<p class="distinguished pb-3 lg:pb-6">{t('PARC_ARTICLES_INTRO')}</p>
		<p class="lg:w-2/3">
			{t('PARC_ARTICLES_DESC')}
		</p>

		<ArticleGrid
			client:load
			initialData={articles}
			locale={locale}
			limit={ARTICLES_LIMIT}
			payloadUrl={PAYLOAD_URL}
			translations={articlesTranslations}
		/>
	</section>
</Layout>
