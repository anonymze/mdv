---
export const prerender = true
import { find } from '@/api/payload'
import LayoutHome1 from '@/assets/imgs/layout_home/1.png'
import LayoutHome2 from '@/assets/imgs/layout_home/2.png'
import LayoutHome3 from '@/assets/imgs/layout_home/3.png'
import LayoutHome4 from '@/assets/imgs/layout_home/4.png'
import LayoutHome5 from '@/assets/imgs/layout_home/5.png'
import LayoutHome6 from '@/assets/imgs/layout_home/6.png'
import FirstImg from '@/assets/imgs/mediatheque/1.webp'
import SecondImg from '@/assets/imgs/mediatheque/2.webp'
import ThirdImg from '@/assets/imgs/mediatheque/3.webp'
import FourthImg from '@/assets/imgs/mediatheque/4.webp'
import FifthImg from '@/assets/imgs/mediatheque/5.webp'
import SixthImg from '@/assets/imgs/mediatheque/6.webp'
import SeventhImg from '@/assets/imgs/mediatheque/7.webp'
import EighthImg from '@/assets/imgs/mediatheque/8.webp'
import NinthImg from '@/assets/imgs/mediatheque/9.webp'
import TenthImg from '@/assets/imgs/mediatheque/10.webp'
import { HoverImageSwap } from '@/components/hover-image-swap'
import { LudothequeGrid } from '@/components/ludotheque-grid'
import { SpectaclesGrid } from '@/components/spectacles-grid'
import { createTranslator, I18n } from '@/i18n/translations'
import Layout from '@/layouts/layout.astro'
import type { Ludotheque, MediathequeSpectacle } from '@/types/mediatheque'
import { getRelativeLocaleUrl } from 'astro:i18n'

const locale = (Astro.currentLocale || 'fr') as I18n
const t = createTranslator(locale)
const localePrefix = getRelativeLocaleUrl(locale, '').replace(/\/$/, '')

const EVENEMENTS_LIMIT = 4

const evenements = await find<MediathequeSpectacle>('mediatheque', {
	limit: EVENEMENTS_LIMIT,
	page: 1,
	locale,
	where: {
		type: { equals: 'mediatheque' }
	}
})

const evenementsTranslations = {
	PRECEDENT: t('PRECEDENT'),
	SUIVANT: t('SUIVANT'),
	IMAGE_PLACEHOLDER: t('IMAGE_PLACEHOLDER'),
	EN_SAVOIR_PLUS: t('EN_SAVOIR_PLUS'),
	AUCUN_CONTENU: t('AUCUN_CONTENU'),
	TOUS: t('TOUS')
}

const LUDO_LIMIT = 6

const ludotheque = await find<Ludotheque>('mediatheque', {
	limit: LUDO_LIMIT,
	page: 1,
	locale,
	upcomingOnly: false,
	where: {
		type: { equals: 'ludotheque' }
	}
})

const ludoTranslations = {
	PRECEDENT: t('PRECEDENT'),
	SUIVANT: t('SUIVANT'),
	IMAGE_PLACEHOLDER: t('IMAGE_PLACEHOLDER'),
	EN_SAVOIR_PLUS: t('EN_SAVOIR_PLUS'),
	MOTS_CLES: t('MOTS_CLES'),
	TEMPS_DE_JEU: t('TEMPS_DE_JEU'),
	NOMBRE_DE_JOUEURS: t('NOMBRE_DE_JOUEURS'),
	AGE: t('AGE'),
	JOUEURS: t('JOUEURS'),
	ANS_ET_PLUS: t('ANS_ET_PLUS'),
	AUCUN_CONTENU: t('AUCUN_CONTENU'),
	TOUS: t('TOUS'),
	durationOptions: [
		{ key: t('LUDO_DURATION_5'), value: '5' },
		{ key: t('LUDO_DURATION_10'), value: '10' },
		{ key: t('LUDO_DURATION_15'), value: '15' },
		{ key: t('LUDO_DURATION_30'), value: '30' },
		{ key: t('LUDO_DURATION_1H'), value: '1h' },
		{ key: t('LUDO_DURATION_1H_PLUS'), value: '1h+' }
	],
	playersOptions: [
		{ key: '1', value: '1' },
		{ key: '2', value: '2' },
		{ key: '3', value: '3' },
		{ key: '4', value: '4' },
		{ key: '5', value: '5' },
		{ key: '6', value: '6' },
		{ key: '7', value: '7' },
		{ key: '8', value: '8' },
		{ key: '8+', value: '8+' }
	],
	publicOptions: [
		{ key: '3', value: '3' },
		{ key: '12', value: '12' },
		{ key: '16', value: '16' },
		{ key: '18', value: '18' }
	],
	durationLabels: {
		'5': t('LUDO_DURATION_5'),
		'10': t('LUDO_DURATION_10'),
		'15': t('LUDO_DURATION_15'),
		'30': t('LUDO_DURATION_30'),
		'1h': t('LUDO_DURATION_1H'),
		'1h+': t('LUDO_DURATION_1H_PLUS')
	}
}

const PAYLOAD_URL = import.meta.env.PUBLIC_PAYLOAD_URL
---

<Layout title={t('MEDIATHEQUE')}>
	<main id="main-content">

	<section
		class="relative grid h-[calc(100dvh-var(--header-height))] max-h-225 grid-cols-40 grid-rows-40 gap-3.5 bg-[#345f6e] p-3.5 pt-11.5 *:rounded-lg lg:rounded-b-3xl"
	>
		<a
			href={getRelativeLocaleUrl(locale, 'art-vivant')}
			aria-label={t('ART_VIVANT')}
			class="notch-br group relative col-span-10 col-start-1 row-span-18 row-start-1 block overflow-hidden bg-[#be7a5a]"
		>
			<img src={LayoutHome1.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
			<div
				class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#be7a5a]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
			>
				<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('ART_VIVANT')}</h2>
				<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
					>{t('HERO_TILE_ART_VIVANT_SUB')}</span
				>
			</div>
		</a>
		<a
			href={getRelativeLocaleUrl(locale, 'cinema')}
			aria-label={t('CINEMA')}
			class="group relative z-20 col-span-11 col-start-11 row-span-16 row-start-1 block [clip-path:inset(0_0_-0.75rem_0_round_0.5rem)] lg:[clip-path:inset(0_0_-1.5rem_0_round_0.5rem)]"
		>
			<div class="absolute inset-0 rounded-lg bg-[#e5aa7f]"></div>
			<div class="absolute inset-x-0 top-0 z-20 h-[calc(100%+0.75rem)] lg:h-[calc(100%+1.5rem)]">
				<img src={LayoutHome2.src} alt="" loading="eager" class="h-full w-full object-cover object-bottom" />
			</div>
			<div
				class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#e5aa7f]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
			>
				<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('CINEMA')}</h2>
				<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
					>{t('HERO_TILE_CINEMA_SUB')}</span
				>
			</div>
		</a>
		<a
			href={getRelativeLocaleUrl(locale, 'exposition')}
			aria-label={t('EXPOSITION')}
			class="notch-bl group relative col-span-19 col-start-22 row-span-20 row-start-1 block overflow-hidden bg-[#f4ede1]"
		>
			<img
				src={LayoutHome3.src}
				alt=""
				loading="eager"
				fetchpriority="high"
				class="h-full w-full rounded-lg object-cover"
			/>
			<div
				class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#f4ede1]/90 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
			>
				<h2 class="text-foreground font-serif text-3xl lg:text-5xl">{t('EXPOSITION')}</h2>
				<span class="text-foreground max-w-40 pt-1 font-sans text-sm font-medium lg:pt-2 lg:text-lg"
					>{t('HERO_TILE_EXPOSITION_SUB')}</span
				>
			</div>
		</a>
		<a
			href={getRelativeLocaleUrl(locale, 'artiste')}
			aria-label={t('ARTISTE')}
			class="notch-tr group relative col-span-13 col-start-1 row-span-22 row-start-19 block overflow-hidden bg-[#f4ede1]"
		>
			<img src={LayoutHome4.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
			<div
				class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#f4ede1]/90 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
			>
				<h2 class="text-foreground font-serif text-3xl lg:text-5xl">{t('ARTISTE')}</h2>
				<span class="text-foreground max-w-40 pt-1 font-sans text-sm font-medium lg:pt-2 lg:text-lg"
					>{t('HERO_TILE_ARTISTE_SUB')}</span
				>
			</div>
		</a>
		<a
			href={getRelativeLocaleUrl(locale, 'jeune-public')}
			aria-label={t('JEUNESSE')}
			class="group relative z-20 col-span-14 col-start-14 row-span-16 row-start-25 block [clip-path:inset(-0.75rem_0_0_0_round_0.5rem)] lg:[clip-path:inset(-1.5rem_0_0_0_round_0.5rem)]"
		>
			<div class="absolute inset-0 rounded-lg bg-[#be7a5a]"></div>
			<div class="absolute inset-x-0 bottom-0 z-20 h-[calc(100%+0.75rem)] lg:h-[calc(100%+1.5rem)]">
				<img src={LayoutHome5.src} alt="" loading="eager" class="h-full w-full object-cover object-top" />
			</div>
			<div
				class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#be7a5a]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
			>
				<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('JEUNESSE')}</h2>
				<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
					>{t('HERO_TILE_JEUNESSE_SUB')}</span
				>
			</div>
		</a>
		<a
			href={getRelativeLocaleUrl(locale, 'mediatheque')}
			aria-label={t('MEDIATHEQUE')}
			class="notch-tl group relative col-span-13 col-start-28 row-span-20 row-start-21 block overflow-hidden bg-[#e5aa7f]"
		>
			<img src={LayoutHome6.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
			<div
				class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#e5aa7f]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
			>
				<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('MEDIATHEQUE')}</h2>
				<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
					>{t('HERO_TILE_MEDIATHEQUE_SUB')}</span
				>
			</div>
		</a>
		<div
			class="z-10 col-span-25 col-start-8 row-span-8 row-start-17 flex translate-x-[0.2rem] items-center justify-center overflow-hidden bg-[#f4ede1] p-2"
		>
			<h1 class="text-primary text-center text-3xl! leading-8 font-medium! lg:text-[42px]! lg:leading-14">
				Maison du Parc national et<br />de la vallée &middot; Luz-Saint-Sauveur
			</h1>
		</div>
	</section>

		<section class="section-default" id="mediatheque">
			<article class="grid grid-cols-1 gap-3 lg:grid-cols-2 lg:gap-5">
				<div class="flex flex-col">
					<h2 class="text-primary pb-2 lg:pb-3">{t('MEDIATHEQUE_TITRE')}</h2>
					<p class="distinguished pb-8 lg:pb-16">{t('MEDIATHEQUE_INTRO')}</p>
					<p>{t('MEDIATHEQUE_DESC')}</p>
				</div>
				<div class="flex flex-col gap-4 lg:gap-5">
					<HoverImageSwap
						client:visible
						direction="horizontal"
						rows={[
							{
								slots: [{ src: FirstImg.src, alt: '' }],
								defaultIndex: 0,
								height: 'h-[300px]',
								width: 'w-full'
							},
							{
								slots: [
									{ src: SecondImg.src, alt: '', barClassName: 'bg-secondary' },
									{ src: ThirdImg.src, alt: '', barClassName: 'bg-secondary-muted' },
									{ src: FourthImg.src, alt: '' }
								],
								defaultIndex: 2,
								height: 'h-[180px]',
								width: 'w-full'
							}
						]}
					/>
				</div>
			</article>
		</section>

		{evenements.docs.length > 0 && (
		<section class="section-default" id="evenements">
			<article>
				<h2 class="pb-2 lg:pb-3">{t('MEDIATHEQUE_EVENEMENTS_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-16">{t('MEDIATHEQUE_EVENEMENTS_INTRO')}</p>
			</article>

			<SpectaclesGrid
				client:load
				initialData={evenements}
				locale={locale}
				localePrefix={localePrefix}
				limit={EVENEMENTS_LIMIT}
				payloadUrl={PAYLOAD_URL}
				collection="mediatheque"
				showFilters={false}
				translations={evenementsTranslations}
			/>
		</section>
		)}

		{ludotheque.docs.length > 0 && (
		<section class="section-default bg-primary" id="ludotheque">
			<article>
				<h2 class="text-secondary pb-2 lg:pb-3">{t('LUDOTHEQUE_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-16">{t('LUDOTHEQUE_INTRO')}</p>
				<p class="lg:w-2/3">
					{t('LUDOTHEQUE_DESC_LONG')}
				</p>
			</article>

			<LudothequeGrid
				client:load
				initialData={ludotheque}
				locale={locale}
				localePrefix={localePrefix}
				limit={LUDO_LIMIT}
				payloadUrl={PAYLOAD_URL}
				showFilters={false}
				translations={ludoTranslations}
			/>
		</section>
		)}

		<section class="section-default" id="cyberbase">
			<article class="pb-8 lg:pb-16">
				<h2 class="pb-2 lg:pb-3">{t('CYBERBASE_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-16">{t('CYBERBASE_INTRO')}</p>
				<p class="lg:w-2/3">{t('CYBERBASE_DESC')}</p>
			</article>

			<div class="hidden lg:block">
				<HoverImageSwap
					client:visible
					direction="horizontal"
					rows={[{
						slots: [
							{ src: FifthImg.src, alt: '', barClassName: 'bg-secondary' },
							{ src: SixthImg.src, alt: '', barClassName: 'bg-secondary-muted' },
							{ src: SeventhImg.src, alt: '', barClassName: 'bg-primary' },
							{ src: EighthImg.src, alt: '', barClassName: 'bg-secondary' },
							{ src: NinthImg.src, alt: '', barClassName: 'bg-secondary-muted' },
							{ src: TenthImg.src, alt: '' }
						],
						defaultIndex: 5,
						height: 'h-[250px]',
						width: 'w-full'
					}]}
				/>
			</div>
			<div class="lg:hidden flex flex-col gap-4">
				<HoverImageSwap
					client:visible
					direction="horizontal"
					rows={[{
						slots: [
							{ src: FifthImg.src, alt: '' },
							{ src: SixthImg.src, alt: '', barClassName: 'bg-primary' },
							{ src: SeventhImg.src, alt: '', barClassName: 'bg-secondary' }
						],
						defaultIndex: 0,
						height: 'h-[180px]',
						width: 'w-full'
					}]}
				/>
				<HoverImageSwap
					client:visible
					direction="horizontal"
					rows={[{
						slots: [
							{ src: EighthImg.src, alt: '', barClassName: 'bg-secondary' },
							{ src: NinthImg.src, alt: '', barClassName: 'bg-secondary-muted' },
							{ src: TenthImg.src, alt: '' }
						],
						defaultIndex: 2,
						height: 'h-[180px]',
						width: 'w-full'
					}]}
				/>
			</div>
		</section>

		<section class="section-default" id="autres-medias">
			<article>
				<h2 class="pb-2 lg:pb-3">{t('AUTRES_MEDIAS_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-16">{t('AUTRES_MEDIAS_INTRO')}</p>
				<p class="lg:w-2/3">{t('AUTRES_MEDIAS_DESC')}</p>
			</article>
		</section>
	</main>
</Layout>
