---
export const prerender = true
import { find } from '@/api/payload'
import FirstImg from '@/assets/imgs/mediatheque/1.webp'
import SecondImg from '@/assets/imgs/mediatheque/2.webp'
import FourthImg from '@/assets/imgs/mediatheque/4.webp'
import FivethImg from '@/assets/imgs/mediatheque/5.webp'
import SixthImg from '@/assets/imgs/mediatheque/6.webp'
import { LudothequeGrid } from '@/components/ludotheque-grid'
import MyImage from '@/components/my-image.astro'
import { createTranslator, I18n } from '@/i18n/translations'
import { getRelativeLocaleUrl } from 'astro:i18n'
import Layout from '@/layouts/layout.astro'
import type { Mediatheque } from '@/types/mediatheque'
import FirstCyberbaseImg from '@/assets/imgs/cyberbase/1.webp'
import SecondCyberbaseImg from '@/assets/imgs/cyberbase/2.webp'
import ThirdCyberbaseImg from '@/assets/imgs/cyberbase/3.webp'
import FirstMediaImg from '@/assets/imgs/media/1.webp'
import SecondMediaImg from '@/assets/imgs/media/2.webp'
import ThirdMediaImg from '@/assets/imgs/media/3.webp'

const locale = (Astro.currentLocale || 'fr') as I18n
const t = createTranslator(locale)
const localePrefix = getRelativeLocaleUrl(locale, '').replace(/\/$/, '')

const LUDO_LIMIT = 6

const ludotheque = await find<Mediatheque>('mediatheque', {
	limit: LUDO_LIMIT,
	page: 1,
	locale,
	upcomingOnly: false,
	where: {
		type: { equals: 'ludotheque' }
	}
})

const ludoTranslations = {
	PRECEDENT: t('PRECEDENT'),
	SUIVANT: t('SUIVANT'),
	IMAGE_PLACEHOLDER: t('IMAGE_PLACEHOLDER'),
	EN_SAVOIR_PLUS: t('EN_SAVOIR_PLUS'),
	MOTS_CLES: t('MOTS_CLES'),
	TEMPS_DE_JEU: t('TEMPS_DE_JEU'),
	NOMBRE_DE_JOUEURS: t('NOMBRE_DE_JOUEURS'),
	AGE: t('AGE'),
	AUCUN_CONTENU: t('AUCUN_CONTENU'),
	TOUS: t('TOUS'),
	durationOptions: [
		{ key: t('LUDO_DURATION_15'), value: '15' },
		{ key: t('LUDO_DURATION_30'), value: '30' },
		{ key: t('LUDO_DURATION_1H'), value: '1h' },
		{ key: t('LUDO_DURATION_1H_PLUS'), value: '1h+' }
	],
	playersOptions: [
		{ key: t('LUDO_PLAYERS_1'), value: '1' },
		{ key: t('LUDO_PLAYERS_1_2'), value: '1-2' },
		{ key: t('LUDO_PLAYERS_1_4'), value: '1-4' },
		{ key: t('LUDO_PLAYERS_1_8'), value: '1-8' },
		{ key: t('LUDO_PLAYERS_4_PLUS'), value: '4+' }
	],
	publicOptions: [
		{ key: t('LUDO_PUBLIC_MINUS_3'), value: '-3' },
		{ key: t('LUDO_PUBLIC_3_PLUS'), value: '3+' },
		{ key: t('LUDO_PUBLIC_12_PLUS'), value: '12+' },
		{ key: t('LUDO_PUBLIC_16_PLUS'), value: '16+' },
		{ key: t('LUDO_PUBLIC_18_PLUS'), value: '18+' }
	],
	publicLabels: {
		'-3': t('LUDO_PUBLIC_MINUS_3'),
		'3+': t('LUDO_PUBLIC_3_PLUS'),
		'12+': t('LUDO_PUBLIC_12_PLUS'),
		'16+': t('LUDO_PUBLIC_16_PLUS'),
		'18+': t('LUDO_PUBLIC_18_PLUS')
	},
	playersLabels: {
		'1': t('LUDO_PLAYERS_1'),
		'1-2': t('LUDO_PLAYERS_1_2'),
		'1-4': t('LUDO_PLAYERS_1_4'),
		'1-8': t('LUDO_PLAYERS_1_8'),
		'4+': t('LUDO_PLAYERS_4_PLUS')
	},
	durationLabels: {
		'15': t('LUDO_DURATION_15'),
		'30': t('LUDO_DURATION_30'),
		'1h': t('LUDO_DURATION_1H'),
		'1h+': t('LUDO_DURATION_1H_PLUS')
	}
}

const PAYLOAD_URL = import.meta.env.PUBLIC_PAYLOAD_URL
---


<Layout title={t('ACCUEIL_TITLE')}>
	<main>
		<section class="section-default" id="mediatheque">
			<article class="grid grid-cols-1 lg:grid-cols-2 gap-3 lg:gap-5">
				<div class="flex flex-col order-1 lg:order-2">
					<h2 class="text-primary pb-2 lg:pb-3">{t('MEDIATHEQUE_TITRE')}</h2>
					<p class="distinguished pb-8 lg:pb-16">{t('MEDIATHEQUE_INTRO')}</p>
					<p>{t('MEDIATHEQUE_DESC')}</p>
				</div>
				<div class="grid grid-cols-3 gap-2 lg:gap-5 order-2 lg:order-1 overflow-hidden">
					<MyImage alt="" src={FirstImg} width={400} height={370} layout="fullWidth" class="col-span-2 max-h-48 lg:max-h-none object-cover w-full" />
					<MyImage alt="" src={SecondImg} width={400} height={370} layout="fullWidth" class="col-span-1 max-h-48 lg:max-h-none object-cover w-full" />
					<MyImage alt="" src={FourthImg} width={400} height={370} layout="fullWidth" class="col-span-3 max-h-32 lg:max-h-none object-cover w-full" />
					<MyImage alt="" src={FivethImg} width={400} height={150} layout="fullWidth" class="col-span-1 max-h-24 lg:max-h-none object-cover w-full" />
					<MyImage alt="" src={SixthImg} width={400} height={150} layout="fullWidth" class="col-span-2 max-h-24 lg:max-h-none object-cover w-full" />
				</div>
			</article>
		</section>


		<section class="section-default bg-primary/20" id="ludotheque">
			<article>
				<h2 class="pb-2 lg:pb-3">{t('LUDOTHEQUE_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-6">{t('LUDOTHEQUE_INTRO')}</p>
				<p class="lg:w-2/3">
					{t('LUDOTHEQUE_DESC_LONG')}
				</p>
			</article>

			<LudothequeGrid
				client:load
				initialData={ludotheque}
				locale={locale}
				localePrefix={localePrefix}
				limit={LUDO_LIMIT}
				payloadUrl={PAYLOAD_URL}
				showFilters={true}
				translations={ludoTranslations}
			/>
		</section>

		<section class="section-default" id="cyberbase">
			<article class="grid grid-cols-1 lg:grid-cols-2 gap-3 lg:gap-5">
				<div class="flex flex-col order-1">
					<h2 class="text-primary pb-2 lg:pb-3">{t('CYBERBASE_TITRE')}</h2>
					<p class="distinguished pb-8 lg:pb-16">{t('CYBERBASE_INTRO')}</p>
					<p>{t('CYBERBASE_DESC')}</p>
				</div>
				<div class="grid grid-cols-2 lg:grid-cols-4 gap-2 lg:gap-5 order-2">
					<MyImage alt="" src={FirstCyberbaseImg} width={200} height={400} layout="fullWidth" class="col-span-1 max-h-48 lg:max-h-none object-cover" />
					<MyImage alt="" src={SecondCyberbaseImg} width={200} height={400} layout="fullWidth" class="col-span-1 max-h-48 lg:max-h-none object-cover" />
					<MyImage alt="" src={ThirdCyberbaseImg} width={420} height={400} layout="fullWidth" class="col-span-2 lg:col-span-2 max-h-48 lg:max-h-none object-cover" />
				</div>
			</article>
		</section>

		<section class="section-default bg-secondary/20" id="autres-medias">
			<article class="grid grid-cols-1 lg:grid-cols-2 gap-3 lg:gap-5">
				<div class="flex flex-col order-1 lg:order-2">
					<h2 class="text-secondary pb-2 lg:pb-3">{t('AUTRES_MEDIAS_TITRE')}</h2>
					<p class="distinguished pb-8 lg:pb-16">{t('AUTRES_MEDIAS_INTRO')}</p>
					<p>{t('AUTRES_MEDIAS_DESC')}</p>
				</div>
				<div class="grid grid-cols-2 gap-2 lg:gap-5 order-2 lg:order-1">
					<MyImage alt="" src={FirstMediaImg} width={420} height={260} layout="fullWidth" class="col-span-1" />
					<MyImage alt="" src={SecondMediaImg} width={420} height={260} layout="fullWidth" class="col-span-1" />
					<MyImage alt="" src={ThirdMediaImg} width={900} height={200} layout="fullWidth" class="col-span-2" />
				</div>
			</article>
		</section>
	</main>
</Layout>
