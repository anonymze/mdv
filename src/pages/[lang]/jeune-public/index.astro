---
export const prerender = true
export const getStaticPaths = () => [
	{ params: { lang: 'fr' } },
	{ params: { lang: 'en' } },
	{ params: { lang: 'es' } }
]
import { find } from '@/api/payload'
import MyImage from '@/components/my-image.astro'
import SpectacleCard from '@/components/spectacle-card.astro'
import { createTranslator, I18n } from '@/i18n/translations'
import { getRelativeLocaleUrl } from 'astro:i18n'
import Layout from '@/layouts/layout.astro'
import {
	translateLudoDuration,
	translatePublicField
} from '@/lib/translate-fields'
import type { ArtVivant } from '@/types/art-vivant'
import type { Cinema } from '@/types/cinema'
import type { Ludotheque, Mediatheque } from '@/types/mediatheque'
import type { ImmanquableDoc } from '@/types/immanquable'
import { HoverImageSwap } from '@/components/hover-image-swap'
import LayoutHome1 from '@/assets/imgs/layout_jeune/1.webp'
import LayoutHome2 from '@/assets/imgs/layout_jeune/1.webp'
import LayoutHome3 from '@/assets/imgs/layout_jeune/2.webp'
import LayoutHome4 from '@/assets/imgs/layout_jeune/3.webp'
import LayoutHome5 from '@/assets/imgs/layout_jeune/1.webp'
import LayoutHome6 from '@/assets/imgs/layout_jeune/1.webp'

const locale = (Astro.params.lang || 'fr') as I18n
const t = createTranslator(locale)

const evenements = await find<ArtVivant>('art_vivant', {
	limit: 4,
	locale,
	where: {
		type: { equals: 'evenement' },
		jeunePublic: { equals: true }
	}
})

const ludotheque = await find<Ludotheque>('mediatheque', {
	limit: 3,
	locale,
	upcomingOnly: false,
	where: {
		type: { equals: 'ludotheque' },
		jeunePublic: { equals: true }
	}
})

const cinema = await find<Cinema>('cinema', {
	limit: 4,
	locale,
	where: {
		jeunePublic: { equals: true }
	}
})

const PAYLOAD_URL = import.meta.env.PUBLIC_PAYLOAD_URL

const immanquableRes = await fetch(`${PAYLOAD_URL}/api/immanquable?collection=art_vivant&locale=${locale}`)
const immanquableData = (await immanquableRes.json()) as { docs: ImmanquableDoc[] }
const immanquables = immanquableData.docs ?? []

const IMMANQUABLE_PATHS: Record<string, (id: string) => string> = {
	art_vivant: (id) => `art-vivant/spectacle/${id}`,
	cinema: (id) => `cinema/seance/${id}`,
	exposition: () => 'exposition',
	parc_national: (id) => `parc-national/evenement/${id}`,
	autres_actualites: (id) => `autres-actualites/evenement/${id}`
}
const getImmanquableUrl = (item: ImmanquableDoc) =>
	getRelativeLocaleUrl(locale, IMMANQUABLE_PATHS[item._collection]?.(item.id) ?? 'jeune-public')
const getImmanquableImage = (item: ImmanquableDoc) => {
	const thumb = 'thumbnail' in item ? item.thumbnail : undefined
	const fallback = 'images' in item ? item.images?.[0]?.image : undefined
	const url = thumb?.url ?? fallback?.url
	return {
		src: url ? `${PAYLOAD_URL}${url}` : LayoutHome6.src,
		alt: thumb?.alt ?? ''
	}
}
---

<Layout title={t('JEUNESSE')}>
	<main id="main-content">
	<section
		class="relative grid h-[calc(100dvh-var(--header-height)+var(--header-overlap))] max-h-225 grid-cols-40 grid-rows-40 gap-2 sm:gap-2.5 md:gap-3.5 bg-[#345f6e] p-1.5 sm:p-3.5 pt-11.5 sm:pt-16 *:rounded-lg lg:rounded-b-3xl"
	>
		<div class="bg-cream relative col-span-24 col-start-1 row-span-17 row-start-1 overflow-hidden lg:p-5">
			<img src={LayoutHome1.src} alt="" loading="eager" class="absolute inset-0 h-full w-full object-cover lg:hidden" />
			<div class="bg-cream/80 absolute inset-0 lg:hidden"></div>
			<div class="hidden lg:block">
				<h2 class="pb-2 text-2xl lg:pb-3">{t('HERO_TILE_JEUNESSE_SUB')}</h2>
				<p class="distinguished pb-3 lg:pb-6">{t('JEUNESSE_HERO_SUB')}</p>
				<p class="text-sm">
					{t('JEUNESSE_HERO_DESC_PART1')}
					<br /><br />
					{t('JEUNESSE_HERO_DESC_PART2')}
				</p>
			</div>
		</div>
		<div class="bg-cream relative col-span-16 col-start-25 row-start-1 row-end-24 overflow-hidden md:row-end-21">
			<img src={LayoutHome3.src} alt="" loading="eager" fetchpriority="high" class="h-full w-full rounded-lg object-cover" />
		</div>
		<div class="bg-cream relative col-span-13 col-start-1 row-span-23 row-start-18 overflow-hidden">
			<img src={LayoutHome4.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
		</div>
		<div class="relative hidden overflow-hidden bg-[#be7a5a] md:col-span-13 md:col-start-14 md:row-span-17 md:row-start-24 md:block">
			<img src={LayoutHome5.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
		</div>
		<div class="bg-cream relative col-span-27 col-start-14 row-start-24 row-end-41 flex flex-col gap-3 overflow-hidden p-3 md:col-span-14 md:col-start-27 md:row-start-21 md:gap-7 lg:p-5">
			{immanquables.length > 0 && (
				<>
					<h2 class="text-center text-xl! md:text-right">{t('LES_IMMANQUABLES')}</h2>
					{immanquables.length === 1 ? (
						<a
							href={getImmanquableUrl(immanquables[0])}
							aria-label={immanquables[0].title}
							class="shadow-card relative block flex-1 overflow-hidden rounded-3xl border border-foreground"
						>
							<img
								src={getImmanquableImage(immanquables[0]).src}
								alt={getImmanquableImage(immanquables[0]).alt}
								loading="eager"
								class="h-full w-full object-cover"
							/>
						</a>
					) : (
						<HoverImageSwap
							client:visible
							direction="horizontal"
							className="flex-1 min-h-0"
							rows={[{
								slots: immanquables.map((item, i) => {
									const img = getImmanquableImage(item)
									return {
										src: img.src,
										alt: img.alt || item.title,
										href: getImmanquableUrl(item),
										...(item.immanquable === 'coup_de_coeur' && { badge: t('COUP_DE_COEUR') }),
										...(item.immanquable === 'cine_passion' && { badge: 'Cine passion' }),
										...(i > 0 && { barClassName: ['bg-secondary', 'bg-secondary-muted', 'bg-primary'][(i - 1) % 3] })
									}
								}),
								defaultIndex: 0,
								height: 'h-full',
								width: 'w-full',
								cardStyle: true,
								compactPills: true
							}]}
						/>
					)}
				</>
			)}
		</div>
		<div class="bg-cream z-40 col-span-17 col-start-12 row-span-6 row-start-18 flex translate-x-[0.2rem] items-center justify-center overflow-hidden p-2 outline-8 outline-[#345f6e] sm:outline-10 md:outline-14">
			<h1 class="text-primary text-center text-xl! leading-7 sm:text-2xl! sm:leading-8 md:text-4xl! md:leading-12 lg:text-[40px]! lg:leading-12 font-medium! break-words">
				{t('JEUNESSE')}
			</h1>
		</div>
	</section>

	<section class="section-default lg:hidden">
		<article>
			<h2 class="pb-2 lg:pb-3">{t('HERO_TILE_JEUNESSE_SUB')}</h2>
			<p class="distinguished pb-3 lg:pb-16">{t('JEUNESSE_HERO_SUB')}</p>
			<p class="pb-2 lg:w-2/3">{t('JEUNESSE_HERO_DESC_PART1')}</p>
			<p class="lg:w-2/3">{t('JEUNESSE_HERO_DESC_PART2')}</p>
		</article>
	</section>

		{evenements.docs.length > 0 && (
		<section class="section-default" id="spectacles">
			<h2 class="text-primary pb-2 lg:pb-3">{t('SPECTACLES_JEUNE_PUBLIC_TITRE')}</h2>
			<p class="distinguished pb-3 lg:pb-16">{t('SPECTACLES_JEUNE_PUBLIC_INTRO')}</p>
			<p class="lg:w-2/3">
				{t('SPECTACLES_JEUNE_PUBLIC_DESC')}
			</p>

			<div
				class="my-8 grid grid-cols-[repeat(auto-fit,320px)] justify-center lg:justify-between content-start gap-x-4 gap-y-8 *:only:col-span-full lg:my-16"
			>
				{
					evenements.docs.map((item) => {
						const descText = item.description.root.children
							.flatMap((para) => para.children)
							.filter((child) => child.type === 'text')
							.map((child) => child.text)
							.join(' ')

						return (
							<SpectacleCard
								title={item.title}
								href={getRelativeLocaleUrl(locale, `jeune-public/spectacles/${item.id}`)}
								locale={locale}
								description={descText}
								dateStart={item.date_start}
								genre={item.genre ?? ''}
								ctaLabel={t('EN_SAVOIR_PLUS')}
								imageSrc={item.thumbnail?.url}
								imageAlt={item.thumbnail?.alt}
								imageBlurhash={item.thumbnail?.blurhash}
								width="w-[320px]"
							/>
						)
					})
				}
			</div>
		</section>
		)}

		{cinema.docs.length > 0 && (
		<section class="section-default bg-primary pb-4" id="cinema">
			<article>
				<h2 class="pb-2 lg:pb-3">{t('CINEMA_JEUNE_PUBLIC_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-16">{t('CINEMA_JEUNE_PUBLIC_INTRO')}</p>
				<p class="lg:w-2/3">{t('CINEMA_JEUNE_PUBLIC_DESC')}</p>
			</article>

			<div class="my-8 grid grid-cols-1 gap-3 lg:my-16 lg:grid-cols-2 lg:gap-5">
				{
					cinema.docs.map((item) => {
						const synopsisText = item.synopsis.root.children
							.flatMap((para) => para.children)
							.filter((child) => child.type === 'text')
							.map((child) => child.text)
							.join(' ')

						return (
							<SpectacleCard
								title={item.title}
								href={getRelativeLocaleUrl(locale, `jeune-public/seance/${item.id}`)}
								locale={locale}
								description={synopsisText}
								dateStart={item.date_start}
								genre={`${translatePublicField(item.public, t)} - ${item.genre} - ${item.languages}`}
								ctaLabel={t('EN_SAVOIR_PLUS')}
								imageSrc={item.thumbnail?.url}
								imageAlt={item.thumbnail?.alt}
								imageBlurhash={item.thumbnail?.blurhash}
								height="h-[300px]"
							/>
						)
					})
				}
			</div>
		</section>
		)}

		{ludotheque.docs.length > 0 && (
		<section class="section-default" id="ludotheque">
			<article>
				<h2 class="pb-2 lg:pb-3">{t('LUDOTHEQUE_JEUNE_PUBLIC_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-16">{t('LUDOTHEQUE_JEUNE_PUBLIC_INTRO')}</p>
				<p class="lg:w-2/3">{t('LUDOTHEQUE_JEUNE_PUBLIC_DESC')}</p>
			</article>

			<div
				class="my-8 grid grid-cols-[repeat(auto-fit,360px)] justify-center lg:justify-between content-start gap-x-4 gap-y-8 *:only:col-span-full lg:my-16"
			>
				{
					ludotheque.docs.map((item) => {
						const descText = item.description.root.children
							.flatMap((para) => para.children)
							.filter((child) => child.type === 'text')
							.map((child) => child.text)
							.join(' ')

						return (
							<article
								class="group shadow-card relative col-span-1 overflow-hidden rounded-2xl border border-foreground bg-white w-[360px] h-[360px]"
							>
								<MyImage
									src={item.thumbnail?.url}
									alt={item.thumbnail?.alt ?? t('IMAGE_PLACEHOLDER')}
									background={item.thumbnail?.blurhash}
									width={275}
									height={400}
									class="h-full w-full rounded-2xl object-cover"
									loading="lazy"
									layout="fullWidth"
								/>
								<figure class="bg-background/90 absolute inset-x-0 bottom-0 h-[116px] overflow-hidden rounded-t-2xl p-4 transition-[height] duration-300 ease-[cubic-bezier(0.2,0,0,1)] group-hover:h-full">
									<figcaption>
										<h3 class="line-clamp-1 mb-0.5 group-hover:line-clamp-2">
											<a
												href={getRelativeLocaleUrl(locale, `jeune-public/ludotheque/${item.id}`)}
												class="after:absolute after:inset-0 after:z-10"
											>
												{item.title}
											</a>
										</h3>
										{item.genre && (
											<p class="distinguished text-primary! line-clamp-1 text-sm group-hover:line-clamp-2">{item.genre}</p>
										)}
										{(item.public || item.players || item.duration) && (
											<div class="bg-secondary text-secondary-foreground rounded-xl mt-1.5 flex items-center">
												<div class="flex-1 min-w-0 distinguished text-center text-xs py-2 px-2 truncate">{item.public}</div>
												<div class="bg-background distinguished flex-1 min-w-0 text-center text-xs py-1 px-2 mx-1 rounded-xl truncate">{item.players}</div>
												<div class="flex-1 min-w-0 distinguished text-center text-xs py-2 px-2 truncate">{translateLudoDuration(item.duration, t)}</div>
											</div>
										)}
										<div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-[cubic-bezier(0.2,0,0,1)] group-hover:grid-rows-[1fr]">
											<div class="overflow-hidden">
												{descText && <p class="text-foreground! line-clamp-8 pt-4 text-sm">{descText}</p>}
												<p class="text-secondary-muted! inline-flex items-center gap-2 pt-4 text-medium font-semibold transition-opacity opacity-0 duration-200 group-hover:opacity-100 group-hover:delay-200 pl-0.5">
													{t('EN_SAVOIR_PLUS')}
													<svg
														xmlns="http://www.w3.org/2000/svg"
														width="16"
														height="16"
														viewBox="0 0 24 24"
														fill="none"
														stroke="currentColor"
														stroke-width="2"
														stroke-linecap="round"
														stroke-linejoin="round"
													>
														<path d="M5 12h14" />
														<path d="m12 5 7 7-7 7" />
													</svg>
												</p>
											</div>
										</div>
									</figcaption>
								</figure>
							</article>
						)
					})
				}
			</div>
		</section>
		)}
	</main>
</Layout>
