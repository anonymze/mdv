---
export const prerender = true
export const getStaticPaths = () => [
	{ params: { lang: 'fr' } },
	{ params: { lang: 'en' } },
	{ params: { lang: 'es' } }
]
import FirstImg from '@/assets/imgs/artiste/1.webp'
import SecondImg from '@/assets/imgs/artiste/2.webp'
import ThirdImg from '@/assets/imgs/artiste/3.webp'
import FourthImg from '@/assets/imgs/artiste/4.webp'
import FifthImg from '@/assets/imgs/artiste/5.webp'
import { HoverImageSwap } from '@/components/hover-image-swap'
import MyImage from '@/components/my-image.astro'
import { Button } from '@/components/ui/button'
import { createTranslator, I18n } from '@/i18n/translations'
import Layout from '@/layouts/layout.astro'
import LayoutHome1 from '@/assets/imgs/layout_artiste/1.webp'
import LayoutHome2 from '@/assets/imgs/layout_artiste/1.webp'
import LayoutHome3 from '@/assets/imgs/layout_artiste/2.webp'
import LayoutHome4 from '@/assets/imgs/layout_artiste/3.webp'
import LayoutHome5 from '@/assets/imgs/layout_artiste/1.webp'
import LayoutHome6 from '@/assets/imgs/layout_artiste/1.webp'
import { getRelativeLocaleUrl } from 'astro:i18n'

const locale = (Astro.params.lang || 'fr') as I18n
const t = createTranslator(locale)
---

<Layout title={t('ARTISTE')}>
	<main id="main-content">

	<section
		class="relative grid h-[calc(100dvh-var(--header-height)+var(--header-overlap))] max-h-225 grid-cols-40 grid-rows-40 gap-2 sm:gap-2.5 md:gap-3.5 bg-[#345f6e] p-1.5 sm:p-3.5 pt-11.5 sm:pt-16 *:rounded-lg lg:rounded-b-3xl"
	>
		<div class="bg-cream relative col-span-24 col-start-1 row-span-17 row-start-1 overflow-hidden lg:p-5">
			<img src={LayoutHome1.src} alt="" loading="eager" class="absolute inset-0 h-full w-full object-cover lg:hidden" />
			<div class="hidden lg:block">
				<h2 class="pb-2 text-2xl lg:pb-3">{t('ARTISTE_HERO_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-6">{t('ARTISTE_HERO_SUB')}</p>
				<p class="text-sm">{t('ARTISTE_HERO_DESC')}</p>
			</div>
		</div>
		<div class="bg-cream relative col-span-16 col-start-25 row-start-1 row-end-24 overflow-hidden md:row-end-21">
			<img src={LayoutHome3.src} alt="" loading="eager" fetchpriority="high" class="h-full w-full rounded-lg object-cover" />
		</div>
		<div class="bg-cream relative col-span-13 col-start-1 row-span-23 row-start-18 overflow-hidden">
			<img src={LayoutHome4.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
		</div>
		<div class="relative hidden overflow-hidden bg-[#be7a5a] md:col-span-13 md:col-start-14 md:row-span-17 md:row-start-24 md:block">
			<img src={LayoutHome5.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
		</div>
		<div class="bg-cream relative col-span-27 col-start-14 row-start-24 row-end-41 flex flex-col items-center justify-end gap-3 overflow-hidden p-3 md:col-span-14 md:col-start-27 md:row-start-21 md:gap-7 lg:p-5">
			<Button link="/dossier_technique.pdf" openInNewTab size={'xl'} className="w-full">{t('DOSSIER_TECHNIQUE')}</Button>
		</div>
		<div class="bg-cream z-40 col-span-17 col-start-12 row-span-6 row-start-18 flex translate-x-[0.2rem] items-center justify-center overflow-hidden p-2 outline-8 outline-[#345f6e] sm:outline-10 md:outline-14">
			<h1 class="text-primary text-center text-xl! leading-7 sm:text-2xl! sm:leading-8 md:text-4xl! md:leading-12 lg:text-[40px]! lg:leading-12 font-medium! break-words">
				{t('ARTISTE')}
			</h1>
		</div>
	</section>

	<section class="section-default lg:hidden">
		<article>
			<h2 class="pb-2 lg:pb-3">{t('ARTISTE_HERO_TITRE')}</h2>
			<p class="distinguished pb-3 lg:pb-16">{t('ARTISTE_HERO_SUB')}</p>
			<p class="lg:w-2/3">{t('ARTISTE_HERO_DESC')}</p>
		</article>
	</section>

		<section class="section-default" id="residence">
			<article class="grid grid-cols-1 gap-3 lg:grid-cols-2 lg:gap-5">
				<div class="flex flex-col">
					<h2 class="text-primary pb-2 lg:pb-3">{t('RESIDENCE_ACCUEIL_TITRE')}</h2>
					<p class="distinguished pb-8 lg:pb-16">{t('RESIDENCE_ACCUEIL_INTRO')}</p>
					<p class="whitespace-pre-line">
						{t('RESIDENCE_ACCUEIL_DESC')}
					</p>
				</div>
				<div class="flex flex-col gap-4 lg:gap-5">
					<HoverImageSwap
						client:visible
						direction="horizontal"
						rows={[{
							slots: [
								{ src: FirstImg.src, alt: '' },
								{ src: ThirdImg.src, alt: '', barClassName: 'bg-secondary-muted' },
								{ src: FourthImg.src, alt: '', barClassName: 'bg-primary' }
							],
							defaultIndex: 0,
							height: 'h-[222px]',
							width: 'w-full'
						}]}
					/>
					<div class="rounded-2xl overflow-hidden h-[160px]">
						<MyImage
							src={SecondImg}
							alt=""
							width={420}
							height={160}
							layout="fullWidth"
							class="h-full w-full object-cover"
						/>
					</div>
				</div>
			</article>
		</section>

		<section class="section-default" id="informations">
			<article class="grid grid-cols-1 gap-3 lg:grid-cols-2 lg:gap-5">
				<div class="order-1 flex flex-col">
					<h2 class="text-primary pb-2 lg:pb-3">{t('INFORMATIONS_TECHNIQUES_TITRE')}</h2>
					<p class="distinguished pb-8 lg:pb-16">{t('INFORMATIONS_TECHNIQUES_INTRO')}</p>
					<p>
						{t('INFORMATIONS_TECHNIQUES_DESC')}
					</p>

					<Button link="/dossier_technique.pdf" openInNewTab size={'xl'} className="mt-auto w-fit my-6 lg:mb-0 lg:mt-auto"
						>{t('DOSSIER_TECHNIQUE')}</Button
					>
				</div>
				<div class="order-2 rounded-2xl overflow-hidden h-full min-h-[300px]">
					<MyImage
						alt=""
						src={FifthImg}
						width={400}
						height={400}
						layout="fullWidth"
						class="h-full w-full object-cover"
					/>
				</div>
			</article>
		</section>
	</main>
</Layout>
