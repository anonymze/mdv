---
export const prerender = true
export const getStaticPaths = () => [
	{ params: { lang: 'fr' } },
	{ params: { lang: 'en' } },
	{ params: { lang: 'es' } }
]
import { find } from '@/api/payload'
import LayoutHome1 from '@/assets/imgs/layout_home/1.webp'
import LayoutHome2 from '@/assets/imgs/layout_home/2.webp'
import LayoutHome3 from '@/assets/imgs/layout_home/3.webp'
import LayoutHome4 from '@/assets/imgs/layout_home/4.webp'
import LayoutHome5 from '@/assets/imgs/layout_home/5.webp'
import LayoutHome6 from '@/assets/imgs/layout_home/6.webp'
import FirstImg from '@/assets/imgs/mediatheque/1.webp'
import SecondImg from '@/assets/imgs/mediatheque/2.webp'
import ThirdImg from '@/assets/imgs/mediatheque/3.webp'
import FourthImg from '@/assets/imgs/mediatheque/4.webp'
import FifthImg from '@/assets/imgs/mediatheque/5.webp'
import SixthImg from '@/assets/imgs/mediatheque/6.webp'
import SeventhImg from '@/assets/imgs/mediatheque/7.webp'
import EighthImg from '@/assets/imgs/mediatheque/8.webp'
import { HoverImageSwap } from '@/components/hover-image-swap'
import { LudothequeGrid } from '@/components/ludotheque-grid'
import { SpectaclesGrid } from '@/components/spectacles-grid'
import { createTranslator, I18n } from '@/i18n/translations'
import Layout from '@/layouts/layout.astro'
import type { Ludotheque, MediathequeSpectacle } from '@/types/mediatheque'
import type { ImmanquableDoc } from '@/types/immanquable'
import { getRelativeLocaleUrl } from 'astro:i18n'

const locale = (Astro.params.lang || 'fr') as I18n
const t = createTranslator(locale)
const localePrefix = getRelativeLocaleUrl(locale, '').replace(/\/$/, '')

const EVENEMENTS_LIMIT = 4

const evenements = await find<MediathequeSpectacle>('mediatheque', {
	limit: EVENEMENTS_LIMIT,
	page: 1,
	locale,
	where: {
		type: { equals: 'mediatheque' }
	}
})

const evenementsTranslations = {
	PRECEDENT: t('PRECEDENT'),
	SUIVANT: t('SUIVANT'),
	IMAGE_PLACEHOLDER: t('IMAGE_PLACEHOLDER'),
	EN_SAVOIR_PLUS: t('EN_SAVOIR_PLUS'),
	AUCUN_CONTENU: t('AUCUN_CONTENU'),
	TOUS: t('TOUS')
}

const LUDO_LIMIT = 6

const ludotheque = await find<Ludotheque>('mediatheque', {
	limit: LUDO_LIMIT,
	page: 1,
	locale,
	upcomingOnly: false,
	where: {
		type: { equals: 'ludotheque' }
	}
})

const ludoTranslations = {
	PRECEDENT: t('PRECEDENT'),
	SUIVANT: t('SUIVANT'),
	IMAGE_PLACEHOLDER: t('IMAGE_PLACEHOLDER'),
	EN_SAVOIR_PLUS: t('EN_SAVOIR_PLUS'),
	MOTS_CLES: t('MOTS_CLES'),
	TEMPS_DE_JEU: t('TEMPS_DE_JEU'),
	NOMBRE_DE_JOUEURS: t('NOMBRE_DE_JOUEURS'),
	AGE: t('AGE'),
	JOUEURS: t('JOUEURS'),
	ANS_ET_PLUS: t('ANS_ET_PLUS'),
	AUCUN_CONTENU: t('AUCUN_CONTENU'),
	TOUS: t('TOUS'),
	durationOptions: [
		{ key: t('LUDO_DURATION_5'), value: '5' },
		{ key: t('LUDO_DURATION_10'), value: '10' },
		{ key: t('LUDO_DURATION_15'), value: '15' },
		{ key: t('LUDO_DURATION_30'), value: '30' },
		{ key: t('LUDO_DURATION_1H'), value: '1h' },
		{ key: t('LUDO_DURATION_1H_PLUS'), value: '1h+' }
	],
	playersOptions: [
		{ key: '1', value: '1' },
		{ key: '2', value: '2' },
		{ key: '3', value: '3' },
		{ key: '4', value: '4' },
		{ key: '5', value: '5' },
		{ key: '6', value: '6' },
		{ key: '7', value: '7' },
		{ key: '8', value: '8' },
		{ key: '8+', value: '8+' }
	],
	publicOptions: [
		{ key: '3', value: '3' },
		{ key: '12', value: '12' },
		{ key: '16', value: '16' },
		{ key: '18', value: '18' }
	],
	durationLabels: {
		'5': t('LUDO_DURATION_5'),
		'10': t('LUDO_DURATION_10'),
		'15': t('LUDO_DURATION_15'),
		'30': t('LUDO_DURATION_30'),
		'1h': t('LUDO_DURATION_1H'),
		'1h+': t('LUDO_DURATION_1H_PLUS')
	}
}

const PAYLOAD_URL = import.meta.env.PUBLIC_PAYLOAD_URL

const immanquableRes = await fetch(`${PAYLOAD_URL}/api/immanquable?collection=art_vivant&locale=${locale}`)
const immanquableData = (await immanquableRes.json()) as { docs: ImmanquableDoc[] }
const immanquables = immanquableData.docs ?? []

const IMMANQUABLE_PATHS: Record<string, (id: string) => string> = {
	art_vivant: (id) => `art-vivant/spectacle/${id}`,
	cinema: (id) => `cinema/seance/${id}`,
	exposition: () => 'exposition',
	parc_national: (id) => `parc-national/evenement/${id}`,
	autres_actualites: (id) => `autres-actualites/evenement/${id}`
}
const getImmanquableUrl = (item: ImmanquableDoc) =>
	getRelativeLocaleUrl(locale, IMMANQUABLE_PATHS[item._collection]?.(item.id) ?? 'mediatheque')
const getImmanquableImage = (item: ImmanquableDoc) => {
	const thumb = 'thumbnail' in item ? item.thumbnail : undefined
	const fallback = 'images' in item ? item.images?.[0]?.image : undefined
	const url = thumb?.url ?? fallback?.url
	return {
		src: url ? `${PAYLOAD_URL}${url}` : LayoutHome6.src,
		alt: thumb?.alt ?? ''
	}
}
---

<Layout title={t('MEDIATHEQUE')}>
	<main id="main-content">

	<section
		class="relative grid h-[calc(100dvh-var(--header-height)+var(--header-overlap))] max-h-225 grid-cols-40 grid-rows-40 gap-2 sm:gap-2.5 md:gap-3.5 bg-[#345f6e] p-1.5 sm:p-3.5 pt-11.5 sm:pt-16 *:rounded-lg lg:rounded-b-3xl"
	>
		<div class="bg-cream relative col-span-24 col-start-1 row-span-17 row-start-1 overflow-hidden lg:p-5">
			<img src={LayoutHome1.src} alt="" loading="eager" class="absolute inset-0 h-full w-full object-cover lg:hidden" />
			<div class="bg-cream/80 absolute inset-0 lg:hidden"></div>
			<div class="hidden lg:block">
				<h2 class="pb-2 text-2xl lg:pb-3">{t('MEDIATHEQUE_HERO_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-6">{t('MEDIATHEQUE_HERO_SUB')}</p>
				<p class="text-sm">
					{t('MEDIATHEQUE_HERO_DESC_PART1')}
					<br /><br />
					{t('MEDIATHEQUE_HERO_DESC_PART2')}
					<br /><br />
					{t('MEDIATHEQUE_HERO_DESC_PART3')}
				</p>
			</div>
		</div>
		<div class="bg-cream relative col-span-16 col-start-25 row-start-1 row-end-24 overflow-hidden md:row-end-21">
			<img src={LayoutHome3.src} alt="" loading="eager" fetchpriority="high" class="h-full w-full rounded-lg object-cover" />
		</div>
		<div class="bg-cream relative col-span-13 col-start-1 row-span-23 row-start-18 overflow-hidden">
			<img src={LayoutHome4.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
		</div>
		<div class="relative hidden overflow-hidden bg-[#be7a5a] md:col-span-13 md:col-start-14 md:row-span-17 md:row-start-24 md:block">
			<img src={LayoutHome5.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
		</div>
		<div class="bg-cream relative col-span-27 col-start-14 row-start-24 row-end-41 flex flex-col gap-3 overflow-hidden p-3 md:col-span-14 md:col-start-27 md:row-start-21 md:gap-7 lg:p-5">
			{immanquables.length > 0 && (
				<>
					<h2 class="text-center text-xl! md:text-right">{t('LES_IMMANQUABLES')}</h2>
					{immanquables.length === 1 ? (
						<a
							href={getImmanquableUrl(immanquables[0])}
							aria-label={immanquables[0].title}
							class="shadow-card relative block flex-1 overflow-hidden rounded-3xl border border-black"
						>
							<img
								src={getImmanquableImage(immanquables[0]).src}
								alt={getImmanquableImage(immanquables[0]).alt}
								loading="eager"
								class="h-full w-full object-cover"
							/>
						</a>
					) : (
						<HoverImageSwap
							client:visible
							direction="horizontal"
							className="flex-1 min-h-0"
							rows={[{
								slots: immanquables.map((item, i) => {
									const img = getImmanquableImage(item)
									return {
										src: img.src,
										alt: img.alt || item.title,
										href: getImmanquableUrl(item),
										...(item.immanquable === 'coup_de_coeur' && { badge: t('COUP_DE_COEUR') }),
										...(item.immanquable === 'cine_passion' && { badge: 'Cine passion' }),
										...(i > 0 && { barClassName: ['bg-secondary', 'bg-secondary-muted', 'bg-primary'][(i - 1) % 3] })
									}
								}),
								defaultIndex: 0,
								height: 'h-full',
								width: 'w-full',
								cardStyle: true,
								compactPills: true
							}]}
						/>
					)}
				</>
			)}
		</div>
		<div class="bg-cream z-40 col-span-17 col-start-12 row-span-6 row-start-18 flex translate-x-[0.2rem] items-center justify-center overflow-hidden p-2 outline-8 outline-[#345f6e] sm:outline-10 md:outline-14">
			<h1 class="text-primary text-center text-xl! leading-7 sm:text-2xl! sm:leading-8 md:text-4xl! md:leading-12 lg:text-[40px]! lg:leading-12 font-medium! break-words">
				{t('MEDIATHEQUE')}
			</h1>
		</div>
	</section>

	<section class="section-default lg:hidden">
		<article>
			<h2 class="pb-2 lg:pb-3">{t('MEDIATHEQUE_HERO_TITRE')}</h2>
			<p class="distinguished pb-3 lg:pb-16">{t('MEDIATHEQUE_HERO_SUB')}</p>
			<p class="pb-2 lg:w-2/3">{t('MEDIATHEQUE_HERO_DESC_PART1')}</p>
			<p class="pb-2 lg:w-2/3">{t('MEDIATHEQUE_HERO_DESC_PART2')}</p>
			<p class="lg:w-2/3">{t('MEDIATHEQUE_HERO_DESC_PART3')}</p>
		</article>
	</section>

		<section class="section-default" id="mediatheque">
			<article class="grid grid-cols-1 gap-3 lg:grid-cols-2 lg:gap-5">
				<div class="flex flex-col">
					<h2 class="text-primary pb-2 lg:pb-3">{t('MEDIATHEQUE_TITRE')}</h2>
					<p class="distinguished pb-8 lg:pb-16">{t('MEDIATHEQUE_INTRO')}</p>
					<p>{t('MEDIATHEQUE_DESC')}</p>
				</div>
				<div class="flex flex-col gap-4 lg:gap-5">
					<HoverImageSwap
						client:visible
						direction="horizontal"
						rows={[
							{
								slots: [{ src: FirstImg.src, alt: '' }],
								defaultIndex: 0,
								height: 'h-[300px]',
								width: 'w-full'
							},
							{
								slots: [
									{ src: SecondImg.src, alt: '', barClassName: 'bg-secondary' },
									{ src: ThirdImg.src, alt: '', barClassName: 'bg-secondary-muted' },
									{ src: FourthImg.src, alt: '' }
								],
								defaultIndex: 2,
								height: 'h-[180px]',
								width: 'w-full'
							}
						]}
					/>
				</div>
			</article>
		</section>

		{evenements.docs.length > 0 && (
		<section class="section-default" id="evenements">
			<article>
				<h2 class="pb-2 lg:pb-3">{t('MEDIATHEQUE_EVENEMENTS_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-16">{t('MEDIATHEQUE_EVENEMENTS_INTRO')}</p>
			</article>

			<SpectaclesGrid
				client:load
				initialData={evenements}
				locale={locale}
				localePrefix={localePrefix}
				limit={EVENEMENTS_LIMIT}
				payloadUrl={PAYLOAD_URL}
				collection="mediatheque"
				showFilters={false}
				translations={evenementsTranslations}
			/>
		</section>
		)}

		{ludotheque.docs.length > 0 && (
		<section class="section-default bg-primary" id="ludotheque">
			<article>
				<h2 class="text-secondary pb-2 lg:pb-3">{t('LUDOTHEQUE_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-16">{t('LUDOTHEQUE_INTRO')}</p>
				<p class="lg:w-2/3">
					{t('LUDOTHEQUE_DESC_LONG')}
				</p>
			</article>

			<LudothequeGrid
				client:load
				initialData={ludotheque}
				locale={locale}
				localePrefix={localePrefix}
				limit={LUDO_LIMIT}
				payloadUrl={PAYLOAD_URL}
				showFilters={false}
				translations={ludoTranslations}
			/>
		</section>
		)}

		<section class="section-default" id="cyberbase">
			<article class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:items-start lg:gap-10">
				<div>
					<h2 class="pb-2 lg:pb-3">{t('CYBERBASE_TITRE')}</h2>
					<p class="distinguished pb-3 lg:pb-16">{t('CYBERBASE_INTRO')}</p>
					<p>{t('CYBERBASE_DESC')}</p>
				</div>

				<div class="grid grid-cols-2 gap-2 lg:gap-4">
					<img src={FifthImg.src} alt="" loading="lazy" decoding="async" class="aspect-[4/3] h-full w-full rounded-lg object-cover" />
					<img src={SixthImg.src} alt="" loading="lazy" decoding="async" class="aspect-[4/3] h-full w-full rounded-lg object-cover" />
					<img src={SeventhImg.src} alt="" loading="lazy" decoding="async" class="aspect-[4/3] h-full w-full rounded-lg object-cover" />
					<img src={EighthImg.src} alt="" loading="lazy" decoding="async" class="aspect-[4/3] h-full w-full rounded-lg object-cover" />
				</div>
			</article>
		</section>

		<section class="section-default" id="autres-medias">
			<article>
				<h2 class="pb-2 lg:pb-3">{t('AUTRES_MEDIAS_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-16">{t('AUTRES_MEDIAS_INTRO')}</p>
				<p class="lg:w-2/3">{t('AUTRES_MEDIAS_DESC')}</p>
			</article>
		</section>
	</main>
</Layout>
