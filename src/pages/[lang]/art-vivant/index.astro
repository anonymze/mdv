---
export const prerender = true
export const getStaticPaths = () => [
	{ params: { lang: 'fr' } },
	{ params: { lang: 'en' } },
	{ params: { lang: 'es' } }
]
import { find } from '@/api/payload'
import FirstMediaImg from '@/assets/imgs/art_vivant/1.webp'
import SecondMediaImg from '@/assets/imgs/art_vivant/2.webp'
import ThirdMediaImg from '@/assets/imgs/art_vivant/3.webp'
import FourthMediaImg from '@/assets/imgs/art_vivant/4.webp'
import LayoutHome1 from '@/assets/imgs/layout_home/1.webp'
import LayoutHome3 from '@/assets/imgs/layout_home/3.webp'
import LayoutHome4 from '@/assets/imgs/layout_home/4.webp'
import LayoutHome5 from '@/assets/imgs/layout_home/5.webp'
import LayoutHome6 from '@/assets/imgs/layout_home/6.webp'
import { HoverImageSwap } from '@/components/hover-image-swap'
import MyImage from '@/components/my-image.astro'
import SpectacleCard from '@/components/spectacle-card.astro'
import { SpectaclesGrid } from '@/components/spectacles-grid'
import { createTranslator, I18n } from '@/i18n/translations'
import Layout from '@/layouts/layout.astro'
import type { ArtVivant } from '@/types/art-vivant'
import type { ImmanquableDoc } from '@/types/immanquable'
import { getRelativeLocaleUrl } from 'astro:i18n'

const locale = (Astro.params.lang || 'fr') as I18n
const t = createTranslator(locale)
const localePrefix = getRelativeLocaleUrl(locale, '').replace(/\/$/, '')

const SPECTACLES_LIMIT = 6
const RESIDENCE_LIMIT = 4

const spectacles = await find<ArtVivant>('art_vivant', {
	limit: SPECTACLES_LIMIT,
	page: 1,
	locale,
	where: { type: { equals: 'evenement' } }
})
const residences = await find<ArtVivant>('art_vivant', {
	limit: RESIDENCE_LIMIT,
	locale,
	where: { type: { equals: 'residence' } }
})

const immanquableRes = await fetch(
	`${import.meta.env.PUBLIC_PAYLOAD_URL}/api/immanquable?collection=art_vivant&locale=${locale}`
)
const immanquableData = (await immanquableRes.json()) as { docs: ImmanquableDoc[] }
const immanquables = immanquableData.docs ?? []

const IMMANQUABLE_PATHS: Record<string, (id: string) => string> = {
	art_vivant: (id) => `art-vivant/spectacle/${id}`,
	cinema: (id) => `cinema/seance/${id}`,
	exposition: () => 'exposition',
	parc_national: (id) => `parc-national/evenement/${id}`,
	autres_actualites: (id) => `autres-actualites/evenement/${id}`
}
const getImmanquableUrl = (item: ImmanquableDoc) =>
	getRelativeLocaleUrl(locale, IMMANQUABLE_PATHS[item._collection]?.(item.id) ?? 'art-vivant')
const getImmanquableImage = (item: ImmanquableDoc) => {
	const thumb = 'thumbnail' in item ? item.thumbnail : undefined
	const fallback = 'images' in item ? item.images?.[0]?.image : undefined
	const url = thumb?.url ?? fallback?.url
	return {
		src: url ? `${import.meta.env.PUBLIC_PAYLOAD_URL}${url}` : LayoutHome6.src,
		alt: thumb?.alt ?? ''
	}
}

const PAYLOAD_URL = import.meta.env.PUBLIC_PAYLOAD_URL
// const immanquableImg = immanquable?.thumbnail?.url ? `${PAYLOAD_URL}${immanquable.thumbnail.url}` : ParcImg1.src

const spectacleTranslations = {
	PRECEDENT: t('PRECEDENT'),
	SUIVANT: t('SUIVANT'),
	IMAGE_PLACEHOLDER: t('IMAGE_PLACEHOLDER'),
	EN_SAVOIR_PLUS: t('EN_SAVOIR_PLUS'),
	MOTS_CLES: t('MOTS_CLES'),
	GENRE: t('GENRE'),
	DATE: t('DATE'),
	AUCUN_CONTENU: t('AUCUN_CONTENU'),
	TOUS: t('TOUS'),
	genreOptions: [
		{ key: t('SPECTACLE_GENRE_CIRQUE'), value: 'Cirque' },
		{ key: t('SPECTACLE_GENRE_CONCERT'), value: 'Concert' },
		{ key: t('SPECTACLE_GENRE_DANSE'), value: 'Danse' },
		{ key: t('SPECTACLE_GENRE_HUMOUR'), value: 'Humour' },
		{ key: t('SPECTACLE_GENRE_MAGIE'), value: 'Magie' },
		{ key: t('SPECTACLE_GENRE_MUSIQUE'), value: 'Musique' },
		{ key: t('SPECTACLE_GENRE_SPECTACLE'), value: 'Spectacle' },
		{ key: t('SPECTACLE_GENRE_THEATRE'), value: 'Théâtre' }
	],
	dateOptions: [
		{ key: t('DATE_SEMAINE_PROCHAINE'), value: 'semaine_prochaine' },
		{ key: t('DATE_MOIS_PROCHAIN'), value: 'mois_prochain' },
		{ key: t('DATE_6_MOIS'), value: '6_mois' },
		{ key: t('DATE_1_AN'), value: '1_an' }
	]
}
---

<Layout title={t('ART_VIVANT')}>
	<main id="main-content">
		{/* HERO */}
		<section
			class="relative grid h-[calc(100dvh-var(--header-height)+var(--header-overlap))] max-h-225 grid-cols-40 grid-rows-40 gap-2 bg-[#345f6e] p-1.5 pt-11.5 *:rounded-lg sm:gap-2.5 sm:p-3.5 sm:pt-16 md:gap-3.5 lg:rounded-b-3xl"
		>
			<div class="bg-cream relative col-span-24 col-start-1 row-span-17 row-start-1 overflow-hidden lg:p-5">
				<img
					src={LayoutHome1.src}
					alt=""
					loading="eager"
					class="absolute inset-0 h-full w-full object-cover lg:hidden"
				/>
				<div class="bg-cream/80 absolute inset-0 lg:hidden"></div>
				<div class="hidden lg:block">
					<h2 class="pb-2 text-2xl lg:pb-3">{t('ART_VIVANT_HERO_TITRE')}</h2>
					<p class="distinguished pb-3 lg:pb-8">{t('SPECTACLES_INTRO')}</p>
					<p class="text-sm">
						{t('ART_VIVANT_DESC_PART1')}
						<br /><br />
						{t('ART_VIVANT_DESC_PART2')}
					</p>
				</div>
			</div>
			<div class="bg-cream relative col-span-16 col-start-25 row-start-1 row-end-24 overflow-hidden md:row-end-21">
				<img
					src={LayoutHome3.src}
					alt=""
					loading="eager"
					fetchpriority="high"
					class="h-full w-full rounded-lg object-cover"
				/>
			</div>
			<div class="bg-cream relative col-span-13 col-start-1 row-span-23 row-start-18 overflow-hidden">
				<img src={LayoutHome4.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
			</div>
			<div
				class="relative hidden overflow-hidden bg-[#be7a5a] md:col-span-13 md:col-start-14 md:row-span-17 md:row-start-24 md:block"
			>
				<img src={LayoutHome5.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
			</div>
			<div
				class="bg-cream relative col-span-27 col-start-14 row-start-24 row-end-41 flex flex-col gap-3 overflow-hidden p-3 md:col-span-14 md:col-start-27 md:row-start-21 md:gap-7 lg:p-5"
			>
				{
					immanquables.length > 0 && (
						<>
							<h2 class="text-center text-xl! md:text-right">{t('LES_IMMANQUABLES')}</h2>
							{immanquables.length === 1 ? (
								<a
									href={getImmanquableUrl(immanquables[0])}
									aria-label={immanquables[0].title}
									class="shadow-card relative block flex-1 overflow-hidden rounded-3xl border border-foreground"
								>
									<img
										src={getImmanquableImage(immanquables[0]).src}
										alt={getImmanquableImage(immanquables[0]).alt}
										loading="eager"
										class="h-full w-full object-cover"
									/>
								</a>
							) : (
								<HoverImageSwap
									client:visible
									direction="horizontal"
									className="flex-1 min-h-0"
									rows={[
										{
											slots: immanquables.map((item, i) => {
												const img = getImmanquableImage(item)
												return {
													src: img.src,
													alt: img.alt || item.title,
													href: getImmanquableUrl(item),
													...(item.immanquable === 'coup_de_coeur' && { badge: t('COUP_DE_COEUR') }),
													...(item.immanquable === 'cine_passion' && { badge: 'Cine passion' }),
													...(i > 0 && {
														barClassName: ['bg-secondary', 'bg-secondary-muted', 'bg-primary'][(i - 1) % 3]
													})
												}
											}),
											defaultIndex: 0,
											height: 'h-full',
											width: 'w-full',
											cardStyle: true,
											compactPills: true
										}
									]}
								/>
							)}
						</>
					)
				}
			</div>
			<div
				class="bg-cream z-40 col-span-17 col-start-12 row-span-6 row-start-18 flex translate-x-[0.2rem] items-center justify-center overflow-hidden p-2 outline-8 outline-[#345f6e] sm:outline-10 md:outline-14"
			>
				<h1
					class="text-primary text-center text-2xl! leading-8 font-medium! break-words sm:text-3xl! sm:leading-10 lg:text-[42px]! lg:leading-14"
				>
					{t('ART_VIVANT')}
				</h1>
			</div>
		</section>

		<section class="section-default lg:hidden">
			<article>
				<h2 class="pb-2 lg:pb-3">{t('ART_VIVANT_HERO_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-16">{t('SPECTACLES_INTRO')}</p>
				<p class="pb-2 lg:w-2/3">{t('ART_VIVANT_DESC_PART1')}</p>
				<p class="lg:w-2/3">{t('ART_VIVANT_DESC_PART2')}</p>
			</article>
		</section>

		{/* SPECTACLES À VENIR */}
		{
			spectacles.docs.length > 0 && (
				<section class="section-default" id="spectacles">
					<article>
						<h2 class="pb-2 lg:pb-3">{t('SPECTACLES_A_VENIR')}</h2>
						<p class="distinguished pb-3 lg:pb-16">{t('SPECTACLES_INTRO')}</p>
						<p class="pb-2 lg:w-2/3">{t('SPECTACLES_DESC_PART1')}</p>
						<p class="lg:w-2/3">{t('SPECTACLES_DESC_PART2')}</p>
					</article>

					<SpectaclesGrid
						client:load
						initialData={spectacles}
						locale={locale}
						localePrefix={localePrefix}
						limit={SPECTACLES_LIMIT}
						payloadUrl={PAYLOAD_URL}
						collection="art_vivant"
						showFilters={false}
						translations={spectacleTranslations}
					/>
				</section>
			)
		}

		{/* RÉSIDENCE ARTISTIQUE */}
		{
			residences.docs.length > 0 && (
				<section class="section-default bg-primary" id="residence">
					<article class="grid grid-cols-1 gap-6 pb-12 lg:grid-cols-12 lg:gap-8">
						<div class="flex flex-col lg:col-span-7">
							<h2 class="text-foreground pb-2 lg:pb-3">{t('RESIDENCE_ARTISTIQUE')}</h2>
							<p class="distinguished pb-3 lg:pb-16">{t('RESIDENCE_INTRO')}</p>
							<p class="pb-4">{t('RESIDENCE_DESC_PART1')}</p>
							<p>{t('RESIDENCE_DESC_PART2')}</p>
						</div>
						<div class="flex flex-col gap-4 lg:col-span-5 lg:gap-5">
							<HoverImageSwap
								client:visible
								direction="horizontal"
								rows={[
									{
										slots: [
											{ src: FirstMediaImg.src, alt: '' },
											{ src: SecondMediaImg.src, alt: '', barClassName: 'bg-secondary-muted' },
											{ src: ThirdMediaImg.src, alt: '', barClassName: 'bg-foreground' }
										],
										defaultIndex: 0,
										height: 'h-[222px]',
										width: 'w-full'
									}
								]}
							/>
							<div class="h-[160px] overflow-hidden rounded-2xl">
								<MyImage
									src={FourthMediaImg}
									alt=""
									width={420}
									height={160}
									layout="fullWidth"
									class="h-full w-full object-cover"
								/>
							</div>
						</div>
					</article>

					<div class="grid grid-cols-[repeat(auto-fit,320px)] content-start justify-center gap-x-4 gap-y-8 *:only:col-span-full lg:justify-between">
						{residences.docs.map((item) => {
							const descText = item.description.root.children
								.flatMap((para) => para.children)
								.filter((child) => child.type === 'text')
								.map((child) => child.text)
								.join(' ')

							return (
								<SpectacleCard
									title={item.title}
									href={`${localePrefix}/art-vivant/residence/${item.id}`}
									locale={locale}
									description={descText}
									dateStart={item.date_start}
									genre={item.genre ?? ''}
									ctaLabel={t('EN_SAVOIR_PLUS')}
									imageSrc={item.thumbnail?.url}
									imageAlt={item.thumbnail?.alt}
									imageBlurhash={item.thumbnail?.blurhash}
									width="w-[320px]"
								/>
							)
						})}
					</div>
				</section>
			)
		}
	</main>
</Layout>
