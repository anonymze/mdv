---
export const prerender = true
export const getStaticPaths = () => [
	{ params: { lang: 'fr' } },
	{ params: { lang: 'en' } },
	{ params: { lang: 'es' } }
]
import { find } from '@/api/payload'
import FirstMediaImg from '@/assets/imgs/parc/1.webp'
import SecondMediaImg from '@/assets/imgs/parc/2.webp'
import ThirdMediaImg from '@/assets/imgs/parc/3.webp'
import FourthMediaImg from '@/assets/imgs/parc/4.webp'
import { ArticleGrid } from '@/components/article-grid'
import MyImage from '@/components/my-image.astro'
import { SpectaclesGrid } from '@/components/spectacles-grid'
import { Button } from '@/components/ui/button'
import { createTranslator, I18n } from '@/i18n/translations'
import Layout from '@/layouts/layout.astro'
import type { ParcNational } from '@/types/parc-national'
import { getRelativeLocaleUrl } from 'astro:i18n'
const locale = (Astro.params.lang || 'fr') as I18n
import LayoutHome1 from '@/assets/imgs/layout_home/1.png'
import LayoutHome2 from '@/assets/imgs/layout_home/2.png'
import LayoutHome3 from '@/assets/imgs/layout_home/3.png'
import LayoutHome4 from '@/assets/imgs/layout_home/4.png'
import LayoutHome5 from '@/assets/imgs/layout_home/5.png'
import LayoutHome6 from '@/assets/imgs/layout_home/6.png'
const t = createTranslator(locale)
const localePrefix = getRelativeLocaleUrl(locale, '').replace(/\/$/, '')

const EVENEMENTS_LIMIT = 4

const evenements = await find<ParcNational>('parc_national', {
	limit: EVENEMENTS_LIMIT,
	page: 1,
	locale,
	where: { type: { equals: 'evenement' } }
})

const ARTICLES_LIMIT = 6

const articles = await find<ParcNational>('parc_national', {
	limit: ARTICLES_LIMIT,
	page: 1,
	locale,
	upcomingOnly: false,
	where: {
		type: { equals: 'article' }
	}
})

const evenementsTranslations = {
	PRECEDENT: t('PRECEDENT'),
	SUIVANT: t('SUIVANT'),
	IMAGE_PLACEHOLDER: t('IMAGE_PLACEHOLDER'),
	EN_SAVOIR_PLUS: t('EN_SAVOIR_PLUS'),
	AUCUN_CONTENU: t('AUCUN_CONTENU')
}

const articlesTranslations = {
	PRECEDENT: t('PRECEDENT'),
	SUIVANT: t('SUIVANT'),
	IMAGE_PLACEHOLDER: t('IMAGE_PLACEHOLDER'),
	AUCUN_CONTENU: t('AUCUN_CONTENU')
}

const PAYLOAD_URL = import.meta.env.PUBLIC_PAYLOAD_URL
---

<Layout title={t('PARC_NATIONAL')}>
	<main id="main-content">

	<section
		class="relative grid h-[calc(100dvh-var(--header-height)+var(--header-overlap))] max-h-225 grid-cols-40 grid-rows-40 gap-2 sm:gap-2.5 md:gap-3.5 bg-[#345f6e] p-1.5 sm:p-3.5 pt-11.5 sm:pt-16 *:rounded-lg lg:rounded-b-3xl"
	>
		<div class="bg-cream relative col-span-24 col-start-1 row-span-17 row-start-1 overflow-hidden lg:p-5">
			<img src={LayoutHome1.src} alt="" loading="eager" class="absolute inset-0 h-full w-full object-cover lg:hidden" />
			<div class="bg-cream/80 absolute inset-0 lg:hidden"></div>
			<div class="hidden lg:block">
				<h2 class="pb-2 text-2xl lg:pb-3">{t('PARC_NATIONAL_INTRO')}</h2>
				<p class="distinguished pb-3 lg:pb-6">{t('PARC_NATIONAL_HERO_SUB')}</p>
				<p class="text-sm">
					{t('PARC_NATIONAL_HERO_DESC_PART1')}
					<br /><br />
					{t('PARC_NATIONAL_HERO_DESC_PART2')}
					<br /><br />
					{t('PARC_NATIONAL_HERO_DESC_PART3')}
				</p>
			</div>
		</div>
		<div class="bg-cream relative col-span-16 col-start-25 row-start-1 row-end-24 overflow-hidden md:row-end-21">
			<img src={LayoutHome3.src} alt="" loading="eager" fetchpriority="high" class="h-full w-full rounded-lg object-cover" />
		</div>
		<div class="bg-cream relative col-span-13 col-start-1 row-span-23 row-start-18 overflow-hidden">
			<img src={LayoutHome4.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
		</div>
		<div class="relative hidden overflow-hidden bg-[#be7a5a] md:col-span-13 md:col-start-14 md:row-span-17 md:row-start-24 md:block">
			<img src={LayoutHome5.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
		</div>
		<div class="relative col-span-27 col-start-14 row-start-24 row-end-41 flex flex-col items-center justify-end gap-3 overflow-hidden p-3 md:col-span-14 md:col-start-27 md:row-start-21 md:gap-7 lg:p-5">
			<img src={FirstMediaImg.src} alt="" loading="eager" class="absolute inset-0 h-full w-full object-cover" />
			<div class="bg-white/80 absolute inset-0"></div>
			<Button link="https://www.pyrenees-parcnational.fr" openInNewTab size={'xl'} className="relative w-full !h-auto !whitespace-normal py-3 text-center">{t('PARC_NATIONAL_SITE_OFFICIEL')}</Button>
		</div>
		<div class="bg-cream z-40 col-span-17 col-start-12 row-span-6 row-start-18 flex translate-x-[0.2rem] items-center justify-center overflow-hidden p-2 outline-8 outline-[#345f6e] sm:outline-10 md:outline-14">
			<h1 class="text-primary text-center text-xl! leading-7 sm:text-2xl! sm:leading-8 md:text-4xl! md:leading-12 lg:text-[40px]! lg:leading-12 font-medium! break-words">
				{t('PARC_NATIONAL_TITRE')}
			</h1>
		</div>
	</section>

	<section class="section-default lg:hidden">
		<article>
			<h2 class="pb-2 lg:pb-3">{t('PARC_NATIONAL_INTRO')}</h2>
			<p class="distinguished pb-3 lg:pb-16">{t('PARC_NATIONAL_HERO_SUB')}</p>
			<p class="pb-2 lg:w-2/3">{t('PARC_NATIONAL_HERO_DESC_PART1')}</p>
			<p class="pb-2 lg:w-2/3">{t('PARC_NATIONAL_HERO_DESC_PART2')}</p>
			<p class="lg:w-2/3">{t('PARC_NATIONAL_HERO_DESC_PART3')}</p>
		</article>
	</section>

		{evenements.docs.length > 0 && (
		<section class="section-default" id="evenements">
			<h2 class="text-primary pb-2 lg:pb-3">{t('PARC_EVENEMENTS_TITRE')}</h2>
			<p class="distinguished pb-3 lg:pb-16">{t('PARC_EVENEMENTS_INTRO')}</p>
			<p class="lg:w-2/3">
				{t('PARC_EVENEMENTS_DESC')}
			</p>

			<SpectaclesGrid
				client:load
				initialData={evenements}
				locale={locale}
				localePrefix={localePrefix}
				limit={EVENEMENTS_LIMIT}
				payloadUrl={PAYLOAD_URL}
				collection="parc_national"
				showFilters={false}
				mobileScrollOnly={true}
				translations={evenementsTranslations}
			/>
		</section>
		)}

		{articles.docs.length > 0 && (
		<section class="section-default bg-primary" id="articles">
			<h2 class="pb-2 lg:pb-3">{t('PARC_ARTICLES_TITRE')}</h2>
			<p class="distinguished pb-3 lg:pb-16">{t('PARC_ARTICLES_INTRO')}</p>
			<p class="lg:w-2/3">
				{t('PARC_ARTICLES_DESC')}
			</p>

			<ArticleGrid
				client:load
				initialData={articles}
				locale={locale}
				limit={ARTICLES_LIMIT}
				payloadUrl={PAYLOAD_URL}
				translations={articlesTranslations}
			/>
		</section>
		)}
	</main>
</Layout>
