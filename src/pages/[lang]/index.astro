---
export const prerender = true
export const getStaticPaths = () => [
	{ params: { lang: 'fr' } },
	{ params: { lang: 'en' } },
	{ params: { lang: 'es' } }
]
import { find } from '@/api/payload'

import FirstImg from '@/assets/imgs/home/1.webp'
import TenthImg from '@/assets/imgs/home/10.webp'
import EleventhImg from '@/assets/imgs/home/11.webp'
import NewsletterImg from '@/assets/imgs/newsletter.webp'
import SecondImg from '@/assets/imgs/home/2.webp'
import ThirdImg from '@/assets/imgs/home/3.webp'
import FourthImg from '@/assets/imgs/home/4.webp'
import FifthImg from '@/assets/imgs/home/5.webp'
import SixthImg from '@/assets/imgs/home/6.webp'
import SeventhImg from '@/assets/imgs/home/7.webp'
import EighthImg from '@/assets/imgs/home/8.webp'
import NinthImg from '@/assets/imgs/home/9.webp'
import ThirtyFourthImg from '@/assets/imgs/home/34.webp'
import ThirtyFiveImg from '@/assets/imgs/home/35.webp'
import ThirtySixImg from '@/assets/imgs/home/36.webp'
import ThirtySevenImg from '@/assets/imgs/home/37.webp'
import LayoutHome1 from '@/assets/imgs/layout_home/1.webp'
import LayoutHome2 from '@/assets/imgs/layout_home/2.webp'
import LayoutHome3 from '@/assets/imgs/layout_home/3.webp'
import LayoutHome4 from '@/assets/imgs/layout_home/4.webp'
import LayoutHome5 from '@/assets/imgs/layout_home/5.webp'
import LayoutHome6 from '@/assets/imgs/layout_home/6.webp'
import { HoverImageSwap } from '@/components/hover-image-swap'
import MyImage from '@/components/my-image.astro'
import { NewsletterForm } from '@/components/newsletter-form'
import SpectacleCard from '@/components/spectacle-card.astro'
import { Button } from '@/components/ui/button'
import { createTranslator, I18n } from '@/i18n/translations'
import Layout from '@/layouts/layout.astro'
import { translatePublicField } from '@/lib/translate-fields'
import type { ArtVivant } from '@/types/art-vivant'
import type { Cinema } from '@/types/cinema'
import type { ExpositionType } from '@/types/exposition'
import { renderRichText, TELEPHONE_DEFAULT } from '@/utils/helper'
import { getRelativeLocaleUrl } from 'astro:i18n'

const locale = (Astro.params.lang || 'fr') as I18n
const t = createTranslator(locale)

const spectacles = await find<ArtVivant>('art_vivant', {
	limit: 3,
	locale,
	where: { type: { equals: 'evenement' } }
})

const seances = await find<Cinema>('cinema', {
	limit: 4,
	locale,
	where: {
		type: { equals: 'seance' }
	}
})

const exposition = (await find<ExpositionType>('exposition/current', {
	locale
})) as unknown as ExpositionType | null

const expoImages =
	exposition?.images
		?.slice(0, 4)
		.map((i) => i.image)
		.filter((img): img is NonNullable<typeof img> => Boolean(img?.url)) ?? []

const PAYLOAD_URL = import.meta.env.PUBLIC_PAYLOAD_URL

const buildExpoRows = () => {
	const toSlot = (img: (typeof expoImages)[number], asBar = false) => ({
		src: `${PAYLOAD_URL}${img.url}`,
		alt: img.alt ?? '',
		...(asBar && { barClassName: 'bg-primary' })
	})

	if (expoImages.length === 1) {
		return [{ slots: [toSlot(expoImages[0])], height: 'h-96' }]
	}
	if (expoImages.length === 2) {
		return [
			{ slots: [toSlot(expoImages[0])], height: 'h-48' },
			{ slots: [toSlot(expoImages[1])], height: 'h-72' }
		]
	}
	if (expoImages.length === 3) {
		return [
			{ slots: [toSlot(expoImages[0])], height: 'h-48' },
			{
				slots: [toSlot(expoImages[1]), toSlot(expoImages[2], true)],
				defaultIndex: 0,
				height: 'h-72'
			}
		]
	}
	return [
		{ slots: [toSlot(expoImages[0])], height: 'h-48' },
		{
			slots: [toSlot(expoImages[1]), toSlot(expoImages[2], true), toSlot(expoImages[3], true)],
			defaultIndex: 0,
			height: 'h-72'
		}
	]
}

const expoRows = buildExpoRows()

// JSON-LD structured data
const SITE_URL = Astro.site?.href.replace(/\/$/, '') ?? 'https://www.maisondelavallee.org'

const venueAddress = {
	'@type': 'PostalAddress',
	streetAddress: '24 Place Saint-Clément',
	postalCode: '65120',
	addressLocality: 'Luz-Saint-Sauveur',
	addressRegion: 'Hautes-Pyrénées',
	addressCountry: 'FR'
}

const venueLocation = {
	'@type': 'Place',
	name: 'Maison du Parc national et de la vallée',
	address: venueAddress
}

const venueSchema = {
	'@type': 'PerformingArtsTheater',
	'@id': `${SITE_URL}/#venue`,
	name: 'Maison du Parc national et de la vallée',
	url: SITE_URL,
	telephone: TELEPHONE_DEFAULT,
	address: venueAddress,
	geo: {
		'@type': 'GeoCoordinates',
		latitude: 42.8722,
		longitude: -0.0033
	}
}

const eventSchemas = [
	...spectacles.docs.map((item) => ({
		'@type': 'TheaterEvent',
		name: item.title,
		startDate: item.date_start,
		eventStatus: 'https://schema.org/EventScheduled',
		eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
		location: venueLocation,
		url: `${SITE_URL}${getRelativeLocaleUrl(locale, `art-vivant/spectacle/${item.id}`)}`,
		organizer: { '@id': `${SITE_URL}/#venue` }
	})),
	...seances.docs.map((item) => ({
		'@type': 'ScreeningEvent',
		name: item.title,
		startDate: item.date_start,
		eventStatus: 'https://schema.org/EventScheduled',
		eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
		location: venueLocation,
		url: `${SITE_URL}${getRelativeLocaleUrl(locale, `cinema/seance/${item.id}`)}`,
		organizer: { '@id': `${SITE_URL}/#venue` }
	})),
	...(exposition
		? [
				{
					'@type': 'ExhibitionEvent',
					name: exposition.title,
					startDate: exposition.date_start,
					endDate: exposition.date_end,
					eventStatus: 'https://schema.org/EventScheduled',
					eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
					location: venueLocation,
					url: `${SITE_URL}${getRelativeLocaleUrl(locale, 'exposition')}`,
					organizer: { '@id': `${SITE_URL}/#venue` }
				}
			]
		: [])
]

const jsonLd = {
	'@context': 'https://schema.org',
	'@graph': [venueSchema, ...eventSchemas]
}
---

<Layout title={t('ACCUEIL_TITLE')}>
	<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
	<main id="main-content">
		<section
			class="relative grid h-[calc(100dvh-var(--header-height)+var(--header-overlap))] max-h-225 grid-cols-40 grid-rows-40 gap-2 sm:gap-2.5 md:gap-3.5 bg-[#345f6e] p-1.5 sm:p-3.5 pt-11.5 sm:pt-16 *:rounded-lg lg:rounded-b-3xl"
		>
			<a
				href={getRelativeLocaleUrl(locale, 'art-vivant')}
				aria-label={t('ART_VIVANT')}
				class="group relative col-span-10 col-start-1 row-span-18 row-start-1 block overflow-hidden bg-[#be7a5a]"
			>
				<img src={LayoutHome1.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
				<div
					class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#be7a5a]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
				>
					<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('ART_VIVANT')}</h2>
					<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
						>{t('HERO_TILE_ART_VIVANT_SUB')}</span
					>
				</div>
			</a>
			<a
				href={getRelativeLocaleUrl(locale, 'cinema')}
				aria-label={t('CINEMA')}
				class="group relative col-span-11 col-start-11 row-span-16 row-start-1 block overflow-hidden bg-[#e5aa7f]"
			>
				<img src={LayoutHome2.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
				<div
					class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#e5aa7f]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
				>
					<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('CINEMA')}</h2>
					<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
						>{t('HERO_TILE_CINEMA_SUB')}</span
					>
				</div>
			</a>
			<a
				href={getRelativeLocaleUrl(locale, 'exposition')}
				aria-label={t('EXPOSITION')}
				class="group relative col-span-19 col-start-22 row-span-20 row-start-1 block overflow-hidden bg-[#f4ede1]"
			>
				<img
					src={LayoutHome3.src}
					alt=""
					loading="eager"
					fetchpriority="high"
					class="h-full w-full rounded-lg object-cover"
				/>
				<div
					class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#f4ede1]/90 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
				>
					<h2 class="text-foreground font-serif text-3xl lg:text-5xl">{t('EXPOSITION')}</h2>
					<span class="text-foreground max-w-40 pt-1 font-sans text-sm font-medium lg:pt-2 lg:text-lg"
						>{t('HERO_TILE_EXPOSITION_SUB')}</span
					>
				</div>
			</a>
			<a
				href={getRelativeLocaleUrl(locale, 'artiste')}
				aria-label={t('ARTISTE')}
				class="group relative col-span-13 col-start-1 row-span-22 row-start-19 block overflow-hidden bg-[#f4ede1]"
			>
				<img src={LayoutHome4.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
				<div
					class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#f4ede1]/90 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
				>
					<h2 class="text-foreground font-serif text-3xl lg:text-5xl">{t('ARTISTE')}</h2>
					<span class="text-foreground max-w-40 pt-1 font-sans text-sm font-medium lg:pt-2 lg:text-lg"
						>{t('HERO_TILE_ARTISTE_SUB')}</span
					>
				</div>
			</a>
			<a
				href={getRelativeLocaleUrl(locale, 'jeune-public')}
				aria-label={t('JEUNESSE')}
				class="group relative col-span-14 col-start-14 row-span-16 row-start-25 block overflow-hidden bg-[#be7a5a]"
			>
				<img src={LayoutHome5.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
				<div
					class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#be7a5a]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
				>
					<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('JEUNESSE')}</h2>
					<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
						>{t('HERO_TILE_JEUNESSE_SUB')}</span
					>
				</div>
			</a>
			<a
				href={getRelativeLocaleUrl(locale, 'mediatheque')}
				aria-label={t('MEDIATHEQUE')}
				class="group relative col-span-13 col-start-28 row-span-20 row-start-21 block overflow-hidden bg-[#e5aa7f]"
			>
				<img src={LayoutHome6.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
				<div
					class="absolute inset-0 z-30 flex flex-col items-center justify-center rounded-lg bg-[#e5aa7f]/85 p-3 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 lg:p-6"
				>
					<h2 class="font-serif text-3xl text-white lg:text-5xl">{t('MEDIATHEQUE')}</h2>
					<span class="max-w-40 pt-1 font-sans text-sm font-medium text-white lg:pt-2 lg:text-lg"
						>{t('HERO_TILE_MEDIATHEQUE_SUB')}</span
					>
				</div>
			</a>
			<div
				class="z-40 col-span-27 col-start-7 md:col-span-25 md:col-start-8 row-span-10 row-start-16 min-[765px]:row-span-8 min-[765px]:row-start-17 flex translate-x-[0.2rem] items-center justify-center overflow-hidden bg-cream p-2 outline-8 sm:outline-10 md:outline-14 outline-[#345f6e]"
			>
				<h1 class="text-primary text-center text-2xl! leading-8 sm:text-3xl! sm:leading-10 font-medium! break-words lg:leading-12 lg:text-[42px]!">
					Maison du Parc national<br /> et de la vallée &middot; Luz
				</h1>
			</div>
		</section>


		<section class="section-default">
			<article class="grid grid-cols-1 gap-4 lg:flex">
				<div class="lg:w-2/3">
					<h2 class="pb-2 lg:pb-3">{t('ESPACE_CULTURE_TITRE')}</h2>
					<p class="distinguished pb-3 lg:pb-12">{t('ESPACE_CULTURE_INTRO')}</p>
					<p>
						{t('ESPACE_CULTURE_DESC_PART1')}<br /><br />
						{t('ESPACE_CULTURE_DESC_PART2')}<br /><br />
						{t('ESPACE_CULTURE_DESC_PART3')}<br /><br />
						{t('ESPACE_CULTURE_DESC_PART4')}<br /><br />
						{t('ESPACE_CULTURE_DESC_PART5')}
					</p>

					<Button
						link={`${getRelativeLocaleUrl(locale, 'parc-national')}#evenements`}
						className="mt-10 mb-4 h-10 px-6 lg:mb-0 lg:h-12 lg:px-8">{t('DECOUVREZ_PROCHAINS_EVENEMENTS')}</Button
					>
				</div>
				<HoverImageSwap
					client:visible
					className="lg:w-1/3"
					rows={[
						{
							slots: [
								{ src: FirstImg.src, alt: '', barClassName: 'bg-foreground' },
								{ src: SecondImg.src, alt: '', barClassName: 'bg-foreground' }
							],
							defaultIndex: 0,
							height: 'h-48'
						},
						{
							slots: [{ src: ThirdImg.src, alt: '' }],
							height: 'h-64'
						},
						{
							slots: [
								{ src: FourthImg.src, alt: '', barClassName: 'bg-secondary' },
								{ src: FifthImg.src, alt: '', barClassName: 'bg-secondary-muted' },
								{ src: ThirtyFourthImg.src, alt: '', barClassName: 'bg-secondary' }
							],
							defaultIndex: 2,
							height: 'h-48'
						}
					]}
				/>
			</article>
		</section>

		<section class="section-default bg-primary">
			<article class="grid grid-cols-5 gap-5">
				<div class="col-span-5 mb-5 lg:col-span-3 lg:mb-0">
					<h2 class="pb-2 lg:pb-3">{t('SPECTACLES_A_VENIR')}</h2>
					<p class="distinguished pb-3 lg:pb-12">{t('SPECTACLES_INTRO')}</p>
					<p>
						{t('SPECTACLES_DESC_PART1')}<br />
						{t('SPECTACLES_DESC_PART2')}
					</p>
				</div>
				<HoverImageSwap
					client:visible
					direction="vertical"
					className="col-span-5 h-100 lg:col-span-2"
					rows={[
						{
							slots: [{ src: EighthImg.src, alt: '' }],
							width: 'w-3/5',
							height: 'h-full'
						},
						{
							slots: [
								{ src: SeventhImg.src, alt: '' },
								{ src: SixthImg.src, alt: '', barClassName: 'bg-white' },
								{ src: ThirtyFiveImg.src, alt: '', barClassName: 'bg-secondary' }
							],
							defaultIndex: 0,
							width: 'w-2/5',
							height: 'h-full'
						}
					]}
				/>
			</article>
			<div
				class="my-16 grid grid-cols-[repeat(auto-fit,320px)] justify-center lg:justify-between content-start gap-x-4 gap-y-8 *:only:col-span-full"
			>
				{
					spectacles.docs.map((item, index) => {
						const descText = item.description.root.children
							.flatMap((para) => para.children)
							.filter((child) => child.type === 'text')
							.map((child) => child.text)
							.join(' ')

						return (
							<SpectacleCard
								title={item.title}
								href={getRelativeLocaleUrl(locale, `art-vivant/spectacle/${item.id}`)}
								locale={locale}
								description={descText}
								dateStart={item.date_start}
								genre={item.genre ?? ''}
								ctaLabel={t('VOIR_LA_REPRESENTATION')}
								imageSrc={item.thumbnail?.url}
								imageAlt={item.thumbnail?.alt}
								imageBlurhash={item.thumbnail?.blurhash}
								width="w-[320px]"
								class={index >= 2 ? 'max-md:hidden' : undefined}
							/>
						)
					})
				}
			</div>

			<Button link={`${getRelativeLocaleUrl(locale, 'art-vivant')}#spectacles`} size={'xl'}
				>{t('VOIR_TOUS_SPECTACLES')}</Button
			>
		</section>

		{
			seances.docs.length > 0 && (
				<section>
					<div class="section-default">
						<div class="flex flex-col gap-5 lg:flex-row lg:gap-5">
							<div class="flex flex-col gap-8 lg:w-2/3">
								<div class="mb-6 pr-4">
									<h2 class="pb-2 lg:pb-3">{t('SEANCES_A_VENIR')}</h2>
									<p class="distinguished pb-3 lg:pb-12">{t('CINEMA_INTRO')}</p>
									<p>{t('CINEMA_DESC_PART1')}</p>
								</div>
								<MyImage src={TenthImg} alt="" width={1200} height={205} layout="fullWidth" />
							</div>
							<HoverImageSwap
								client:visible
								direction="vertical"
								className="lg:w-1/3"
								rows={[
									{
										slots: [
											{ src: NinthImg.src, alt: '', barClassName: 'bg-primary' },
											{ src: ThirtySixImg.src, alt: '', barClassName: 'bg-foreground' },
											{ src: EleventhImg.src, alt: '', barClassName: 'bg-secondary-muted' },
											{ src: ThirtySevenImg.src, alt: '', barClassName: 'bg-secondary' }
										],
										defaultIndex: 1,
										height: 'h-[455px]'
									}
								]}
							/>
						</div>

						<div class="my-8 grid grid-cols-1 gap-3 lg:my-16 lg:grid-cols-2 lg:gap-5">
							{seances.docs.map((item, index, arr) => {
								const synopsisText = item.synopsis.root.children
									.flatMap((para) => para.children)
									.filter((child) => child.type === 'text')
									.map((child) => child.text)
									.join(' ')

								const isLoneOnRow = index === arr.length - 1 && arr.length % 2 === 1
								const cardClass = [isLoneOnRow && 'lg:col-span-2', index >= 2 && 'max-md:hidden']
									.filter(Boolean)
									.join(' ')

								return (
									<SpectacleCard
										title={item.title}
										href={getRelativeLocaleUrl(locale, `cinema/seance/${item.id}`)}
										locale={locale}
										description={synopsisText}
										dateStart={item.date_start}
										genre={`${translatePublicField(item.public, t)} - ${item.genre} - ${item.languages}`}
										ctaLabel={t('EN_SAVOIR_PLUS')}
										imageSrc={item.thumbnail?.url}
										imageAlt={item.thumbnail?.alt}
										imageBlurhash={item.thumbnail?.blurhash}
										height="h-[300px]"
										class={cardClass || undefined}
									/>
								)
							})}
						</div>
						<Button link={`${getRelativeLocaleUrl(locale, 'cinema')}#cinema`} size={'xl'} className="mt-6 lg:mt-12">
							{t('VOIR_TOUTES_SEANCES')}
						</Button>
					</div>
				</section>
			)
		}

		{
			exposition && (
				<section class="section-default">
					<article class="grid grid-cols-1 gap-5 lg:grid-cols-2">
						<div class="flex flex-col">
							<h2 class="pb-2 lg:pb-3">{t('EXPO_MOMENT_TITRE')}</h2>
							<p class="distinguished pb-3 lg:pb-12">{exposition.title}</p>
							<p set:html={renderRichText(exposition.description)} />

							<div class="mb-5 pt-12 lg:mt-auto">
								<Button link={`${getRelativeLocaleUrl(locale, 'exposition')}#exposition`} size={'xl'} className="w-fit">
									{t('EN_SAVOIR_PLUS')}
								</Button>
							</div>
						</div>
						{expoRows.length > 0 && <HoverImageSwap client:visible rows={expoRows} />}
					</article>
				</section>
			)
		}

		<section class="section-default mx-auto w-[335px] px-0 sm:w-[358px] lg:w-auto lg:px-8">
				<article class="bg-primary flex w-full flex-col-reverse rounded-4xl lg:flex-row">
				<div
					class="relative h-[301px] w-full shrink-0 overflow-hidden rounded-b-4xl sm:w-[358px] lg:h-[349.5px] lg:w-[378px] lg:overflow-visible lg:rounded-none"
				>
					<div
						class="absolute -inset-[29px] z-1 lg:inset-auto lg:right-0 lg:bottom-0 lg:h-[calc(100%+28px)] lg:w-[calc(100%+28px)]"
					>
						<MyImage
							alt=""
							src={NewsletterImg}
							width={420}
							height={400}
							layout="constrained"
							class="h-full! w-full! rounded-none object-cover object-left-top lg:object-center"
						/>
					</div>
				</div>
				<div class="mb-8 flex flex-col justify-center p-4 lg:mb-0 lg:p-8">
					<h2 class="pb-3 text-white!">{t('NEWSLETTER_TITRE')}</h2>
					<p class="pb-8 text-base font-medium text-white">{t('NEWSLETTER_INTRO')}</p>
					<p class="pb-8 text-sm text-white">{t('NEWSLETTER_DESC')}</p>

					<NewsletterForm
						client:load
						locale={locale}
						variant="default"
						apiBaseUrl={import.meta.env.PUBLIC_PAYLOAD_URL}
					/>
				</div>
