---
export const prerender = true
export const getStaticPaths = () => [
	{ params: { lang: 'fr' } },
	{ params: { lang: 'en' } },
	{ params: { lang: 'es' } }
]
import { find } from '@/api/payload'
import FirstMediaImg from '@/assets/imgs/cinema/1.webp'
import SecondMediaImg from '@/assets/imgs/cinema/2.webp'
import ThirdMediaImg from '@/assets/imgs/cinema/3.webp'
import FourthMediaImg from '@/assets/imgs/cinema/4.webp'
import AdrcLogo from '@/assets/imgs/cinema/ADRC.webp'
import AfcaeLogo from '@/assets/imgs/cinema/AFCAE.webp'
import CinephilaeLogo from '@/assets/imgs/cinema/cinephile.webp'
import VeoLogo from '@/assets/imgs/cinema/veo.webp'
import LayoutHome1 from '@/assets/imgs/layout_cinema/1.webp'
import LayoutHome2 from '@/assets/imgs/layout_cinema/1.webp'
import LayoutHome3 from '@/assets/imgs/layout_cinema/2.webp'
import LayoutHome4 from '@/assets/imgs/layout_cinema/3.webp'
import LayoutHome5 from '@/assets/imgs/layout_cinema/1.webp'
import LayoutHome6 from '@/assets/imgs/layout_cinema/1.webp'
import { CinemaGrid } from '@/components/cinema-grid'
import { HoverImageSwap } from '@/components/hover-image-swap'
import MyImage from '@/components/my-image.astro'
import SpectacleCard from '@/components/spectacle-card.astro'
import { createTranslator, I18n } from '@/i18n/translations'
import Layout from '@/layouts/layout.astro'
import type { Cinema } from '@/types/cinema'
import type { ImmanquableDoc } from '@/types/immanquable'
import { getRelativeLocaleUrl } from 'astro:i18n'
const locale = (Astro.params.lang || 'fr') as I18n
const t = createTranslator(locale)
const localePrefix = getRelativeLocaleUrl(locale, '').replace(/\/$/, '')

const SEANCES_LIMIT = 6

const seances = await find<Cinema>('cinema', {
	limit: SEANCES_LIMIT,
	page: 1,
	locale,
	where: {
		type: { equals: 'seance' }
	}
})

const rdv = await find<Cinema>('cinema', {
	limit: 4,
	locale,
	where: {
		type: { equals: 'rdv_cinema' }
	}
})

const SCOLAIRE_LIMIT = 6
const scolaire = await find<Cinema>('cinema', {
	limit: SCOLAIRE_LIMIT,
	locale,
	where: {
		type: { equals: 'scolaire' }
	}
})
const cinemaTranslations = {
	PRECEDENT: t('PRECEDENT'),
	SUIVANT: t('SUIVANT'),
	IMAGE_PLACEHOLDER: t('IMAGE_PLACEHOLDER'),
	EN_SAVOIR_PLUS: t('EN_SAVOIR_PLUS'),
	MOTS_CLES: t('MOTS_CLES'),
	GENRE: t('GENRE'),
	TAGS_FILTER: t('TYPE_PUBLIC'),
	DATE: t('DATE'),
	AUCUN_CONTENU: t('AUCUN_CONTENU'),
	TOUS: t('TOUS'),
	publicLabels: {
		children: t('PUBLIC_ENFANTS'),
		all_public: t('PUBLIC_TOUT_PUBLIC'),
		all_public_avertissment: t('PUBLIC_TOUT_PUBLIC_AVERTISSEMENT'),
		forbidden_12: t('PUBLIC_INTERDIT_12'),
		forbidden_16: t('PUBLIC_INTERDIT_16'),
		forbidden_18: t('PUBLIC_INTERDIT_18')
	},
	genreOptions: [
		{ key: t('GENRE_COMEDIE'), value: 'Comédie' },
		{ key: t('GENRE_DRAME'), value: 'Drame' },
		{ key: t('GENRE_ACTION'), value: 'Action' },
		{ key: t('GENRE_ANIMATION'), value: 'Animation' },
		{ key: t('GENRE_DOCUMENTAIRE'), value: 'Documentaire' }
	],
	dateOptions: [
		{ key: t('DATE_SEMAINE_PROCHAINE'), value: 'semaine_prochaine' },
		{ key: t('DATE_MOIS_PROCHAIN'), value: 'mois_prochain' },
		{ key: t('DATE_6_MOIS'), value: '6_mois' },
		{ key: t('DATE_1_AN'), value: '1_an' }
	],
	LANGUE: t('LANGUE'),
	langueOptions: [
		{ key: t('LANGUE_VF'), value: 'VF' },
		{ key: t('LANGUE_VOSTFR'), value: 'VOSTFR' }
	]
}

const PAYLOAD_URL = import.meta.env.PUBLIC_PAYLOAD_URL

const immanquableRes = await fetch(`${PAYLOAD_URL}/api/immanquable?collection=cinema&locale=${locale}`)
const immanquableData = (await immanquableRes.json()) as { docs: ImmanquableDoc[] }
const immanquables = immanquableData.docs ?? []

const IMMANQUABLE_PATHS: Record<string, (id: string) => string> = {
	art_vivant: (id) => `art-vivant/spectacle/${id}`,
	cinema: (id) => `cinema/seance/${id}`,
	exposition: () => 'exposition',
	parc_national: (id) => `parc-national/evenement/${id}`,
	autres_actualites: (id) => `autres-actualites/evenement/${id}`
}
const getImmanquableUrl = (item: ImmanquableDoc) =>
	getRelativeLocaleUrl(locale, IMMANQUABLE_PATHS[item._collection]?.(item.id) ?? 'cinema')
const getImmanquableImage = (item: ImmanquableDoc) => {
	const thumb = 'thumbnail' in item ? item.thumbnail : undefined
	const fallback = 'images' in item ? item.images?.[0]?.image : undefined
	const url = thumb?.url ?? fallback?.url
	return {
		src: url ? `${PAYLOAD_URL}${url}` : LayoutHome6.src,
		alt: thumb?.alt ?? ''
	}
}
---

<Layout title={t('CINEMA')}>
	<main id="main-content">

	<section
		class="relative grid h-[calc(100dvh-var(--header-height)+var(--header-overlap))] max-h-225 grid-cols-40 grid-rows-40 gap-2 sm:gap-2.5 md:gap-3.5 bg-[#345f6e] p-1.5 sm:p-3.5 pt-11.5 sm:pt-16 *:rounded-lg lg:rounded-b-3xl"
	>
		<div class="bg-cream relative col-span-24 col-start-1 row-span-17 row-start-1 overflow-hidden lg:p-5">
			<img src={LayoutHome1.src} alt="" loading="eager" class="absolute inset-0 h-full w-full object-cover lg:hidden" />
			<div class="bg-cream/80 absolute inset-0 lg:hidden"></div>
			<div class="hidden lg:block">
				<h2 class="pb-2 text-2xl lg:pb-3">{t('CINEMA_HERO_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-6">{t('CINEMA_HERO_SUB')}</p>
				<p class="text-sm">
					{t('CINEMA_DESC_PART1')}
					<br /><br />
					{t('CINEMA_DESC_PART2')}
					<br /><br />
					{t('CINEMA_DESC_PART3')}
				</p>
			</div>
		</div>
		<div class="bg-cream relative col-span-16 col-start-25 row-start-1 row-end-24 overflow-hidden md:row-end-21">
			<img src={LayoutHome3.src} alt="" loading="eager" fetchpriority="high" class="h-full w-full rounded-lg object-cover" />
		</div>
		<div class="bg-cream relative col-span-13 col-start-1 row-span-23 row-start-18 overflow-hidden">
			<img src={LayoutHome4.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
		</div>
		<div class="relative hidden overflow-hidden bg-[#be7a5a] md:col-span-13 md:col-start-14 md:row-span-17 md:row-start-24 md:block">
			<img src={LayoutHome5.src} alt="" loading="eager" class="h-full w-full rounded-lg object-cover" />
		</div>
		<div class="bg-cream relative col-span-27 col-start-14 row-start-24 row-end-41 flex flex-col gap-3 overflow-hidden p-3 md:col-span-14 md:col-start-27 md:row-start-21 md:gap-7 lg:p-5">
			{immanquables.length > 0 && (
				<>
					<h2 class="text-center text-xl! md:text-right">{t('LES_IMMANQUABLES')}</h2>
					{immanquables.length === 1 ? (
						<a
							href={getImmanquableUrl(immanquables[0])}
							aria-label={immanquables[0].title}
							class="shadow-card relative block flex-1 overflow-hidden rounded-3xl border border-foreground"
						>
							<img
								src={getImmanquableImage(immanquables[0]).src}
								alt={getImmanquableImage(immanquables[0]).alt}
								loading="eager"
								class="h-full w-full object-cover"
							/>
						</a>
					) : (
						<HoverImageSwap
							client:visible
							direction="horizontal"
							className="flex-1 min-h-0"
							rows={[{
								slots: immanquables.map((item, i) => {
									const img = getImmanquableImage(item)
									return {
										src: img.src,
										alt: img.alt || item.title,
										href: getImmanquableUrl(item),
										...(item.immanquable === 'coup_de_coeur' && { badge: t('COUP_DE_COEUR') }),
										...(item.immanquable === 'cine_passion' && { badge: 'Cine passion' }),
										...(i > 0 && { barClassName: ['bg-secondary', 'bg-secondary-muted', 'bg-primary'][(i - 1) % 3] })
									}
								}),
								defaultIndex: 0,
								height: 'h-full',
								width: 'w-full',
								cardStyle: true,
								compactPills: true
							}]}
						/>
					)}
				</>
			)}
		</div>
		<div class="bg-cream z-40 col-span-17 col-start-12 row-span-6 row-start-18 flex translate-x-[0.2rem] items-center justify-center overflow-hidden p-2 outline-8 outline-[#345f6e] sm:outline-10 md:outline-14">
			<h1 class="text-primary text-center text-2xl! leading-8 sm:text-3xl! sm:leading-10 font-medium! break-words lg:leading-14 lg:text-[42px]!">
				{t('CINEMA')}
			</h1>
		</div>
	</section>

	<section class="section-default lg:hidden">
		<article>
			<h2 class="pb-2 lg:pb-3">{t('CINEMA_HERO_TITRE')}</h2>
			<p class="distinguished pb-3 lg:pb-16">{t('CINEMA_HERO_SUB')}</p>
			<p class="pb-2 lg:w-2/3">{t('CINEMA_DESC_PART1')}</p>
			<p class="pb-2 lg:w-2/3">{t('CINEMA_DESC_PART2')}</p>
			<p class="lg:w-2/3">{t('CINEMA_DESC_PART3')}</p>
		</article>
	</section>

		{seances.docs.length > 0 && (
		<section class="section-default" id="cinema">
			<article>
				<h2 class="pb-3 lg:pb-16">{t('CINEMA_PROGRAMME_TITRE')}</h2>
				<p>{t('CINEMA_PROGRAMME_INTRO')}</p>
			</article>

			<CinemaGrid
				client:load
				initialData={seances}
				locale={locale}
				localePrefix={localePrefix}
				limit={SEANCES_LIMIT}
				payloadUrl={PAYLOAD_URL}
				showFilters={false}
				translations={cinemaTranslations}
			/>
		</section>
		)}

		{rdv.docs.length > 0 && (
		<section class="section-default bg-primary" id="rdv-cinema">
			<article class="grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-8 pb-12">
				<div class="lg:col-span-8 flex flex-col">
					<h2 class="text-foreground pb-2 lg:pb-3">{t('RDV_CINEMA')}</h2>
					<p class="distinguished pb-3 lg:pb-16">{t('RDV_CINEMA_INTRO')}</p>
					<p>{t('RDV_CINEMA_DESC')}</p>
				</div>
				<div class="lg:col-span-4 grid grid-cols-[2fr_3fr] gap-4 lg:gap-5 h-[420px]">
					<HoverImageSwap
						client:visible
						direction="vertical"
						rows={[{
							slots: [
								{ src: ThirdMediaImg.src, alt: '' },
								{ src: FirstMediaImg.src, alt: '', barClassName: 'bg-background' },
								{ src: SecondMediaImg.src, alt: '', barClassName: 'bg-secondary' }
							],
							defaultIndex: 0,
							height: 'h-full',
							width: 'w-full'
						}]}
					/>
					<div class="rounded-2xl overflow-hidden">
						<MyImage
							src={FourthMediaImg}
							alt=""
							width={420}
							height={450}
							layout="fullWidth"
							class="h-full w-full object-cover"
						/>
					</div>
				</div>
			</article>

			<div
				class="grid grid-cols-1 place-items-center gap-x-4 gap-y-8 *:max-w-80 *:min-w-75 md:grid-cols-2 lg:grid-cols-[repeat(auto-fit,minmax(300px,1fr))]"
			>
				{
					rdv.docs.map((item) => {
						const descText = item.synopsis.root.children
							.flatMap((para) => para.children)
							.filter((child) => child.type === 'text')
							.map((child) => child.text)
							.join(' ')

						return (
							<SpectacleCard
								title={item.title}
								href={`${localePrefix}/cinema/rdv-cinema/${item.id}`}
								locale={locale}
								description={descText}
								dateStart={item.date_start}
								genre={item.genre ?? ''}
								ctaLabel={t('EN_SAVOIR_PLUS')}
								imageSrc={item.thumbnail?.url}
								imageAlt={item.thumbnail?.alt}
								imageBlurhash={item.thumbnail?.blurhash}
							/>
						)
					})
				}
			</div>
		</section>
		)}

		{scolaire.docs.length > 0 && (
		<section class="section-default" id="scolaire">
			<article>
				<h2 class="pb-2 lg:pb-3">{t('CINEMA_SCOLAIRE_TITRE')}</h2>
				<p class="distinguished pb-3 lg:pb-16">{t('CINEMA_SCOLAIRE_INTRO')}</p>
				<p class="lg:w-2/3">{t('CINEMA_SCOLAIRE_DESC')}</p>
			</article>

			<CinemaGrid
				client:load
				initialData={scolaire}
				locale={locale}
				localePrefix={localePrefix}
				limit={SCOLAIRE_LIMIT}
				payloadUrl={PAYLOAD_URL}
				showFilters={false}
				linkPath="scolaire"
				translations={cinemaTranslations}
			/>
		</section>
		)}

		<section class="section-default pt-0" aria-label="Partenaires cinéma">
			<div class="grid grid-cols-2 place-items-center gap-8 lg:grid-cols-4 lg:gap-12">
				<MyImage src={VeoLogo} alt="VEO" width={180} height={109} class="h-auto max-h-16 w-auto rounded-none object-contain lg:max-h-20" />
				<MyImage src={AdrcLogo} alt="ADRC" width={240} height={168} class="h-auto max-h-16 w-auto rounded-none object-contain lg:max-h-20" />
				<MyImage src={AfcaeLogo} alt="AFCAE" width={260} height={152} class="h-auto max-h-16 w-auto rounded-none object-contain lg:max-h-20" />
				<MyImage
					src={CinephilaeLogo}
					alt="Cinephilae"
					width={180}
					height={96}
					class="h-auto max-h-16 w-auto rounded-none object-contain lg:max-h-20"
				/>
			</div>
		</section>
	</main>
</Layout>
