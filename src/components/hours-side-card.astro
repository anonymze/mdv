---
import { findGlobal } from '@/api/payload'
import { createTranslator, type I18n } from '@/i18n/translations'
import { getHoursForToday } from '@/lib/hours'
import type { Hour } from '@/types/hours'
import { getRelativeLocaleUrl } from 'astro:i18n'
import { SideCard } from './side-card'

interface Props {
	locale: I18n
}

const { locale } = Astro.props
const t = createTranslator(locale)

const hours = await findGlobal<Hour>('hours', { locale })
const { isClosed, today, openStart, openEnd } = getHoursForToday(hours)

const formatHourFr = (iso: string) => {
	const d = new Date(iso)
	const parts = d.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit', hour12: false, timeZone: 'Europe/Paris' }).split(':')
	const h = parseInt(parts[0], 10)
	const m = parts[1]
	return m === '00' ? `${h}h` : `${h}h${m}`
}
---

<SideCard client:media="(min-width: 1280px)" height="h-60" tabText={[t('HORAIRES')]} ariaLabel={t('PANNEAU_HORAIRES_OUVERTURE')}>
	<div class="flex h-full flex-col items-start px-4 py-5 text-left">
		<p class="text-sm capitalize text-white">
			{t('DATE_FROM')}{' '}
			<time datetime={today.toISOString().split('T')[0]}>
				{today.toLocaleDateString(locale, { weekday: 'long', day: 'numeric', month: 'long', timeZone: 'Europe/Paris' })}
			</time>
			&nbsp;:
		</p>

		{isClosed ? (
			<p class="font-serif text-3xl pt-2 w-full text-center text-white">{t('FERME')}</p>
		) : openStart && openEnd ? (
			<p class="font-serif text-3xl pt-2 w-full text-center text-white" itemscope itemtype="https://schema.org/OpeningHoursSpecification">
				<meta itemprop="opens" content={openStart} />
				<meta itemprop="closes" content={openEnd} />
				<time datetime={openStart}>{formatHourFr(openStart)}</time> - <time datetime={openEnd}>{formatHourFr(openEnd)}</time>
			</p>
		) : null}

		<p class="pt-6 pb-2 text-sm font-semibold text-white">{t('DE_LA_SAISON')}&nbsp;:</p>

		<div class="text-sm space-y-0.5">
			<p class="text-white">{t('LUNDI_SAMEDI')} : {formatHourFr(hours.horaires_base.base_start)} - {formatHourFr(hours.horaires_base.base_end)}</p>
			<p class="text-white">{t('DIMANCHE')} : {formatHourFr(hours.horaires_base.dimanche_start)} - {formatHourFr(hours.horaires_base.dimanche_end)}</p>
		</div>

		<a href={`${getRelativeLocaleUrl(locale, 'informations')}#horaires`} class="mt-auto text-xs underline underline-offset-4 text-white">
			{t('EN_SAVOIR_PLUS')}
		</a>
	</div>
</SideCard>
